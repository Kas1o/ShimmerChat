@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject IThemeService ThemeService

<div class="shimmer-layout @(isPortrait ? "portrait" : "landscape")">
    @if (isPortrait)
    {
        <header class="shimmer-topbar">
            <button class="hamburger-btn" @onclick="ToggleNav" aria-label="Toggle navigation">
                <i class="bi @(isNavExpanded ? "bi-x-lg" : "bi-list")"></i>
            </button>
            <div class="topbar-brand">
                <img src="@(ThemeService.CurrentTheme?.IsDarkMode == true ? "/shimmer-chat.png" : "/shimmer-chat-light-theme.png")" alt="ShimmerChat Logo" class="topbar-logo" />
                <span class="topbar-title">ShimmerChat</span>
            </div>
            <div class="topbar-spacer"></div>
        </header>
        @if (isNavExpanded)
        {
            <div class="shimmer-nav-overlay" @onclick="CloseNav">
                <nav class="shimmer-nav-dropdown" @onclick:stopPropagation="true">
                    <NavMenu IsPortrait="true" />
                </nav>
            </div>
        }
    }
    else
    {
        <aside class="shimmer-sidebar">
            <NavMenu />
        </aside>
    }

    <main class="shimmer-main">
        <article class="shimmer-content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

<ShimmerChat.Components.SubComponents.PopupMessageBox/>
<ShimmerChat.Components.SubComponents.ThemeCss/>


<style>
    .shimmer-layout {
        display: flex;
        height: 100vh;
        width: 100vw;
        overflow: hidden;
    }

    .shimmer-layout.landscape {
        flex-direction: row;
    }

    .shimmer-layout.portrait {
        flex-direction: column;
    }

    .shimmer-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background-color: var(--color-background);
    }

    .shimmer-content {
        flex: 1;
        padding: 24px;
        overflow-y: auto;
        overflow-x: hidden;
    }

    /* 竖屏顶部导航栏 */
    .shimmer-topbar {
        display: flex;
        align-items: center;
        height: 56px;
        min-height: 56px;
        background-color: var(--color-surface);
        border-bottom: 1px solid var(--color-border);
        padding: 0 16px;
        gap: 12px;
        z-index: 20;
    }

    .hamburger-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border: none;
        background: transparent;
        color: var(--color-text);
        font-size: 1.5rem;
        cursor: pointer;
        border-radius: var(--radius-md);
        transition: background-color 0.2s;
        flex-shrink: 0;
    }

    .hamburger-btn:hover {
        background-color: var(--color-hover);
    }

    .topbar-brand {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .topbar-logo {
        height: 28px;
        width: 28px;
    }

    .topbar-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--color-primary);
        white-space: nowrap;
    }

    .topbar-spacer {
        flex: 1;
    }

    /* 竖屏导航下拉覆盖层 */
    .shimmer-nav-overlay {
        position: fixed;
        top: 56px;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(0, 0, 0, 0.4);
        z-index: 30;
        animation: fadeIn 0.2s ease;
    }

    .shimmer-nav-dropdown {
        background-color: var(--color-surface);
        border-bottom: 1px solid var(--color-border);
        max-height: calc(100vh - 56px);
        overflow-y: auto;
        animation: slideDown 0.25s ease;
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @@keyframes slideDown {
        from { transform: translateY(-10px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }

    /* 竖屏内容区域调整 */
    .shimmer-layout.portrait .shimmer-content {
        padding: 16px;
    }
</style>
@code {
    private bool isPortrait;
    private bool isNavExpanded;
    private DotNetObjectReference<MainLayout>? dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create(this);
            isPortrait = await JS.InvokeAsync<bool>("getIsPortrait");
            await JS.InvokeVoidAsync("listenOrientation", dotNetRef);
            NavigationManager.LocationChanged += OnLocationChanged;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void OnOrientationChanged(bool portrait)
    {
        if (isPortrait != portrait)
        {
            isPortrait = portrait;
            isNavExpanded = false;
            StateHasChanged();
        }
    }

    private void ToggleNav()
    {
        isNavExpanded = !isNavExpanded;
    }

    private void CloseNav()
    {
        isNavExpanded = false;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (isPortrait && isNavExpanded)
        {
            isNavExpanded = false;
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        if (dotNetRef != null)
        {
            await JS.InvokeVoidAsync("unlistenOrientation");
            dotNetRef.Dispose();
        }
    }
}
