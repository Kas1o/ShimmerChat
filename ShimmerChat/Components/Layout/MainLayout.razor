@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject IThemeService ThemeService

<div class="shimmer-layout @(isPortrait ? "portrait" : "landscape")">
    @if (isPortrait)
    {
        <header class="shimmer-topbar">
            <button class="hamburger-btn" @onclick="ToggleNav" aria-label="Toggle navigation">
                <i class="bi @(isNavExpanded ? "bi-x-lg" : "bi-list")"></i>
            </button>
            <div class="topbar-brand">
                <img src="@(ThemeService.CurrentTheme?.IsDarkMode == true ? "/shimmer-chat.png" : "/shimmer-chat-light-theme.png")" alt="ShimmerChat Logo" class="topbar-logo" />
                <span class="topbar-title">ShimmerChat</span>
            </div>
            <div class="topbar-spacer"></div>
        </header>
        @if (isNavExpanded)
        {
            <div class="shimmer-nav-overlay" @onclick="CloseNav">
                <nav class="shimmer-nav-dropdown" @onclick:stopPropagation="true">
                    <NavMenu IsPortrait="true" />
                </nav>
            </div>
        }
    }
    else
    {
        <aside class="shimmer-sidebar">
            <NavMenu />
        </aside>
    }

    <main class="shimmer-main">
        <article class="shimmer-content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

<ShimmerChat.Components.SubComponents.PopupMessageBox/>
<ShimmerChat.Components.SubComponents.ThemeCss/>

@code {
    private bool isPortrait;
    private bool isNavExpanded;
    private DotNetObjectReference<MainLayout>? dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create(this);
            isPortrait = await JS.InvokeAsync<bool>("getIsPortrait");
            await JS.InvokeVoidAsync("listenOrientation", dotNetRef);
            NavigationManager.LocationChanged += OnLocationChanged;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void OnOrientationChanged(bool portrait)
    {
        if (isPortrait != portrait)
        {
            isPortrait = portrait;
            isNavExpanded = false;
            StateHasChanged();
        }
    }

    private void ToggleNav()
    {
        isNavExpanded = !isNavExpanded;
    }

    private void CloseNav()
    {
        isNavExpanded = false;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (isPortrait && isNavExpanded)
        {
            isNavExpanded = false;
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        if (dotNetRef != null)
        {
            try
            {
                await JS.InvokeVoidAsync("unlistenOrientation");
            }
            catch (JSDisconnectedException)
            {
                // 电路已断开，无法执行 JS interop，忽略
            }
            catch (ObjectDisposedException)
            {
                // JS 运行时已释放，忽略
            }
            dotNetRef.Dispose();
        }
    }
}
