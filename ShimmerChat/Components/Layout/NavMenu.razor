@using Microsoft.AspNetCore.Components.Routing
@using ShimmerChatLib.Interface
@using System.Reflection
@inject IPluginPanelService PluginPanelService
@inject ILocService Loc
@implements IDisposable

<div class="@(IsPortrait ? "shimmer-nav-portrait" : "")">
    @if (!IsPortrait)
    {
        <div class="shimmer-nav-header">
            <div class="shimmer-nav-brand">
                <img src="@(ThemeService.CurrentTheme?.IsDarkMode == true ? "/shimmer-chat.png" : "/shimmer-chat-light-theme.png")" alt="ShimmerChat Logo" class="shimmer-nav-logo" />
                <h1 class="shimmer-nav-title">@Loc["ShimmerChat"]</h1>
            </div>
        </div>

        <div class="shimmer-nav-divider"></div>
    }

    <nav class="shimmer-nav-menu">
        <div class="shimmer-nav-list">
            <div>
                <NavLink class="shimmer-nav-item" href="" Match="NavLinkMatch.All">
                    <div class="nav-item-content">
                        <span class="nav-icon"><i class="bi bi-house-door"></i></span>
                        <span class="nav-text">@Loc["Home"]</span>
                    </div>
                </NavLink>
            </div>

            <div>
                <NavLink class="shimmer-nav-item" href="generationmanager" Match="NavLinkMatch.All">
                    <div class="nav-item-content">
                        <span class="nav-icon"><i class="bi bi-diagram-3"></i></span>
                        <span class="nav-text">Pre-Generation</span>
                    </div>
                </NavLink>
            </div>

            <div>
                <NavLink class="shimmer-nav-item" href="postgeneration" Match="NavLinkMatch.All">
                    <div class="nav-item-content">
                        <span class="nav-icon"><i class="bi bi-arrow-repeat"></i></span>
                        <span class="nav-text">Post-Generation</span>
                    </div>
                </NavLink>
            </div>

            <div>
                <NavLink class="shimmer-nav-item" href="agentselect" Match="NavLinkMatch.All">
                    <div class="nav-item-content">
                        <span class="nav-icon"><i class="bi bi-person"></i></span>
                        <span class="nav-text">@Loc["Agents"]</span>
                    </div>
                </NavLink>
            </div>
            <div>
                <NavLink class="shimmer-nav-item" href="misc" Match="NavLinkMatch.All">
                    <div class="nav-item-content">
                        <span class="nav-icon"><i class="bi bi-ui-checks-grid"></i></span>
                        <span class="nav-text">@Loc["Misc"]</span>
                    </div>
                </NavLink>
            </div>

            <div class="shimmer-nav-section-label">@Loc["nav.section_representation"]</div>
            <div>
                <NavLink class="shimmer-nav-item" href="messagerender" Match="NavLinkMatch.All">
                    <div class="nav-item-content">
                        <span class="nav-icon"><i class="bi bi-eye"></i></span>
                        <span class="nav-text">@Loc["nav.message_render"]</span>
                    </div>
                </NavLink>
            </div>
            <div>
                <NavLink class="shimmer-nav-item" href="thememanager" Match="NavLinkMatch.All">
                    <div class="nav-item-content">
                        <span class="nav-icon"><i class="bi bi-palette"></i></span>
                        <span class="nav-text">@Loc["nav.theme_manager"]</span>
                    </div>
                </NavLink>
            </div>

            <div class="shimmer-nav-section-label">@Loc["nav.section_plugin_panels"]</div>
            @foreach (var panel in _pluginPanels)
            {
                <div>
                    <NavLink class="shimmer-nav-item" href="@($"pluginpanel/{Uri.EscapeDataString(panel.NameKey)}")" Match="NavLinkMatch.All">
                        <div class="nav-item-content">
                            <span class="nav-icon"><i class="bi @(panel.Icon ?? "bi-puzzle")"></i></span>
                            <span class="nav-text">@Loc[panel.NameKey]</span>
                        </div>
                    </NavLink>
                </div>
            }
        </div>
    </nav>

    @if (!IsPortrait)
    {
    <div class="shimmer-nav-footer">
        <div class="shimmer-nav-locale">
            <select class="locale-select" @bind="_selectedCulture" @bind:after="OnCultureChanged">
                @foreach (var c in Loc.SupportedCultures)
                {
                    <option value="@c">@c</option>
                }
            </select>
        </div>
        <div class="shimmer-nav-version">
            <span>@Loc["nav.version_prefix"] @Version</span>
        </div>
    </div>
    }
</div>

@code {
    [Parameter]
    public bool IsPortrait { get; set; }

    [Inject]
    public required IThemeService ThemeService { get; set; }

    public string? Version { get; set; } = default!; // 由 OnInitialized 设置

    private List<PluginPanelInfo> _pluginPanels = new();
    private string _selectedCulture = "zh-CN";

    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += HandleThemeChanged;
        Version = typeof(Program).Assembly
            .GetCustomAttributes<AssemblyInformationalVersionAttribute>()
            ?.First()?.InformationalVersion ?? "Unknown";
        _selectedCulture = Loc.CurrentCulture;
        _pluginPanels = PluginPanelService.GetPluginPanels()
            .Where(p => p.PanelDisplayPlace == ShimmerChatLib.Panel.PanelDisplayPlace.Settings)
            .OrderBy(p => p.Order)
            .ToList();
    }

    private void HandleThemeChanged(ShimmerChatLib.Models.Theme theme)
    {
        // 触发组件重新渲染
        StateHasChanged();
    }

    public void Dispose()
    {
        // 取消订阅，避免内存泄漏
        ThemeService.OnThemeChanged -= HandleThemeChanged;
    }

    private async Task OnCultureChanged()
    {
        if (_selectedCulture != Loc.CurrentCulture)
        {
            Loc.SetCulture(_selectedCulture);
            StateHasChanged();
        }
    }
}

