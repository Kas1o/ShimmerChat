@page "/agent/{AgentGuid}/{ChatGuid}"
@using ShimmerChatLib
@using SharperLLM.API
@using System.Collections.ObjectModel
@using System.Threading
@using ShimmerChat.Singletons
@using Microsoft.JSInterop

@inject IGenerationManagerV2 generationManager
@inject IPopupService popupService
@inject IJSRuntime JS
@inject IKVDataService KVData
@inject IMessageStoreService messageStore
@inject ILocService Loc
@inject NavigationManager navigation
@inject ILogger<AgentChatPage> logger


@if (chat != null)
{
	<div class="chat-page">
		<div class="chat-topbar">
			<button class="chat-back" @onclick="BackToAgentPage">← @agent!.Name</button>
		</div>

		<div class="chat-messages" @ref="ChatMainElement" @onscroll="OnChatScroll">
			<div class="chat-messages-inner">
				@if (virtualize)
				{
					<Virtualize Items="messages" Context="message">
						<ShimmerChat.Components.SubComponents.Message Delete="() => DeleteMessage(message)" RegenerateFrom="() => RegenerateFromMessage(message)" ContinueFrom="() => ContinueFromMessage(message)" DeleteFrom="() => DeleteMessagesFrom(message)" message="message" MakeDirty="GetDirty" AgentName="@agent.Name" Chat="@chat" Agent="@agent" />
					</Virtualize>
				}
				else
				{
					@foreach (var message in messages)
					{
						<ShimmerChat.Components.SubComponents.Message Delete="() => DeleteMessage(message)" RegenerateFrom="() => RegenerateFromMessage(message)" ContinueFrom="() => ContinueFromMessage(message)" DeleteFrom="() => DeleteMessagesFrom(message)" message="message" MakeDirty="GetDirty" AgentName="@agent.Name" Chat="@chat" Agent="@agent" />
					}
				}
			</div>
		</div>

		@if (!isUserAtBottom)
		{
			<button class="chat-scroll-btn" @onclick="ScrollToBottomManually">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
					<path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
				</svg>
			</button>
		}

		<div class="chat-input">
			<textarea @ref="inputArea"
				value="@inputText" @oninput="OnInputResize"
				@onkeydown="@(e => CheckEnter(e))"
				placeholder="@Loc["chat.input_placeholder"]"
				rows="1"></textarea>
			@if (generating)
			{
				<button class="chat-input-stop" @onclick="OnClickStopGenerationButton">
					<svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><rect x="3" y="3" width="10" height="10" rx="1"/></svg>
				</button>
			}
			else
			{
				<button class="chat-input-send" @onclick="OnClickSendButton" disabled="@(string.IsNullOrWhiteSpace(inputText))">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13"/><path d="M22 2L15 22L11 13L2 9L22 2Z"/></svg>
				</button>
			}
		</div>
	</div>
	<ShimmerChat.Components.SubComponents.ChatPluginPanelContainer AgentGuid="agent.Guid" ChatGuid="chat.Guid" @ref="ChatPluginPanelContainer"/>
}

@if(chat == null)
{
	<p>@Loc.Format("chat.not_found", AgentGuid, ChatGuid)</p>
}

@code {

	#region 参数
	[Parameter]
	public string AgentGuid { get; set; } = string.Empty;
	[Parameter]
	public string ChatGuid { get; set; } = string.Empty; // The chat name to load
	#endregion

	#region 成员

	/// <summary>
	/// 指向聊天容器，用于在生成时自动滚动到底部 <see cref="AddLLMReplyStream"/> <see cref="MiscSettingsPage._autoScrollDown"/>
	/// </summary>
	ElementReference ChatMainElement;
	ElementReference inputArea;

	bool generating = false; // 表示当前是否在生成中
	CancellationTokenSource? cts; // 用于取消生成任务的令牌源
	private Agent? agent; // 当前对话所属的Agent引用
	private Chat? chat; // 当前对话的引用

	/// <summary>
	/// 消息列表的引用，由 <see cref="OnParametersSetAsync" /> 设置为对 <see cref="Chat.Messages"/> 的 引用。
	/// </summary>
	ObservableCollection<Message> messages = new ObservableCollection<Message>();
	string inputText { get; set; } = ""; // 当前正在输入的文本。

	bool throwExceptionInsteadOfPopupErrorMessage = false; // 抛出异常设置
	bool autoScrollDown = true; // 自动滚动设置
	bool virtualize = false;
	bool isUserAtBottom = true; // 用户是否位于底部

	ShimmerChat.Components.SubComponents.ChatPluginPanelContainer? ChatPluginPanelContainer;
	#endregion

	#region 交互
	private bool _skipNextInput;

	private async void OnInputResize(ChangeEventArgs e)
	{
		if (_skipNextInput) { _skipNextInput = false; return; }
		inputText = e.Value?.ToString() ?? string.Empty;
		await JS.InvokeVoidAsync("autoResizeTextarea", inputArea);
	}
	async Task CheckEnter(KeyboardEventArgs e)
	{
		if (e.Key == "Enter" && !e.ShiftKey && !generating) // 检测是否按下 Enter 键
		{
			_skipNextInput = true;      // 标记：下次 oninput 不更新
			await Send(); // 无论输入是否为空，都调用Send方法
		}
	}
	async Task OnClickStopGenerationButton()
	{
		StopGeneration();
	}
	async Task OnClickSendButton()
	{
		await Send();
	}
	void BackToAgentPage()
	{
		navigation.NavigateTo($"/agent/{AgentGuid}");
	}
	async Task OnChatScroll()
	{
		try
		{
			bool atBottom = await JS.InvokeAsync<bool>("isScrolledToBottom", ChatMainElement, 50);
			if (isUserAtBottom != atBottom)
			{
				isUserAtBottom = atBottom;
				await InvokeAsync(StateHasChanged);
			}
		}
		catch (Exception)
		{
		}
	}
	async Task ScrollToBottomManually()
	{
		try
		{
			await JS.InvokeVoidAsync("scrollToBottom", ChatMainElement);
			isUserAtBottom = true;
			await InvokeAsync(StateHasChanged);
		}
		catch (Exception)
		{
		}
	}
	#endregion

	#region 逻辑
	async Task Send()
	{
		// 取消之前可能存在的生成任务
		CancelPreviousGeneration();

		if (chat == null || agent == null)
		{
			return;
		}

		// 只有当输入不为空时才添加用户消息
		if (!string.IsNullOrWhiteSpace(inputText))
			if (inputText.Trim().Length > 0)
			{
				var message = new Message()
				{
					message = new SharperLLM.Util.ChatMessage
					{
						Content= inputText // 使用输入框的内容
					},
					timestamp = DateTime.Now, // 设置消息的时间戳
					sender = ShimmerChatLib.Sender.User // 设置发送者，可以是 "User" 或其他标识
				};

				// 添加消息到聊天
				chat.AddMessage(message);
				chat.SaveMessage(messageStore, message);
				ChatPluginPanelContainer?.OnUserMessage(message);
				inputText = ""; // 清空输入框
				GetDirty(); // 标记为脏数据以保存
			}

		// 无论输入是否为空，都启动AI生成任务
		_ = Task.Run(AddLLMReplyStream);
	}
	/// <summary>
	/// 获取当前正在生成的消息
	/// </summary>
	private Message? GetGeneratingMessage()
	{
		return messages.FirstOrDefault(m => m.IsGenerating);
	}

	void StopGeneration()
	{
		if (cts != null)
		{
			try
			{
				cts.Cancel();
				cts.Dispose();
				cts = null;

				// 标记当前AI消息为完成状态
				var generatingMessage = GetGeneratingMessage();
				if (generatingMessage != null)
				{
					generatingMessage.GenerationState = MessageGenerationState.Completed;
				}

				generating = false;
				InvokeAsync(StateHasChanged);
			}
			catch (Exception ex)
			{
				if (throwExceptionInsteadOfPopupErrorMessage)
				{
					throw;
				}
				else
				{
					popupService.ShowAsync(ex.Message, Loc["chat.stop_error"]);
				}
			}
		}
	}
	async Task AddLLMReplyStream()
	{
		if (agent == null || chat == null)
			return;

		generating = true;

		// 创建新的CancellationTokenSource
		cts = new CancellationTokenSource();
		var cancellationToken = cts.Token;

		try
		{
			await generationManager.GenerateStreamAsync(
				agent, chat,
				onStreamDelta: async (accumulated) =>
				{
					// 在第一个 delta 时创建消息
					var regeneratingMessage = messages.FirstOrDefault(m => m.GenerationState == MessageGenerationState.Regenerating);
					Message generatingMessage;

					if (regeneratingMessage != null)
					{
						generatingMessage = regeneratingMessage;
						if (generatingMessage.CurrentVersion != null)
						{
							generatingMessage.CurrentVersion.Content = "";
							generatingMessage.CurrentVersion.thinking = null;
							generatingMessage.CurrentVersion.toolCalls = null;
						}
						generatingMessage.GenerationState = MessageGenerationState.Generating;
						chat.SaveMessage(messageStore, generatingMessage);
					}
					else
					{
						var existingGenerating = messages.FirstOrDefault(m => m.GenerationState == MessageGenerationState.Generating);
						if (existingGenerating != null)
						{
							generatingMessage = existingGenerating;
						}
						else
						{
							generatingMessage = new Message
							{
								message = new SharperLLM.Util.ChatMessage{ Content = "", thinking = string.Empty},
								timestamp = DateTime.Now,
								sender = ShimmerChatLib.Sender.AI,
								GenerationState = MessageGenerationState.Generating
							};
							messages.Add(generatingMessage);
							chat.SaveMessage(messageStore, generatingMessage);
						}
					}

					// 更新消息内容
					if (!string.IsNullOrEmpty(accumulated.Body.Content))
					{
						if (generatingMessage.CurrentVersion != null)
							generatingMessage.CurrentVersion.Content = accumulated.Body.Content;
						else
							generatingMessage.message = new SharperLLM.Util.ChatMessage { Content = accumulated.Body.Content };
					}

					if (accumulated.Body.thinking != null)
					{
						if (generatingMessage.CurrentVersion != null)
							generatingMessage.CurrentVersion.thinking = accumulated.Body.thinking;
						else if (generatingMessage.message != null)
							generatingMessage.message.thinking = accumulated.Body.thinking;
					}

					if (accumulated.Body.toolCalls != null)
					{
						if (generatingMessage.CurrentVersion != null)
							generatingMessage.CurrentVersion.toolCalls = accumulated.Body.toolCalls;
						else if (generatingMessage.message != null)
							generatingMessage.message.toolCalls = accumulated.Body.toolCalls;
					}

					if (autoScrollDown && isUserAtBottom)
					{
						await JS.InvokeVoidAsync("scrollToBottom", ChatMainElement);
					}

					await InvokeAsync(StateHasChanged);
				},
				onAssistantComplete: async (accumulated) =>
				{
					var generatingMessage = messages.FirstOrDefault(m => m.GenerationState == MessageGenerationState.Generating);
					if (generatingMessage != null)
					{
						generatingMessage.GenerationState = MessageGenerationState.Completed;
						chat.SaveMessage(messageStore, generatingMessage);
						ChatPluginPanelContainer?.OnAgentMessage(generatingMessage);
					}
					await InvokeAsync(StateHasChanged);
				},
				// 处理工具调用的回调
				onToolCall: (toolCalls) =>
				{
					// 触发UI刷新
					InvokeAsync(StateHasChanged);
				},
				// 处理工具结果的回调
				onToolResult: (tuple) =>
				{
					var newMessage = new Message
					{
						message = new SharperLLM.Util.ChatMessage { Content = tuple.resp, id = tuple.id, thinking = null },
						timestamp = DateTime.Now,
						sender = ShimmerChatLib.Sender.ToolResult
					};
					// 工具调用结果
					messages.Add(newMessage);
					chat.SaveMessage(messageStore, newMessage);

					ChatPluginPanelContainer?.OnToolCallResult(newMessage);

					if (autoScrollDown && isUserAtBottom)
					{
						JS.InvokeVoidAsync("scrollToBottom", ChatMainElement);
					}
					// 触发UI刷新
					InvokeAsync(StateHasChanged);
				},
				cancellationToken
			);
		}
		catch (OperationCanceledException)
		{
			// 操作被用户取消，这是预期行为，不需要显示错误
		}
		catch (Exception ex)
		{
			// 发生错误时，标记所有生成中的消息为完成状态
			foreach (var msg in messages.Where(m => m.IsGenerating))
			{
				msg.GenerationState = MessageGenerationState.Completed;
			}

			if(throwExceptionInsteadOfPopupErrorMessage)
			{
				throw;
			}
			else
			{
				popupService.ShowAsync($"{ex.Message} \n {ex.InnerException?.Message ?? ""}", Loc.Format("chat.gen_error", ex.Source));
			}
		}
		finally
		{
			generating = false;
			cts?.Dispose();
			cts = null;
			GetDirty();
			await Refresh();

			// AI生成完成时调用通知
			await ShowNotificationWhenCompleted();
		}
	}

	/// <summary>
	/// 继续生成流式响应，对指定消息附加 prefix: true 参数
	/// </summary>
	async Task AddLLMReplyStreamContinuation(Message continuationMessage)
	{
		if (agent == null || chat == null || continuationMessage == null)
			return;

		generating = true;

		// 创建新的CancellationTokenSource
		cts = new CancellationTokenSource();
		var cancellationToken = cts.Token;

		try
		{
			continuationMessage.GenerationState = MessageGenerationState.Generating;
			string originalContent = continuationMessage.CurrentVersion?.Content ?? "";

			await generationManager.GenerateStreamAsync(
				agent, chat,
				onStreamDelta: async (accumulated) =>
				{
					// 将新内容追加到原始内容后面
					if (!string.IsNullOrEmpty(accumulated.Body.Content))
					{
						if (continuationMessage.CurrentVersion != null)
							continuationMessage.CurrentVersion.Content = originalContent + accumulated.Body.Content;
					}

					if (accumulated.Body.thinking != null)
					{
						if (continuationMessage.CurrentVersion != null)
							continuationMessage.CurrentVersion.thinking = accumulated.Body.thinking;
					}

					if (autoScrollDown && isUserAtBottom)
					{
						await JS.InvokeVoidAsync("scrollToBottom", ChatMainElement);
					}

					await InvokeAsync(StateHasChanged);
				},
				onAssistantComplete: async (accumulated) =>
				{
					continuationMessage.GenerationState = MessageGenerationState.Completed;
					continuationMessage.IsContinuation = false;
					chat.SaveMessage(messageStore, continuationMessage);
					ChatPluginPanelContainer?.OnAgentMessage(continuationMessage);
					await InvokeAsync(StateHasChanged);
				},
				onToolCall: null!,
				onToolResult: null!,
				cancellationToken
			);
		}
		catch (OperationCanceledException)
		{
			continuationMessage.IsContinuation = false;
			// 操作被用户取消，这是预期行为，不需要显示错误
		}
		catch (Exception ex)
		{
			continuationMessage.IsContinuation = false;
			// 发生错误时，标记所有生成中的消息为完成状态
			foreach (var msg in messages.Where(m => m.IsGenerating))
			{
				msg.GenerationState = MessageGenerationState.Completed;
			}

			if(throwExceptionInsteadOfPopupErrorMessage)
			{
				throw;
			}
			else
			{
				popupService.ShowAsync($"{ex.Message} \n {ex.InnerException?.Message ?? ""}", Loc.Format("chat.gen_error", ex.Source));
			}
		}
		finally
		{
			generating = false;
			cts?.Dispose();
			cts = null;
			GetDirty();
			await Refresh();

			// AI生成完成时调用通知
			await ShowNotificationWhenCompleted();
		}
	}

	void CancelPreviousGeneration()
	{
		if (cts != null)
		{
			cts.Cancel();
			cts.Dispose();
			cts = null;
		}

		// 如果有正在生成的消息，标记为完成状态
		var generatingMessage = GetGeneratingMessage();
		if (generatingMessage != null)
		{
			generatingMessage.GenerationState = MessageGenerationState.Completed;
		}
	}
	async Task DeleteMessage(Message message)
	{
		if (message.IsGenerating) StopGeneration();
		chat?.DeleteMessage(messageStore, message);
		GetDirty();
		await Refresh();
	}
	async Task DeleteMessagesFrom(Message message)
	{
		var count = messages.Count - messages.IndexOf(message) - 1;
		var confirmed = await popupService.ShowAsync(
			string.Format(Loc["POPUP_DELETE_FROM"], count),
			Loc["POPUP_DELETE_FROM_TITLE"], showCancel: true);
		if (!confirmed) return;

		if (message.IsGenerating) StopGeneration();
		var idx = messages.IndexOf(message);
		if (idx < 0) return;
		for (int i = messages.Count - 1; i >= idx; i--)
			chat?.DeleteMessage(messageStore, messages[i]);
		GetDirty();
		await Refresh();
	}
	async Task RegenerateFromMessage(Message message)
	{
		// 停止当前可能正在进行的生成
		StopGeneration();

		// 找到消息的索引
		int messageIndex = messages.IndexOf(message);

		// 如果找不到消息，直接返回
		if (messageIndex == -1) return;

		// 保存当前消息作为版本（如果内容不为空）
		var currentContent = message.CurrentVersion?.Content ?? "";
		var currentThinking = message.CurrentVersion?.thinking ?? "";
		var currentToolCalls = message.CurrentVersion?.toolCalls;

		if (!string.IsNullOrEmpty(currentContent))
		{
			// 将当前内容添加为新版本
			var versionMessage = new SharperLLM.Util.ChatMessage
			{
				Content = currentContent,
				thinking = currentThinking,
				toolCalls = currentToolCalls != null ? new List<SharperLLM.API.ToolCall>(currentToolCalls) : null
			};
			message.AddVersion(versionMessage);
		}

		// 标记消息为 Regenerating 状态，AddLLMReplyStream 会识别这个状态
		message.GenerationState = MessageGenerationState.Regenerating;

		// 删除此消息之后的所有消息
		for (int i = messages.Count - 1; i > messageIndex; i--)
		{
			messages.RemoveAt(i);
		}

		// 重新持久化所有剩余消息
		chat?.SaveAllMessages(messageStore);

		// 保存更改
		GetDirty();
		await Refresh();

		// 启动新的AI回复生成
		_ = Task.Run(AddLLMReplyStream);
	}

	/// <summary>
	/// 从指定消息继续生成（使用 prefix continuation 功能）
	/// </summary>
	async Task ContinueFromMessage(Message message)
	{
		// 停止当前可能正在进行的生成
		StopGeneration();

		// 找到消息的索引
		int messageIndex = messages.IndexOf(message);

		// 如果找不到消息，直接返回
		if (messageIndex == -1) return;

		// 确保是AI消息
		if (message.sender != ShimmerChatLib.Sender.AI) return;

		// 标记消息为继续状态
		message.IsContinuation = true;

		// 保存更改
		GetDirty();
		await Refresh();

		// 启动继续生成
		_ = Task.Run(() => AddLLMReplyStreamContinuation(message));
	}
	#endregion

	#region 初始化 & 参数设置
	protected override void OnInitialized()
	{
		if (bool.TryParse(KVData.Read("App", "throw_exception"), out var result))
		{
			throwExceptionInsteadOfPopupErrorMessage = result;
		}
		if (bool.TryParse(KVData.Read("App", "auto_scroll_down"), out var autoscroll))
		{
			autoScrollDown = autoscroll;
		}
		if (bool.TryParse(KVData.Read("App", "virtualize"), out var virt))
		{
			virtualize = virt;
		}
	}
	protected override async Task OnParametersSetAsync()
	{
		agent = null;
		chat = null;
		messages = new ObservableCollection<Message>();

		if (Guid.TryParse(AgentGuid, out var guid))
		{
			try
			{
				agent = Agent.Load(guid, KVData);
				if (agent != null)
				{
					if (Guid.TryParse(ChatGuid, out var chatGuid) && agent.ChatGuids.Contains(chatGuid))
					{
						chat = Chat.LoadAndMigrate(chatGuid, KVData, messageStore);
						chat.LoadAllMessages(messageStore);
						messages = chat.Messages;
					}
				}
			}
			catch (Exception)
			{
				agent = null;
				chat = null;
				messages = new ObservableCollection<Message>();
			}
		}

		await base.OnParametersSetAsync();
	}

	private bool _hasRendered;

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			_hasRendered = true;
		}

		if (_hasRendered && autoScrollDown && chat != null)
		{
			await JS.InvokeVoidAsync("scrollToBottom", ChatMainElement);
			_hasRendered = false;
		}
	}
	#endregion

	#region IO
	private async Task ShowNotificationWhenCompleted()
	{
		try
		{
			// 检查用户是否启用了通知
			var notificationsEnabled = false;
			var notificationsEnabledStr = KVData.Read("App", "enable_notifications");
			if (bool.TryParse(notificationsEnabledStr, out var result))
			{
				notificationsEnabled = result;
			}

			// 如果用户未启用通知，则直接返回
			if (!notificationsEnabled)
			{
				return;
			}

			// 检查是否有AI消息
			var aiMessage = messages.LastOrDefault(m => m.sender == ShimmerChatLib.Sender.AI);
			if (aiMessage != null && !string.IsNullOrEmpty(aiMessage.CurrentVersion?.Content))
			{
				// 准备通知选项
				var notificationOptions = new
				{
					body = aiMessage.CurrentVersion.Content.Length > 100 ? aiMessage.CurrentVersion.Content.Substring(0, 100) + "..." : aiMessage.CurrentVersion.Content,
					icon = Assets["favicon.png"], // 可以使用项目中的图标
				};

				// 调用JavaScript中的通知函数
				await JS.InvokeVoidAsync("showNotification", Loc.Format("chat.new_message_notification", agent?.Name), notificationOptions);
			}
		}
		catch (Exception ex)
		{
			// 如果通知失败，记录错误但不中断程序
			logger.LogError($"显示通知时出错: {ex.Message}");
		}
	}
	void GetDirty()
	{
		if (chat == null) return;
		chat.LastModifyTime = DateTime.Now;
		chat.Save(KVData);
		if (agent != null)
		{
			agent.MoveChatToTop(chat.Guid);
			agent.Save(KVData);
		}
	}
	async Task Refresh()
	{
		await InvokeAsync(StateHasChanged);
	}
	#endregion
}
