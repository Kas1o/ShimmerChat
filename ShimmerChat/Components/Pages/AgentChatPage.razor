@page "/agent/{AgentGuid}/{ChatGuid}"
@using ShimmerChatLib
@using ShimmerChatLib.Generation
@using System.Collections.ObjectModel
@using System.Threading
@using Microsoft.JSInterop

@inject GenerationSessionService sessionService
@inject IPopupService popupService
@inject IJSRuntime JS
@inject IKVDataService KVData
@inject IMessageStoreService messageStore
@inject ILocService Loc
@inject NavigationManager navigation
@inject ILogger<AgentChatPage> logger
@implements IAsyncDisposable


@if (chat != null)
{
	<div class="chat-page">
		<div class="chat-topbar">
			<button class="chat-back" @onclick="BackToAgentPage">← @agent!.Name</button>
			@if (session != null && session.Phase != null)
			{
				<span class="generation-phase @($"phase-{session.Phase}")">
					<span class="phase-dot"></span>
					@switch (session.Phase)
					{
						case "pre":
							@Loc["chat.phase_pre"]
							break;
						case "gen":
							@Loc["chat.phase_gen"]
							break;
						case "post":
							@Loc["chat.phase_post"]
							break;
					}
				</span>
			}
		</div>

		<div class="chat-messages" @ref="ChatMainElement" @onscroll="OnChatScroll">
			<div class="chat-messages-inner">
				@if (virtualize)
				{
					<Virtualize Items="messages" Context="message">
						<ShimmerChat.Components.SubComponents.Message Delete="async () => await DeleteMessage(message)" RegenerateFrom="async () => await RegenerateFromMessage(message)" ContinueFrom="async () => await ContinueFromMessage(message)" DeleteFrom="async () => await DeleteMessagesFrom(message)" message="message" MakeDirty="GetDirty" AgentName="@agent.Name" Chat="@chat" Agent="@agent" />
					</Virtualize>
				}
				else
				{
					@foreach (var message in messages)
					{
						<ShimmerChat.Components.SubComponents.Message Delete="async () => await DeleteMessage(message)" RegenerateFrom="async () => await RegenerateFromMessage(message)" ContinueFrom="async () => await ContinueFromMessage(message)" DeleteFrom="async () => await DeleteMessagesFrom(message)" message="message" MakeDirty="GetDirty" AgentName="@agent.Name" Chat="@chat" Agent="@agent" />
					}
				}
			</div>
		</div>

		@if (!isUserAtBottom)
		{
			<button class="chat-scroll-btn" @onclick="ScrollToBottomManually">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
					<path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
				</svg>
			</button>
		}

		<div class="chat-input">
			<textarea @ref="inputArea"
				value="@inputText" @oninput="OnInputResize"
				@onkeydown="@(e => CheckEnter(e))"
				placeholder="@Loc["chat.input_placeholder"]"
				rows="1"></textarea>
			@if (session != null && session.IsActive)
			{
				<button class="chat-input-stop" @onclick="OnClickStopGenerationButton">
					<svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><rect x="3" y="3" width="10" height="10" rx="1"/></svg>
				</button>
			}
			else
			{
				<button class="chat-input-send" @onclick="OnClickSendButton" disabled="@(string.IsNullOrWhiteSpace(inputText))">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13"/><path d="M22 2L15 22L11 13L2 9L22 2Z"/></svg>
				</button>
			}
		</div>
	</div>
	<ShimmerChat.Components.SubComponents.ChatPluginPanelContainer AgentGuid="agent.Guid" ChatGuid="chat.Guid" @ref="ChatPluginPanelContainer"/>
}

@if(chat == null)
{
	<p>@Loc.Format("chat.not_found", AgentGuid, ChatGuid)</p>
}

@code {

	#region 参数
	[Parameter]
	public string AgentGuid { get; set; } = string.Empty;
	[Parameter]
	public string ChatGuid { get; set; } = string.Empty;
	#endregion

	#region 成员

	ElementReference ChatMainElement;
	ElementReference inputArea;

	/// <summary>
	/// 当前生成会话。为 null 表示没有活跃会话。离开页面后会话继续在后台运行。
	/// </summary>
	private GenerationSession? session;

	private Agent? agent;
	private Chat? chat;

	/// <summary>
	/// 当前显示的消息列表。会话活跃时指向 session.Chat.Messages，否则指向本地加载的 chat.Messages。
	/// </summary>
	ObservableCollection<Message> messages = new();

	string inputText { get; set; } = "";

	bool throwExceptionInsteadOfPopupErrorMessage = false;
	bool autoScrollDown = true;
	bool virtualize = false;
	bool isUserAtBottom = true;

	ShimmerChat.Components.SubComponents.ChatPluginPanelContainer? ChatPluginPanelContainer;
	#endregion

	#region 交互
	private bool _skipNextInput;

	private async void OnInputResize(ChangeEventArgs e)
	{
		if (_skipNextInput) { _skipNextInput = false; return; }
		inputText = e.Value?.ToString() ?? string.Empty;
		await JS.InvokeVoidAsync("autoResizeTextarea", inputArea);
	}
	async Task CheckEnter(KeyboardEventArgs e)
	{
		if (e.Key == "Enter" && !e.ShiftKey && (session == null || !session.IsActive))
		{
			_skipNextInput = true;
			await Send();
		}
	}
	async Task OnClickStopGenerationButton()
	{
		if (session == null) return;

		var postProcessing = messages.FirstOrDefault(m => m.GenerationState == MessageGenerationState.PostProcessing);
		if (postProcessing != null)
		{
			var confirmed = await popupService.ShowAsync(
				Loc["chat.stop_post_processing_warn"],
				Loc["chat.stop_warn_title"], showCancel: true);
			if (!confirmed) return;
		}
		await sessionService.StopGeneration(ChatGuid);
	}
	async Task OnClickSendButton()
	{
		await Send();
	}
	void BackToAgentPage()
	{
		navigation.NavigateTo($"/agent/{AgentGuid}");
	}
	async Task OnChatScroll()
	{
		try
		{
			bool atBottom = await JS.InvokeAsync<bool>("isScrolledToBottom", ChatMainElement, 50);
			if (isUserAtBottom != atBottom)
			{
				isUserAtBottom = atBottom;
				await InvokeAsync(StateHasChanged);
			}
		}
		catch (Exception) { }
	}
	async Task ScrollToBottomManually()
	{
		try
		{
			await JS.InvokeVoidAsync("scrollToBottom", ChatMainElement);
			isUserAtBottom = true;
			await InvokeAsync(StateHasChanged);
		}
		catch (Exception) { }
	}
	#endregion

	#region 逻辑
	async Task Send()
	{
		if (chat == null || agent == null)
			return;

		// 取消之前的生成
		sessionService.CancelPreviousGeneration(ChatGuid);

		// 添加用户消息
		if (!string.IsNullOrWhiteSpace(inputText) && inputText.Trim().Length > 0)
		{
			var message = new Message()
			{
				message = new SharperLLM.Util.ChatMessage { Content = inputText },
				timestamp = DateTime.Now,
				sender = ShimmerChatLib.Sender.User
			};

			chat.AddMessage(message);
			chat.SaveMessage(messageStore, message);

			session?.NotifyUserMessageAdded(message);
			ChatPluginPanelContainer?.OnUserMessage(message);

			inputText = "";
			GetDirty();
		}

		// 启动后台生成
		session = sessionService.GetOrCreateSession(ChatGuid, AgentGuid);
		SubscribeToSession(session);
		sessionService.StartGeneration(session, agent, chat, throwExceptionInsteadOfPopupErrorMessage);
	}

	async Task DeleteMessage(Message message)
	{
		if (message.IsGenerating)
		{
			await sessionService.StopGeneration(ChatGuid);
		}
		chat?.DeleteMessage(messageStore, message);
		GetDirty();
		await Refresh();
	}
	async Task DeleteMessagesFrom(Message message)
	{
		var count = messages.Count - messages.IndexOf(message) - 1;
		var confirmed = await popupService.ShowAsync(
			string.Format(Loc["POPUP_DELETE_FROM"], count),
			Loc["POPUP_DELETE_FROM_TITLE"], showCancel: true);
		if (!confirmed) return;

		if (message.IsGenerating)
			await sessionService.StopGeneration(ChatGuid);

		var idx = messages.IndexOf(message);
		if (idx < 0) return;
		for (int i = messages.Count - 1; i >= idx; i--)
			chat?.DeleteMessage(messageStore, messages[i]);
		GetDirty();
		await Refresh();
	}
	async Task RegenerateFromMessage(Message message)
	{
		await sessionService.StopGeneration(ChatGuid);

		int messageIndex = messages.IndexOf(message);
		if (messageIndex == -1) return;

		var currentContent = message.CurrentVersion?.Content ?? "";
		var currentThinking = message.CurrentVersion?.thinking ?? "";
		var currentToolCalls = message.CurrentVersion?.toolCalls;

		if (!string.IsNullOrEmpty(currentContent))
		{
			var versionMessage = new SharperLLM.Util.ChatMessage
			{
				Content = currentContent,
				thinking = currentThinking,
				toolCalls = currentToolCalls != null ? new List<SharperLLM.API.ToolCall>(currentToolCalls) : null
			};
			message.AddVersion(versionMessage);
		}

		message.GenerationState = MessageGenerationState.Regenerating;

		for (int i = messages.Count - 1; i > messageIndex; i--)
		{
			messages.RemoveAt(i);
		}

		chat?.SaveAllMessages(messageStore);
		GetDirty();
		await Refresh();

		// 启动后台生成
		session = sessionService.GetOrCreateSession(ChatGuid, AgentGuid);
		SubscribeToSession(session);
		sessionService.StartGeneration(session, agent!, chat!, throwExceptionInsteadOfPopupErrorMessage);
	}

	async Task ContinueFromMessage(Message message)
	{
		await sessionService.StopGeneration(ChatGuid);

		int messageIndex = messages.IndexOf(message);
		if (messageIndex == -1) return;
		if (message.sender != ShimmerChatLib.Sender.AI) return;

		message.IsContinuation = true;
		GetDirty();
		await Refresh();

		// 启动后台续写
		session = sessionService.GetOrCreateSession(ChatGuid, AgentGuid);
		SubscribeToSession(session);
		sessionService.StartContinuation(session, agent!, chat!, message, throwExceptionInsteadOfPopupErrorMessage);
	}
	#endregion

	#region 会话事件订阅

	/// <summary>
	/// 订阅会话事件，将后台生成状态桥接到 Blazor UI。
	/// </summary>
	private void SubscribeToSession(GenerationSession s)
	{
		// 先取消旧订阅
		UnsubscribeFromSession();

		session = s;
		if (s == null) return;

		s.StateChanged += OnSessionStateChanged;
		s.ScrollRequested += OnSessionScrollRequested;
		s.ErrorOccurred += OnSessionError;
		s.AgentMessageCompleted += OnSessionAgentMessageCompleted;
		s.ToolResultAdded += OnSessionToolResultAdded;
		s.GenerationCompleted += OnSessionGenerationCompleted;
	}

	private void UnsubscribeFromSession()
	{
		if (session == null) return;

		session.StateChanged -= OnSessionStateChanged;
		session.ScrollRequested -= OnSessionScrollRequested;
		session.ErrorOccurred -= OnSessionError;
		session.AgentMessageCompleted -= OnSessionAgentMessageCompleted;
		session.ToolResultAdded -= OnSessionToolResultAdded;
		session.GenerationCompleted -= OnSessionGenerationCompleted;
	}

	private async void OnSessionStateChanged()
	{
		await InvokeAsync(StateHasChanged);
	}

	private async void OnSessionScrollRequested()
	{
		if (autoScrollDown && isUserAtBottom)
		{
			try
			{
				await JS.InvokeVoidAsync("scrollToBottom", ChatMainElement);
			}
			catch (Exception) { }
		}
	}

	private async void OnSessionError(string message, string title)
	{
		await popupService.ShowAsync(message, title);
	}

	private void OnSessionAgentMessageCompleted(Message msg)
	{
		ChatPluginPanelContainer?.OnAgentMessage(msg);
	}

	private void OnSessionToolResultAdded(Message msg)
	{
		ChatPluginPanelContainer?.OnToolCallResult(msg);
	}

	private async void OnSessionGenerationCompleted()
	{
		try
		{
			await ShowNotificationWhenCompleted();
		}
		catch (Exception ex)
		{
			logger.LogError(ex, "显示通知时出错");
		}
	}
	#endregion

	#region 初始化 & 生命周期
	protected override void OnInitialized()
	{
		if (bool.TryParse(KVData.Read("App", "throw_exception"), out var result))
		{
			throwExceptionInsteadOfPopupErrorMessage = result;
		}
		if (bool.TryParse(KVData.Read("App", "auto_scroll_down"), out var autoscroll))
		{
			autoScrollDown = autoscroll;
		}
		if (bool.TryParse(KVData.Read("App", "virtualize"), out var virt))
		{
			virtualize = virt;
		}
	}

	protected override async Task OnParametersSetAsync()
	{
		// 先取消旧会话订阅
		UnsubscribeFromSession();

		agent = null;
		chat = null;
		messages = new ObservableCollection<Message>();

		if (Guid.TryParse(AgentGuid, out var guid))
		{
			try
			{
				agent = Agent.Load(guid, KVData);
				if (agent != null)
				{
					if (Guid.TryParse(ChatGuid, out var chatGuid) && agent.ChatGuids.Contains(chatGuid))
					{
						// 检查是否有活跃的生成会话（从其他页面返回）
						var existingSession = sessionService.GetSession(ChatGuid);
						if (existingSession is { IsActive: true, Chat: not null })
						{
							// 复用会话的 Chat 引用，确保看到最新消息
							chat = existingSession.Chat;
							messages = chat.Messages;
							SubscribeToSession(existingSession);
						}
						else
						{
							chat = Chat.LoadAndMigrate(chatGuid, KVData, messageStore);
							chat.LoadAllMessages(messageStore);
							messages = chat.Messages;

							// 清理旧的非活跃会话
							sessionService.CleanupSession(ChatGuid);
							session = null;
						}
					}
				}
			}
			catch (Exception)
			{
				agent = null;
				chat = null;
				messages = new ObservableCollection<Message>();
			}
		}

		await base.OnParametersSetAsync();
	}

	private bool _hasRendered;

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			_hasRendered = true;
		}

		if (_hasRendered && autoScrollDown && chat != null)
		{
			await JS.InvokeVoidAsync("scrollToBottom", ChatMainElement);
			_hasRendered = false;
		}
	}

	public async ValueTask DisposeAsync()
	{
		// 取消订阅但不停止生成 —— 离开页面后生成继续在后台运行
		UnsubscribeFromSession();
		session = null;
		await Task.CompletedTask;
	}
	#endregion

	#region IO
	private async Task ShowNotificationWhenCompleted()
	{
		try
		{
			var notificationsEnabled = false;
			var notificationsEnabledStr = KVData.Read("App", "enable_notifications");
			if (bool.TryParse(notificationsEnabledStr, out var result))
			{
				notificationsEnabled = result;
			}

			if (!notificationsEnabled)
				return;

			var aiMessage = messages.LastOrDefault(m => m.sender == ShimmerChatLib.Sender.AI);
			if (aiMessage != null && !string.IsNullOrEmpty(aiMessage.CurrentVersion?.Content))
			{
				var notificationOptions = new
				{
					body = aiMessage.CurrentVersion.Content.Length > 100
						? aiMessage.CurrentVersion.Content.Substring(0, 100) + "..."
						: aiMessage.CurrentVersion.Content,
					icon = Assets["favicon.png"],
				};

				await JS.InvokeVoidAsync("showNotification",
					Loc.Format("chat.new_message_notification", agent?.Name ?? "No Name"),
					notificationOptions);
			}
		}
		catch (Exception ex)
		{
			logger.LogError($"显示通知时出错: {ex.Message}");
		}
	}
	void GetDirty()
	{
		if (chat == null) return;
		chat.LastModifyTime = DateTime.Now;
		chat.Save(KVData);
		if (agent != null)
		{
			agent.MoveChatToTop(chat.Guid);
			agent.Save(KVData);
		}
	}
	async Task Refresh()
	{
		await InvokeAsync(StateHasChanged);
	}
	#endregion
}
