    private async Task NewChat()
    {
        var swTotal = Stopwatch.StartNew();
        PerfLog("NewChat start");

        if (agent == null)
        {
            PerfLog("NewChat skipped: agent is null");
            return;
        }

        var swCreate = Stopwatch.StartNew();
        var chat = new Chat
        {
            Guid = Guid.NewGuid(),
            Name = $"{DateTime.Now.ToString().Replace(" ","-").Replace("/","-").Replace(":","-")}",
            CreateTime = DateTime.Now,
            LastModifyTime = DateTime.Now
        };
        swCreate.Stop();
        PerfLog($"NewChat create model done: elapsedMs={swCreate.ElapsedMilliseconds}");

        var swGreeting = Stopwatch.StartNew();
        if (!string.IsNullOrEmpty(agent.Greeting) || (agent.AlternativeGreetings != null && agent.AlternativeGreetings.Count > 0))
        {
            var welcomeMessage = new Message
            {
                sender = Sender.AI,
                timestamp = DateTime.Now,
                message = new SharperLLM.Util.ChatMessage
                {
                    Content = agent.Greeting ?? ""
                }
            };

            // 如果有替代问候语，将它们添加为版本
            if (agent.AlternativeGreetings != null)
            {
                foreach (var altGreeting in agent.AlternativeGreetings)
                {
                    if (!string.IsNullOrEmpty(altGreeting) && altGreeting != agent.Greeting)
                    {
                        var altMessage = new SharperLLM.Util.ChatMessage
                        {
                            Content = altGreeting
                        };
                        welcomeMessage.AddVersion(altMessage);
                    }
                }
            }
            welcomeMessage.CurrentVersionIndex = 0;

            chat.AddMessage(welcomeMessage);
            chat.SaveMessage(messageStore, welcomeMessage);
        }
        swGreeting.Stop();
        PerfLog($"NewChat greeting+saveMessage done: elapsedMs={swGreeting.ElapsedMilliseconds}");

        var swSave = Stopwatch.StartNew();
        // Save the chat first
        chat.Save(kvDataService);
        agent.AddChatGuid(chat.Guid);
        // Save the agent
        agent.Save(kvDataService);
        swSave.Stop();
        PerfLog($"NewChat save chat+agent done: elapsedMs={swSave.ElapsedMilliseconds}");

        // Refresh the Virtualize component to show the new chat
        var swRefresh = Stopwatch.StartNew();
        await RefreshChatsAsync(true);
        swRefresh.Stop();
        PerfLog($"NewChat RefreshChatsAsync done: elapsedMs={swRefresh.ElapsedMilliseconds}");

        var swNav = Stopwatch.StartNew();
        OpenChat(chat);
        swNav.Stop();
        PerfLog($"NewChat navigate done: elapsedMs={swNav.ElapsedMilliseconds}");

        swTotal.Stop();
        PerfLog($"NewChat end: totalElapsedMs={swTotal.ElapsedMilliseconds}");
    }

