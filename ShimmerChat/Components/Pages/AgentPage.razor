@code {
    [Parameter]
    public string agentguid { get; set; } = string.Empty;

    private Agent? agent;
    string activeTab = "chats";

    private Dictionary<string, object> AgentPluginParameters => new()
    {
        ["AgentGuid"] = agent?.Guid ?? Guid.Empty,
        ["EventHandlerReg"] = (Action<ShimmerChatLib.Panel.IChatPanelEventHandler>)(handler =>
        {
            if (handler != null)
                _agentEventHandlers.Add(handler);
        })
    };

    List<ShimmerChatLib.Panel.IChatPanelEventHandler> _agentEventHandlers = [];
    string Name
    {
        get => agent?.Name ?? string.Empty;
        set
        {
            if (agent != null)
            {
                agent.Name = value;
                agent.Save(kvDataService);
            }
        }
    }
    string Greeting
    {
        get => agent?.Greeting ?? string.Empty;
        set
        {
            if (agent != null)
            {
                agent.Greeting = value;
                agent.Save(kvDataService);
            }
        }
    }

    string UserIntro
    {
        get => agent?.UserIntro ?? string.Empty;
        set
        {
            if (agent != null)
            {
                agent.UserIntro = value;
                agent.Save(kvDataService);
            }
        }
    }

    string TagsString
    {
        get => agent?.Tags != null ? string.Join(", ", agent.Tags) : string.Empty;
        set
        {
            if (agent != null)
            {
                if (!string.IsNullOrWhiteSpace(value))
                {
                    agent.Tags = value.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
                }
                else
                {
                    agent.Tags = new List<string>();
                }
                agent.Save(kvDataService);
            }
        }
    }

    string NewTagInput { get; set; } = "";
    bool ShowTagAutocomplete { get; set; } = false;
    List<string>? _allExistingTagsCache = null;

    List<string> AllExistingTags
    {
        get
        {
            if (_allExistingTagsCache != null)
                return _allExistingTagsCache;
            LoadAllTags();
            return _allExistingTagsCache!;
        }
    }

    void LoadAllTags()
    {
        var sw = Stopwatch.StartNew();
        var allGuids = Agent.GetAllAgentGuids(kvDataService);
        var allTags = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        int loadedAgents = 0;
        foreach (var guid in allGuids)
        {
            try
            {
                var a = Agent.Load(guid, kvDataService);
                loadedAgents++;
                if (a.Tags != null)
                {
                    foreach (var t in a.Tags)
                        allTags.Add(t);
                }
            }
            catch { }
        }
        _allExistingTagsCache = allTags.OrderBy(t => t).ToList();
        sw.Stop();
        PerfLog($"LoadAllTags done: allAgentGuids={allGuids.Count}, loadedAgents={loadedAgents}, totalTags={_allExistingTagsCache.Count}, elapsedMs={sw.ElapsedMilliseconds}");
    }

    List<string> TagSuggestions
    {
        get
        {
            var input = (NewTagInput ?? "").Trim();
            var all = AllExistingTags;
            if (agent?.Tags != null)
                all = all.Where(t => !agent.Tags.Contains(t)).ToList();
            if (string.IsNullOrEmpty(input))
                return all;
            return all.Where(t => t.Contains(input, StringComparison.OrdinalIgnoreCase)).ToList();
        }
    }

    void AddTag(string tag)
    {
        if (agent == null || string.IsNullOrWhiteSpace(tag))
            return;
        agent.Tags ??= new List<string>();
        if (!agent.Tags.Any(t => t.Equals(tag, StringComparison.OrdinalIgnoreCase)))
        {
            agent.Tags.Add(tag);
            agent.Save(kvDataService);
            if (_allExistingTagsCache != null && !_allExistingTagsCache.Contains(tag, StringComparer.OrdinalIgnoreCase))
                _allExistingTagsCache.Add(tag);
        }
        NewTagInput = "";
        ShowTagAutocomplete = false;
    }

    void RemoveTag(string tag)
    {
        if (agent?.Tags == null)
            return;
        agent.Tags.RemoveAll(t => t.Equals(tag, StringComparison.OrdinalIgnoreCase));
        agent.Save(kvDataService);
    }

    async Task OnTagKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddTag(NewTagInput);
        }
        else if (e.Key == "Escape")
        {
            ShowTagAutocomplete = false;
        }
    }

    async Task OnTagAutocompleteFocusOut()
    {
        await Task.Delay(200);
        ShowTagAutocomplete = false;
    }

    void SelectTagSuggestion(string tag)
    {
        AddTag(tag);
    }

    string AlternativeGreetings
    {
        get => agent?.AlternativeGreetings != null ? string.Join("<|>", agent.AlternativeGreetings) : string.Empty;
        set
        {
            if (agent != null)
            {
                // 将多行文本分割成列表
                if (!string.IsNullOrEmpty(value))
                {
                    agent.AlternativeGreetings = value.Split("<|>", StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
                }
                else
                {
                    agent.AlternativeGreetings = new List<string>();
                }
                agent.Save(kvDataService);
            }
        }
    }

    string AvatarPath => $"/userimages/{agent.AvatarGuid}.png";
    string BackgroudPath => $"/userimages/{agent.BackgroundGuid}.png";

    bool virtualize = false;
    List<ChatSummary> allChatSummaries = new();
    List<ChatSummary> fullTextMatchedSummaries = new();
    List<ChatSummary> currentPageSummaries = new();
    int loadedPage = -1;
    int loadedPageSize = -1;

    string ChatSearchQuery { get; set; } = string.Empty;
    bool EnableFullTextSearch { get; set; } = false;
    bool IsSearchInProgress { get; set; } = false;
    CancellationTokenSource? searchCts;

    int CurrentPage { get; set; } = 1;
    int PageSize { get; set; } = 20;
    int[] PageSizeOptions { get; } = new[] { 10, 20, 50, 100 };

    IReadOnlyList<ChatSummary> FilteredChatSummaries
    {
        get
        {
            var query = (ChatSearchQuery ?? string.Empty).Trim();
            if (string.IsNullOrEmpty(query))
            {
                return allChatSummaries;
            }

            IEnumerable<ChatSummary> result = allChatSummaries.Where(s =>
                (s.Name?.Contains(query, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (s.LastMessagePreview?.Contains(query, StringComparison.OrdinalIgnoreCase) ?? false));

            if (EnableFullTextSearch && fullTextMatchedSummaries.Count > 0)
            {
                var idSet = fullTextMatchedSummaries.Select(s => s.Guid).ToHashSet();
                result = result.Union(allChatSummaries.Where(s => idSet.Contains(s.Guid)));
            }

            return result.ToList();
        }
    }

    bool IsSearchActive => !string.IsNullOrWhiteSpace(ChatSearchQuery) || EnableFullTextSearch;

    int EffectiveTotalCount => IsSearchActive
        ? FilteredChatSummaries.Count
        : (agent?.GetChatCount() ?? 0);

    int TotalPages => Math.Max(1, (int)Math.Ceiling((double)EffectiveTotalCount / PageSize));

    IReadOnlyList<ChatSummary> PagedChatSummaries
    {
        get
        {
            if (IsSearchActive)
            {
                return FilteredChatSummaries
                    .Skip((CurrentPage - 1) * PageSize)
                    .Take(PageSize)
                    .ToList();
            }

            if (loadedPage != CurrentPage || loadedPageSize != PageSize)
            {
                if (agent != null)
                {
                    currentPageSummaries = agent.GetChatSummariesRange(kvDataService, (CurrentPage - 1) * PageSize, PageSize);
                }
                else
                {
                    currentPageSummaries = new();
                }
                loadedPage = CurrentPage;
                loadedPageSize = PageSize;
            }

            return currentPageSummaries;
        }
    }

    bool CanUseVirtualizedList => virtualize && string.IsNullOrWhiteSpace(ChatSearchQuery) && !EnableFullTextSearch;

    const bool EnablePerfLog = true;
    static string PerfNow() => DateTime.Now.ToString("HH:mm:ss.fff");
    static void PerfLog(string message)
    {
        if (EnablePerfLog)
        {
            Console.WriteLine($"[PERF][AgentPage][{PerfNow()}] {message}");
        }
    }

    protected override void OnInitialized()
    {
        if (bool.TryParse(kvDataService.Read("App", "virtualize"), out var virt))
        {
            virtualize = virt;
        }
    }

    protected override void OnParametersSet()
    {
        var swTotal = Stopwatch.StartNew();
        PerfLog($"OnParametersSet start: agentguid={agentguid}, virtualize={virtualize}");

        base.OnParametersSet();

        agent = null;

        var swAgentLoad = Stopwatch.StartNew();
        if (Guid.TryParse(agentguid, out var guid))
        {
            try
            {
                agent = Agent.Load(guid, kvDataService);
            }
            catch (Exception)
            {
                agent = null;
            }
        }
        swAgentLoad.Stop();
        PerfLog($"OnParametersSet Agent.Load done: found={(agent != null)}, elapsedMs={swAgentLoad.ElapsedMilliseconds}");

        // ShimmerChat 2.0: tools are now managed via GenerationManager + ToolManager
        LoadPresets();

        var swTags = Stopwatch.StartNew();
        LoadAllTags();
        swTags.Stop();
        PerfLog($"OnParametersSet LoadAllTags done: elapsedMs={swTags.ElapsedMilliseconds}");

        allChatSummaries = new();
        fullTextMatchedSummaries = new();
        currentPageSummaries = new();
        loadedPage = -1;

        CurrentPage = 1;
        swTotal.Stop();
        PerfLog($"OnParametersSet end: totalElapsedMs={swTotal.ElapsedMilliseconds}");
    }

    async Task OnChatSearchInput(ChangeEventArgs e)
    {
        ChatSearchQuery = e.Value?.ToString() ?? string.Empty;
        CurrentPage = 1;

        if (!string.IsNullOrWhiteSpace(ChatSearchQuery) && allChatSummaries.Count == 0)
        {
            LoadAllChatSummaries();
        }

        if (EnableFullTextSearch)
        {
            await RunFullTextSearchAsync();
        }
        else
        {
            fullTextMatchedSummaries = new();
        }

        await RefreshChatsAsync();
    }

    async Task OnEnableFullTextSearchChanged(ChangeEventArgs e)
    {
        EnableFullTextSearch = e.Value is bool b && b;
        CurrentPage = 1;

        if (EnableFullTextSearch)
        {
            if (allChatSummaries.Count == 0)
            {
                LoadAllChatSummaries();
            }
            await RunFullTextSearchAsync();
        }
        else
        {
            searchCts?.Cancel();
            fullTextMatchedSummaries = new();
            IsSearchInProgress = false;
        }

        await RefreshChatsAsync();
    }

    async Task RunFullTextSearchAsync()
    {
        var query = (ChatSearchQuery ?? string.Empty).Trim();
        if (string.IsNullOrEmpty(query) || agent == null)
        {
            fullTextMatchedSummaries = new();
            IsSearchInProgress = false;
            return;
        }

        searchCts?.Cancel();
        searchCts = new CancellationTokenSource();
        var token = searchCts.Token;

        IsSearchInProgress = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            if (allChatSummaries.Count == 0)
            {
                LoadAllChatSummaries();
            }

            var matches = await Task.Run(() =>
            {
                var result = new List<ChatSummary>();
                foreach (var summary in allChatSummaries)
                {
                    token.ThrowIfCancellationRequested();
                    var messages = messageStore.GetMessages(summary.Guid, 0, Math.Max(summary.MessageCount, 1));
                    if (messages.Any(m => (m.message?.Content?.Contains(query, StringComparison.OrdinalIgnoreCase) ?? false)))
                    {
                        result.Add(summary);
                    }
                }
                return result;
            }, token);

            fullTextMatchedSummaries = matches;
        }
        catch (OperationCanceledException)
        {
        }
        finally
        {
            IsSearchInProgress = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    void GoToPreviousPage()
    {
        if (CurrentPage > 1)
            CurrentPage--;
    }

    void GoToNextPage()
    {
        if (CurrentPage < TotalPages)
            CurrentPage++;
    }

    async Task OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var newSize) && newSize > 0)
        {
            PageSize = newSize;
            CurrentPage = 1;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async void InputAvatar(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.ContentType != "image/png")
        {
            await PopupService.ShowAsync("Unsupported file type! Only .png file are supported.");
            return;
        }
        if (file.Size > 1024 * 1024 * 30) {
            await PopupService.ShowAsync("File Too Large! 30MiB limit!");
            return;
        }

        Stream stream = file.OpenReadStream(1024 * 1024 * 30, default);
        var guid = Guid.NewGuid();
        using (var localFile = File.Create($"{AppContext.BaseDirectory}/UserUploadImage/{guid}.png"))
        {
            await stream.CopyToAsync(localFile);
        }

        agent.AvatarGuid = guid;
        agent.Save(kvDataService);
        StateHasChanged();
    }
    private async void InputBackground(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.ContentType != "image/png")
        {
            await PopupService.ShowAsync("Unsupported file type! Only .png file are supported.");
            return;
        }
        if (file.Size > 1024 * 1024 * 30)
        {
            await PopupService.ShowAsync("File Too Large! 30MiB limit!");
            return;
        }

        Stream stream = file.OpenReadStream(1024 * 1024 * 30, default);
        var guid = Guid.NewGuid();
        using (var localFile = File.Create($"{AppContext.BaseDirectory}/UserUploadImage/{guid}.png"))
        {
            await stream.CopyToAsync(localFile);
        }

        agent.BackgroundGuid = guid;
        agent.Save(kvDataService);
        StateHasChanged();
    }

    private void NavigateBack()
    {
        navigation.NavigateTo("agentselect");
    }

    private async Task NewChat()
    {
        var swTotal = Stopwatch.StartNew();
        PerfLog("NewChat start");

        if (agent == null)
        {
            PerfLog("NewChat skipped: agent is null");
            return;
        }

        var swCreate = Stopwatch.StartNew();
        var chat = new Chat
        {
            Guid = Guid.NewGuid(),
            Name = $"{DateTime.Now.ToString().Replace(" ","-").Replace("/","-").Replace(":","-")}",
            CreateTime = DateTime.Now,
            LastModifyTime = DateTime.Now
        };
        swCreate.Stop();
        PerfLog($"NewChat create model done: elapsedMs={swCreate.ElapsedMilliseconds}");

        var swGreeting = Stopwatch.StartNew();
        if (!string.IsNullOrEmpty(agent.Greeting) || (agent.AlternativeGreetings != null && agent.AlternativeGreetings.Count > 0))
        {
            var welcomeMessage = new Message
            {
                sender = Sender.AI,
                timestamp = DateTime.Now,
                message = new SharperLLM.Util.ChatMessage
                {
                    Content = agent.Greeting ?? ""
                }
            };

            // 如果有替代问候语，将它们添加为版本
            if (agent.AlternativeGreetings != null)
            {
                foreach (var altGreeting in agent.AlternativeGreetings)
                {
                    if (!string.IsNullOrEmpty(altGreeting) && altGreeting != agent.Greeting)
                    {
                        var altMessage = new SharperLLM.Util.ChatMessage
                        {
                            Content = altGreeting
                        };
                        welcomeMessage.AddVersion(altMessage);
                    }
                }
            }
            welcomeMessage.CurrentVersionIndex = 0;

            chat.AddMessage(welcomeMessage);
            chat.SaveMessage(messageStore, welcomeMessage);
        }
        swGreeting.Stop();
        PerfLog($"NewChat greeting+saveMessage done: elapsedMs={swGreeting.ElapsedMilliseconds}");

        var swSave = Stopwatch.StartNew();
        // Save the chat first
        chat.Save(kvDataService);
        agent.AddChatGuid(chat.Guid);
        // Save the agent
        agent.Save(kvDataService);
        swSave.Stop();
        PerfLog($"NewChat save chat+agent done: elapsedMs={swSave.ElapsedMilliseconds}");

        // Refresh the Virtualize component to show the new chat
        var swRefresh = Stopwatch.StartNew();
        await RefreshChatsAsync(true);
        swRefresh.Stop();
        PerfLog($"NewChat RefreshChatsAsync done: elapsedMs={swRefresh.ElapsedMilliseconds}");

        var swNav = Stopwatch.StartNew();
        OpenChat(chat);
        swNav.Stop();
        PerfLog($"NewChat navigate done: elapsedMs={swNav.ElapsedMilliseconds}");

        swTotal.Stop();
        PerfLog($"NewChat end: totalElapsedMs={swTotal.ElapsedMilliseconds}");
    }

    void OpenChat(Chat chat)
    {
        navigation.NavigateTo(navigation.Uri + "/" + chat.Guid.ToString());
    }

    void OpenChatSummary(ChatSummary summary)
    {
        navigation.NavigateTo(navigation.Uri + "/" + summary.Guid.ToString());
    }

    private async Task Export()
    {
        if (agent == null)
            return;
        var content = agent.Export();
        var bytes = System.Text.Encoding.UTF8.GetBytes(content);
        var fileStream = new MemoryStream(bytes);
        var fileName = $"{agent.Name}.json";
        using (var streamRef = new DotNetStreamReference(stream: fileStream))
        {
            await JS.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
        };
    }
    
    #region Chat Management
    
    bool DeleteChatPopupVisible { get; set; } = false;
    ChatSummary? ChatToDelete { get; set; } = null;

    string GetLastMessagePreview(ChatSummary summary)
    {
        return summary.LastMessagePreview;
    }

    void ShowDeleteChatConfirmation(ChatSummary summary)
    {
        ChatToDelete = summary;
        DeleteChatPopupVisible = true;
    }

    async Task DeleteChatConfirmed()
    {
        if (ChatToDelete != null && agent != null)
        {
            agent.RemoveChatGuid(ChatToDelete.Guid);
            agent.Save(kvDataService);

            messageStore.DeleteAllMessages(ChatToDelete.Guid);

            DeleteChatPopupVisible = false;
            ChatToDelete = null;

            await RefreshChatsAsync(true);
        }
    }

    #endregion

    #region Chat Loading

    private Virtualize<ChatSummary>? chatVirtualize;

    private void LoadAllChatSummaries()
    {
        var sw = Stopwatch.StartNew();
        if (agent == null)
        {
            allChatSummaries = new();
            fullTextMatchedSummaries = new();
            PerfLog("LoadAllChatSummaries skipped: agent is null");
            return;
        }

        var totalCount = agent.GetChatCount();
        allChatSummaries = agent.GetChatSummariesRange(kvDataService, 0, totalCount).ToList();

        if (!string.IsNullOrWhiteSpace(ChatSearchQuery) && EnableFullTextSearch)
        {
            var validIds = allChatSummaries.Select(x => x.Guid).ToHashSet();
            fullTextMatchedSummaries = fullTextMatchedSummaries.Where(x => validIds.Contains(x.Guid)).ToList();
        }

        CurrentPage = Math.Min(CurrentPage, TotalPages);
        CurrentPage = Math.Max(1, CurrentPage);

        sw.Stop();
        PerfLog($"LoadAllChatSummaries done: totalCount={totalCount}, loaded={allChatSummaries.Count}, elapsedMs={sw.ElapsedMilliseconds}");
    }

    private ValueTask<ItemsProviderResult<ChatSummary>> LoadChatSummariesAsync(ItemsProviderRequest request)
    {
        var sw = Stopwatch.StartNew();
        if (agent == null)
        {
            PerfLog($"LoadChatSummariesAsync skipped: agent is null, start={request.StartIndex}, count={request.Count}");
            return ValueTask.FromResult(new ItemsProviderResult<ChatSummary>(Array.Empty<ChatSummary>(), 0));
        }

        var totalCount = agent.GetChatCount();
        var summaries = agent.GetChatSummariesRange(kvDataService, request.StartIndex, request.Count);
        sw.Stop();
        PerfLog($"LoadChatSummariesAsync done: start={request.StartIndex}, count={request.Count}, returned={summaries.Count}, total={totalCount}, elapsedMs={sw.ElapsedMilliseconds}");

        return ValueTask.FromResult(new ItemsProviderResult<ChatSummary>(summaries, totalCount));
    }

    private async Task RefreshChatsAsync(bool forceReload = false)
    {
        var sw = Stopwatch.StartNew();
        if (CanUseVirtualizedList)
        {
            if (chatVirtualize != null)
            {
                await chatVirtualize.RefreshDataAsync();
            }
        }
        else
        {
            if (forceReload || (IsSearchActive && allChatSummaries.Count == 0))
            {
                if (IsSearchActive && agent != null)
                {
                    LoadAllChatSummaries();
                }
                loadedPage = -1;
            }
            await InvokeAsync(StateHasChanged);
        }
        sw.Stop();
        PerfLog($"RefreshChatsAsync done: virtualize={virtualize}, canUseVirtualized={CanUseVirtualizedList}, forceReload={forceReload}, elapsedMs={sw.ElapsedMilliseconds}");
    }

    #endregion

    private List<GenerationPreset> _availablePresets = new();
    private string _selectedPresetId = "";

    private void LoadPresets()
    {
        var json = kvDataService.Read("GenerationManager", "generation_presets");
        if (!string.IsNullOrEmpty(json))
            _availablePresets = Newtonsoft.Json.JsonConvert.DeserializeObject<List<GenerationPreset>>(json) ?? new();
        else
            _availablePresets = new();
    }

    private void CreatePrivateTree()
    {
        if (agent == null) return;
        var root = new SequenceNode
        {
            Name = "Agent Private Tree",
            Nodes = new List<IGenerationNode>()
        };

        if (!string.IsNullOrEmpty(_selectedPresetId))
        {
            var preset = _availablePresets.FirstOrDefault(p => p.Id == _selectedPresetId);
            root.Nodes.Add(new CallNode
            {
                Name = preset?.Name ?? "Preset",
                PresetId = _selectedPresetId
            });
        }

        agent.ModifierTreeJson = GenerationNodeSerializer.Serialize(root);
        agent.Save(kvDataService);
    }

    private void EditPrivateTree()
    {
        navigation.NavigateTo($"/generationmanager?agent={agent?.Guid}");
    }

    private void RevertToPreset()
    {
        if (agent == null) return;
        agent.ModifierTreeJson = null;
        agent.Save(kvDataService);
    }
}
