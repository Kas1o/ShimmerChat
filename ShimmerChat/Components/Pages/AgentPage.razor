@page "/agent/{agentguid}"
@using ShimmerChatLib.Models
@using ShimmerChatLib.Generation
@using ShimmerChatBuiltin.Generation.Nodes
@using System.Diagnostics
@using System.Threading
@inject NavigationManager navigation
@inject IKVDataService kvDataService
@inject IPopupService PopupService
@inject IJSRuntime JS
@inject IMessageStoreService messageStore

@if(agent != null)
{
    <div class="agent-page-container shimmer-content" style="background-image: url('@BackgroudPath'); background-size: cover; background-position: center; min-height: 100vh;">
        <div class="agent-header">
            <button class="agent-back-btn" @onclick="NavigateBack" title="Back">
                <i class="bi bi-arrow-left"></i>
            </button>
            <img class="agent-header-avatar" src="@AvatarPath" alt="avatar" />
            <div class="agent-header-info">
                <h2>@agent.Name</h2>
                @if(!string.IsNullOrWhiteSpace(agent.UserIntro))
                {
                    <p class="agent-header-desc">@agent.UserIntro</p>
                }
            </div>
        </div>

        <div class="agent-tabs">
            <button class="agent-tab @(activeTab == "chats" ? "active" : "")" @onclick='() => activeTab = "chats"'>
                <i class="bi bi-chat-dots"></i> <span>Chats</span>
            </button>
            <button class="agent-tab @(activeTab == "settings" ? "active" : "")" @onclick='() => activeTab = "settings"'>
                <i class="bi bi-sliders"></i> <span>Settings</span>
            </button>
        </div>

        <div id="content">
        <div class="content-wrapper">
            <div id="left-section" class="@(activeTab == "chats" ? "tab-active" : "tab-hidden")">

                <div class="chat-toolbar shimmer-group">
                    <input class="shimmer-input chat-search-input"
                           placeholder="Search chats..."
                           value="@ChatSearchQuery"
                           @oninput="OnChatSearchInput" />
                    <div class="chat-toolbar-row">
                        <label class="fulltext-toggle">
                            <input type="checkbox" checked="@EnableFullTextSearch" @onchange="OnEnableFullTextSearchChanged" />
                            Full-text search
                        </label>
                        <div class="chat-toolbar-meta">
                            <span>@FilteredChatSummaries.Count result(s)</span>
                            @if (IsSearchInProgress)
                            {
                                <span class="search-loading">Searching...</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="chat-section chat-list">
                    <div class="chat-item new-chat-item" @onclick="NewChat">
                        <i class="bi bi-plus-lg chat-item-icon"></i>
                        <div class="chat-info">
                            <div class="chat-name">New Chat</div>
                        </div>
                    </div>

                    @if (CanUseVirtualizedList)
                    {
                        <Virtualize ItemsProvider="LoadChatSummariesAsync" Context="summary" @ref="chatVirtualize">
                            <ItemContent>
                                <div class="chat-item" @onclick="() => OpenChatSummary(summary)">
                                    <div class="chat-info">
                                        <div class="chat-name">@summary.Name</div>
                                        <div class="chat-last-message">@summary.LastMessagePreview</div>
                                    </div>
                                    <button class="chat-delete-btn" @onclick:stopPropagation @onclick="() => ShowDeleteChatConfirmation(summary)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </ItemContent>
                            <Placeholder>
                                <div class="chat-item chat-item-placeholder">
                                    <div class="chat-info">
                                        <div class="chat-name">Loading...</div>
                                        <div class="chat-last-message">Please wait</div>
                                    </div>
                                </div>
                            </Placeholder>
                        </Virtualize>
                    }
                    else
                    {
                        @foreach (var summary in PagedChatSummaries)
                        {
                            <div class="chat-item" @onclick="() => OpenChatSummary(summary)">
                                <div class="chat-info">
                                    <div class="chat-name">@summary.Name</div>
                                    <div class="chat-last-message">@summary.LastMessagePreview</div>
                                </div>
                                <button class="chat-delete-btn" @onclick:stopPropagation @onclick="() => ShowDeleteChatConfirmation(summary)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        }

                        @if (!PagedChatSummaries.Any() && !IsSearchInProgress)
                        {
                            <div class="chat-empty">
                                <i class="bi bi-inbox"></i>
                                <p>No chats found.</p>
                            </div>
                        }

                        <div class="pagination-bar shimmer-group">
                            <div class="pagination-left">
                                <button class="btn btn-secondary btn-sm" @onclick="GoToPreviousPage" disabled="@(CurrentPage <= 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                                <span>@CurrentPage / @TotalPages</span>
                                <button class="btn btn-secondary btn-sm" @onclick="GoToNextPage" disabled="@(CurrentPage >= TotalPages)">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </div>
                            <div class="pagination-right">
                                <select class="shimmer-input page-size-select" value="@PageSize" @onchange="OnPageSizeChanged">
                                    @foreach (var option in PageSizeOptions)
                                    {
                                        <option value="@option">@option</option>
                                    }
                                </select>
                            </div>
                        </div>
                    }
                </div>
                
                @if (DeleteChatPopupVisible)
                {
                    <div class="shimmer-popup-overlay" @onclick="() => DeleteChatPopupVisible=false">
                        <div class="shimmer-popup-content" @onclick:stopPropagation>
                            <h5>Delete Chat</h5>
                            <p>Are you sure you want to delete the chat "@ChatToDelete?.Name"?</p>
                            <div class="popup-actions">
                                <button class="btn btn-secondary" @onclick="() => DeleteChatPopupVisible=false">Cancel</button>
                                <button class="btn btn-danger" @onclick="DeleteChatConfirmed">Delete</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="settings-section shimmer-group @(activeTab == "settings" ? "tab-active" : "tab-hidden")">
                <div class="settings-scroll">
                    <div class="settings-group">
                        <h4><i class="bi bi-person-gear"></i> Basic Info</h4>
                        <div class="settings-field">
                            <label>Name</label>
                            <input class="shimmer-input" @bind="Name"/>
                        </div>
                        <div class="settings-field">
                            <label>User Introduction</label>
                            <textarea class="shimmer-textarea" @bind="UserIntro" rows="3" placeholder="A short description shown in the agent list and header" />
                        </div>
                    </div>

                    <div class="settings-group">
                        <h4><i class="bi bi-tags"></i> Tags</h4>
                        <div class="tag-editor-wrapper">
                            <div class="tag-editor-chips">
                                @if (agent?.Tags != null)
                                {
                                    @foreach (var tag in agent.Tags)
                                    {
                                        <span class="agent-tag-chip">
                                            @tag
                                            <button class="tag-remove-btn" @onclick="() => RemoveTag(tag)">×</button>
                                        </span>
                                    }
                                }
                            </div>
                            <div class="tag-input-wrapper">
                                <input class="shimmer-input tag-autocomplete-input" type="text"
                                    @bind="NewTagInput" @bind:event="oninput"
                                    @onkeydown="OnTagKeyDown"
                                    @onfocus="() => ShowTagAutocomplete = true"
                                    @onfocusout="OnTagAutocompleteFocusOut"
                                    placeholder="Add tag..." />
                                @if (ShowTagAutocomplete && TagSuggestions.Count > 0)
                                {
                                    <div class="tag-suggestions-dropdown">
                                        @foreach (var suggestion in TagSuggestions)
                                        {
                                            <div class="tag-suggestion-item" @onmousedown="() => SelectTagSuggestion(suggestion)" @onmousedown:preventDefault>
                                                @suggestion
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="settings-group">
                        <h4><i class="bi bi-chat-heart"></i> Greetings</h4>
                        <div class="settings-field">
                            <label>Greeting</label>
                            <textarea class="shimmer-textarea" @bind="Greeting" rows="3" />
                        </div>
                        <div class="settings-field">
                            <label>Alternative Greetings</label>
                            <textarea class="shimmer-textarea" @bind="AlternativeGreetings" placeholder="Enter alternative greetings, sep by '<|>'" rows="3" />
                        </div>
                    </div>

                    <div class="settings-group">
                        <h4><i class="bi bi-image"></i> Avatar &amp; Background</h4>
                        <div class="media-upload-row">
                            <div class="media-upload-item">
                                <img id="avatar-preview" src="@AvatarPath" alt="avatar"/>
                                <InputFile OnChange="InputAvatar" accept="image/png" />
                            </div>
                            <div class="media-upload-item">
                                <span class="media-label">Background Image</span>
                                <InputFile OnChange="InputBackground" accept="image/png" />
                            </div>
                        </div>
                    </div>

                    <div class="settings-group">
                        <h4><i class="bi bi-diagram-3"></i> Generation Config</h4>
                        <div class="settings-field">
                            <label>Modifier Tree</label>
                            @if (!string.IsNullOrEmpty(agent?.ModifierTreeJson))
                            {
                                <div class="gen-config-status">
                                    <span class="gen-config-badge private">Private Tree</span>
                                    <span class="gen-config-hint">This agent has a custom modifier tree.</span>
                                </div>
                                <div style="margin-top:8px; display:flex; gap:8px;">
                                    <button class="btn btn-primary btn-sm" @onclick="EditPrivateTree">
                                        <i class="bi bi-pencil"></i> Edit Private Tree
                                    </button>
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="RevertToPreset">
                                        <i class="bi bi-arrow-counterclockwise"></i> Revert to Preset
                                    </button>
                                </div>
                            }
                            else
                            {
                                <div class="gen-config-status">
                                    <span class="gen-config-badge preset">Using Preset</span>
                                    <span class="gen-config-hint">Select a preset from Generation Manager.</span>
                                </div>
                                <div style="margin-top:8px; display:flex; gap:8px; align-items:center;">
                                    <select class="shimmer-input" style="flex:1;max-width:300px;" @bind="_selectedPresetId">
                                        <option value="">-- No preset --</option>
                                        @foreach (var p in _availablePresets)
                                        {
                                            <option value="@p.Id">@p.Name</option>
                                        }
                                    </select>
                                    <button class="btn btn-outline-primary btn-sm" @onclick="CreatePrivateTree">
                                        <i class="bi bi-pencil"></i> Create Private Tree
                                    </button>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="settings-group">
                        <h4><i class="bi bi-puzzle"></i> Plugins</h4>
                        <ShimmerChatLib.Components.PluginPanelContainer
                            PanelDisplayPlace="ShimmerChatLib.Panel.PanelDisplayPlace.Agent"
                            Parameters="AgentPluginParameters"/>
                    </div>

                    <div class="settings-actions">
                        <button class="btn btn-primary" @onclick="Export">
                            <i class="bi bi-download"></i> Export Agent
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        /* Container */
        .agent-page-container {
            display: flex;
            flex-direction: column;
            height: calc(100vh - var(--topbar-height, 0px));
            overflow: hidden;
        }

        .shimmer-content {
            padding: 0px !important;
        }

        /* Header */
        .agent-header {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 20px;
            background-color: color-mix(in srgb, var(--color-card) 85%, black 15%);
            backdrop-filter: blur(8px);
            border-bottom: 1px solid var(--color-border);
            flex-shrink: 0;
        }

        .agent-back-btn {
            background: none;
            border: none;
            cursor: pointer;
            font-size: 20px;
            color: var(--color-text-primary);
            padding: 8px;
            border-radius: var(--radius-md);
            transition: background-color 0.2s;
            display: flex;
            align-items: center;
        }

        .agent-back-btn:hover {
            background-color: var(--color-surface);
        }

        .agent-header-avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--color-border);
            flex-shrink: 0;
        }

        .agent-header-info {
            flex-grow: 1;
            min-width: 0;
        }

        .agent-header-info h2 {
            margin: 0;
            font-size: 1.3rem;
            color: var(--color-text-primary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .agent-header-desc {
            margin: 2px 0 0 0;
            font-size: 0.85rem;
            color: var(--color-text-secondary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* Tabs (portrait only) */
        .agent-tabs {
            display: none;
            flex-shrink: 0;
            background-color: color-mix(in srgb, var(--color-card) 90%, black 10%);
            backdrop-filter: blur(8px);
            border-bottom: 1px solid var(--color-border);
        }

        .agent-tab {
            flex: 1;
            background: none;
            border: none;
            border-bottom: 2px solid transparent;
            cursor: pointer;
            padding: 12px;
            font-size: 0.95rem;
            color: var(--color-text-secondary);
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

        .agent-tab.active {
            color: var(--color-primary);
            border-bottom-color: var(--color-primary);
            font-weight: 600;
        }

        /* Content layout */
        #content {
            flex: 1;
            overflow: hidden;
            padding: 16px;
        }

        .content-wrapper {
            display: flex;
            gap: 16px;
            height: 100%;
        }

        #left-section {
            width: 50%;
            display: flex;
            flex-direction: column;
            gap: 12px;
            min-height: 0;
        }

        .settings-section {
            width: 50%;
            display: flex;
            flex-direction: column;
            min-height: 0;
        }

        .settings-scroll {
            overflow-y: auto;
            padding: 16px;
            flex: 1;
        }

        /* Chat toolbar */
        .chat-toolbar {
            display: flex;
            flex-direction: column;
            gap: 8px;
            padding: 12px;
            flex-shrink: 0;
        }

        .chat-toolbar-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
        }

        .chat-search-input {
            width: 100%;
        }

        .fulltext-toggle {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 0.85rem;
            color: var(--color-text-secondary);
            cursor: pointer;
        }

        .chat-toolbar-meta {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.8rem;
            color: var(--color-text-secondary);
        }

        .search-loading {
            color: var(--color-primary);
            font-weight: 600;
        }

        /* Chat list */
        .chat-section {
            flex: 1;
            overflow-y: auto;
            padding-right: 4px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            min-height: 0;
        }

        .chat-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 14px;
            background-color: color-mix(in srgb, var(--color-card) 80%, transparent 20%);
            backdrop-filter: blur(4px);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .chat-item:hover {
            border-color: var(--color-primary);
            background-color: var(--color-surface);
            box-shadow: var(--shadow-md);
        }

        .chat-item-icon {
            font-size: 1.1rem;
            color: var(--color-text-secondary);
            flex-shrink: 0;
        }

        .chat-info {
            flex-grow: 1;
            min-width: 0;
        }

        .chat-name {
            font-weight: 600;
            color: var(--color-text-primary);
            margin-bottom: 2px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .chat-last-message {
            color: var(--color-text-secondary);
            font-size: 0.85em;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .new-chat-item {
            background-color: var(--color-primary);
            color: white;
            border-color: var(--color-primary);
        }

        .new-chat-item:hover {
            background-color: var(--color-primary-hover);
            border-color: var(--color-primary-hover);
        }

        .new-chat-item .chat-name,
        .new-chat-item .chat-item-icon {
            color: white;
        }

        .chat-empty {
            text-align: center;
            color: var(--color-text-secondary);
            padding: 32px 16px;
        }

        .chat-empty i {
            font-size: 2rem;
            display: block;
            margin-bottom: 8px;
            opacity: 0.5;
        }

        /* Pagination */
        .pagination-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            flex-shrink: 0;
        }

        .pagination-left,
        .pagination-right {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .pagination-left span {
            font-size: 0.85rem;
            color: var(--color-text-secondary);
        }

        .page-size-select {
            width: 70px;
            padding-right: 1.5rem;
        }

        .chat-delete-btn {
            background: rgba(0, 0, 0, 0.3);
            color: white;
            border: none;
            border-radius: var(--radius-sm);
            width: 30px;
            height: 30px;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            opacity: 0;
            transition: all 0.2s;
            flex-shrink: 0;
        }

        .chat-item:hover .chat-delete-btn {
            opacity: 1;
        }

        .chat-delete-btn:hover {
            background: var(--color-error);
        }

        /* Settings groups */
        .settings-group {
            margin-bottom: 20px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--color-border);
        }

        .settings-group:last-of-type {
            border-bottom: none;
        }

        .settings-group h4 {
            margin: 0 0 12px 0;
            font-size: 1rem;
            color: var(--color-text-primary);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .settings-group h4 i {
            color: var(--color-primary);
        }

        .settings-field {
            margin-bottom: 12px;
        }

        .settings-field label {
            display: block;
            margin-bottom: 4px;
            font-size: 0.85rem;
            font-weight: 500;
            color: var(--color-text-secondary);
        }

        .settings-field .shimmer-input,
        .settings-field .shimmer-textarea {
            width: 100%;
        }

        /* Avatar & Background */
        .media-upload-row {
            display: flex;
            gap: 20px;
            align-items: flex-start;
            flex-wrap: wrap;
        }

        .media-upload-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
        }

        .media-label {
            font-size: 0.85rem;
            color: var(--color-text-secondary);
            font-weight: 500;
        }

        #avatar-preview {
            width: 100px;
            height: 100px;
            object-fit: cover;
            border-radius: var(--radius-md);
            border: 2px solid var(--color-border);
        }

        /* Tags */
        .tag-editor-wrapper {
            margin-bottom: 8px;
        }

        .tag-editor-chips {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-bottom: 8px;
            min-height: 24px;
        }

        .agent-tag-chip {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 8px 3px 12px;
            font-size: 0.85rem;
            font-weight: 500;
            border-radius: 14px;
            background-color: var(--color-primary-light);
            color: var(--color-primary);
            border: 1px solid var(--color-primary);
        }

        .tag-remove-btn {
            background: none;
            border: none;
            color: inherit;
            font-size: 1.1rem;
            line-height: 1;
            cursor: pointer;
            padding: 0 2px;
            opacity: 0.6;
            transition: opacity 0.15s;
        }

        .tag-remove-btn:hover {
            opacity: 1;
        }

        .tag-input-wrapper {
            position: relative;
        }

        .tag-suggestions-dropdown {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background-color: var(--color-card);
            border: 1px solid var(--color-border);
            border-radius: 0 0 var(--radius-md) var(--radius-md);
            box-shadow: var(--shadow-md);
            z-index: 100;
            max-height: 180px;
            overflow-y: auto;
        }

        .tag-suggestion-item {
            padding: 8px 12px;
            cursor: pointer;
            color: var(--color-text-primary);
            transition: background-color 0.15s;
        }

        .tag-suggestion-item:hover {
            background-color: var(--color-surface);
        }

        /* Tools */
        .tool-selector {
            display: flex;
            gap: 8px;
            margin-bottom: 12px;
        }

        .tool-selector select {
            flex-grow: 1;
        }

        .tool-list {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .tool-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 12px;
            background-color: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-sm);
        }

        .tool-name {
            font-weight: 500;
            color: var(--color-text-primary);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .tool-name i {
            color: var(--color-text-secondary);
        }

        .tool-empty {
            color: var(--color-text-secondary);
            font-size: 0.85rem;
            text-align: center;
            padding: 12px;
        }

        .gen-config-status { display: flex; align-items: center; gap: 8px; margin: 6px 0; }
        .gen-config-badge { padding: 2px 10px; border-radius: 12px; font-size: 0.78em; font-weight: 600; }
        .gen-config-badge.private { background: rgba(100,200,100,0.15); color: #6c6; }
        .gen-config-badge.preset { background: rgba(100,150,255,0.15); color: #8af; }
        .gen-config-hint { font-size: 0.8em; color: #888; }

        /* Settings actions */
        .settings-actions {
            padding-top: 8px;
        }

        /* Popup */
        .shimmer-popup-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(0, 0, 0, 0.6);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
            backdrop-filter: blur(4px);
        }

        .shimmer-popup-content {
            background-color: var(--color-card);
            padding: 24px;
            border-radius: var(--radius-xl);
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--color-border);
            max-width: 90vw;
            max-height: 90vh;
            overflow-y: auto;
            min-width: 300px;
            width: fit-content;
        }

        .popup-actions {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            margin-top: 20px;
        }

        /* Portrait / narrow screen */
        @@media (max-width: 768px) {
            .agent-tabs {
