@page "/agent/{agentguid}"
@using ShimmerChatLib.Models
@using ShimmerChatLib.Generation
@using ShimmerChatBuiltin.Generation.Nodes
@using System.Diagnostics
@using System.Threading
@inject NavigationManager navigation
@inject IKVDataService kvDataService
@inject IPopupService PopupService
@inject IJSRuntime JS
@inject IMessageStoreService messageStore
@inject IGenerationNodeSerializer Serializer
@inject ILocService Loc
@inject ILogger<AgentPage> logger

@if(agent != null)
{
    <div class="agent-page-container shimmer-content" style="background-image: url('@BackgroudPath'); background-size: cover; background-position: center; min-height: 100vh;">
        <div class="agent-header">
            <button class="agent-back-btn" @onclick="NavigateBack" title="@Loc["agent.back"]">
                <i class="bi bi-arrow-left"></i>
            </button>
            @if (agent.AvatarGuid != null)
            {
                <img class="agent-header-avatar" src="@AvatarPath" alt="@Loc["agent.avatar_alt"]" />
            }
            else
            {
                <div class="agent-header-avatar agent-avatar-placeholder" style="background-color: @GetAvatarColor(agent.Name)">
                    @GetAvatarInitial(agent.Name)
                </div>
            }
            <div class="agent-header-info">
                <h2>@agent.Name</h2>
                @if(!string.IsNullOrWhiteSpace(agent.UserIntro))
                {
                    <p class="agent-header-desc">@agent.UserIntro</p>
                }
            </div>
        </div>

        <div class="agent-tabs">
            <button class="agent-tab @(activeTab == "chats" ? "active" : "")" @onclick='() => activeTab = "chats"'>
                <i class="bi bi-chat-dots"></i> <span>@Loc["agent.tab_chats"]</span>
            </button>
            <button class="agent-tab @(activeTab == "settings" ? "active" : "")" @onclick='() => activeTab = "settings"'>
                <i class="bi bi-sliders"></i> <span>@Loc["agent.tab_settings"]</span>
            </button>
        </div>

        <div id="content">
        <div class="content-wrapper">
            <div id="left-section" class="@(activeTab == "chats" ? "tab-active" : "tab-hidden")">

                <div class="chat-toolbar su-group">
                    <input class="shimmer-input chat-search-input"
                           placeholder="@Loc["agent.search_chats_placeholder"]"
                           value="@ChatSearchQuery"
                           @oninput="OnChatSearchInput" />
                    <div class="chat-toolbar-row">
                        <label class="fulltext-toggle">
                            <input type="checkbox" checked="@EnableFullTextSearch" @onchange="OnEnableFullTextSearchChanged" />
                            @Loc["agent.full_text_search"]
                        </label>
                        <div class="chat-toolbar-meta">
                            <span>@Loc.Format("agent.search_results", FilteredChatSummaries.Count)</span>
                            @if (IsSearchInProgress)
                            {
                                <span class="search-loading">@Loc["agent.searching"]</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="chat-section chat-list">
                    <div class="chat-item new-chat-item" @onclick="NewChat">
                        <i class="bi bi-plus-lg chat-item-icon"></i>
                        <div class="chat-info">
                            <div class="chat-name">@Loc["agent.new_chat"]</div>
                        </div>
                    </div>

                    @if (CanUseVirtualizedList)
                    {
                        <Virtualize ItemsProvider="LoadChatSummariesAsync" Context="summary" @ref="chatVirtualize">
                            <ItemContent>
                                <div class="chat-item" @onclick="() => OpenChatSummary(summary)">
                                    <div class="chat-info">
                                        <div class="chat-name">@summary.Name</div>
                                        <div class="chat-last-message">@summary.LastMessagePreview</div>
                                    </div>
                                    <button class="chat-delete-btn" @onclick:stopPropagation @onclick="() => ShowDeleteChatConfirmation(summary)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </ItemContent>
                            <Placeholder>
                                <div class="chat-item chat-item-placeholder">
                                    <div class="chat-info">
                                        <div class="chat-name">@Loc["agent.loading"]</div>
                                        <div class="chat-last-message">@Loc["agent.please_wait"]</div>
                                    </div>
                                </div>
                            </Placeholder>
                        </Virtualize>
                    }
                    else
                    {
                        @foreach (var summary in PagedChatSummaries)
                        {
                            <div class="chat-item" @onclick="() => OpenChatSummary(summary)">
                                <div class="chat-info">
                                    <div class="chat-name">@summary.Name</div>
                                    <div class="chat-last-message">@summary.LastMessagePreview</div>
                                </div>
                                <button class="chat-delete-btn" @onclick:stopPropagation @onclick="() => ShowDeleteChatConfirmation(summary)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        }

                        @if (!PagedChatSummaries.Any() && !IsSearchInProgress)
                        {
                            <div class="chat-empty">
                                <i class="bi bi-inbox"></i>
                                <p>@Loc["agent.no_chats"]</p>
                            </div>
                        }

                        <div class="pagination-bar su-group">
                            <div class="pagination-left">
                                <button class="su-btn su-btn-secondary su-btn-sm" @onclick="GoToPreviousPage" disabled="@(CurrentPage <= 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                                <span>@CurrentPage / @TotalPages</span>
                                <button class="su-btn su-btn-secondary su-btn-sm" @onclick="GoToNextPage" disabled="@(CurrentPage >= TotalPages)">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </div>
                            <div class="pagination-right">
                                <select class="shimmer-input page-size-select" value="@PageSize" @onchange="OnPageSizeChanged">
                                    @foreach (var option in PageSizeOptions)
                                    {
                                        <option value="@option">@option</option>
                                    }
                                </select>
                            </div>
                        </div>
                    }
                </div>
                
                @if (DeleteChatPopupVisible)
                {
                    <div class="su-modal-mask" @onclick="() => DeleteChatPopupVisible=false">
                        <div class="su-modal su-modal-sm su-p-4" @onclick:stopPropagation>
                            <h5>@Loc["agent.delete_chat_title"]</h5>
                            <p>@Loc.Format("agent.delete_chat_msg", ChatToDelete?.Name ?? "No Name")</p>
                            <div class="su-modal-footer">
                                <button class="su-btn su-btn-secondary" @onclick="() => DeleteChatPopupVisible=false">Cancel</button>
                                <button class="su-btn su-btn-danger" @onclick="DeleteChatConfirmed">Delete</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="settings-section su-group @(activeTab == "settings" ? "tab-active" : "tab-hidden")">
                <div class="settings-scroll">
                    <div class="settings-group">
                        <h4><i class="bi bi-person-gear"></i> @Loc["agent.section_basic_info"]</h4>
                        <div class="settings-field">
                            <label>@Loc["agent.label_name"]</label>
                            <input class="shimmer-input" @bind="Name"/>
                        </div>
                        <div class="settings-field">
                            <label>@Loc["agent.label_introduction"]</label>
                            <textarea class="shimmer-textarea" @bind="UserIntro" rows="3" placeholder="@Loc["agent.introduction_placeholder"]" />
                        </div>
                    </div>

                    <div class="settings-group">
                        <h4><i class="bi bi-tags"></i> @Loc["agent.section_tags"]</h4>
                        <div class="tag-editor-wrapper">
                            <div class="tag-editor-chips">
                                @if (agent?.Tags != null)
                                {
                                    @foreach (var tag in agent.Tags)
                                    {
                                        <span class="agent-tag-chip">
                                            @tag
                                            <button class="tag-remove-btn" @onclick="() => RemoveTag(tag)">×</button>
                                        </span>
                                    }
                                }
                            </div>
                            <div class="tag-input-wrapper">
                                <input class="shimmer-input tag-autocomplete-input" type="text"
                                    @bind="NewTagInput" @bind:event="oninput"
                                    @onkeydown="OnTagKeyDown"
                                    @onfocus="() => ShowTagAutocomplete = true"
                                    @onfocusout="OnTagAutocompleteFocusOut"
                                    placeholder="@Loc["agent.add_tag_placeholder"]" />
                                @if (ShowTagAutocomplete && TagSuggestions.Count > 0)
                                {
                                    <div class="tag-suggestions-dropdown">
                                        @foreach (var suggestion in TagSuggestions)
                                        {
                                            <div class="tag-suggestion-item" @onmousedown="() => SelectTagSuggestion(suggestion)" @onmousedown:preventDefault>
                                                @suggestion
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="settings-group">
                        <h4><i class="bi bi-chat-heart"></i> @Loc["agent.section_greetings"]</h4>
                        <div class="settings-field">
                            <label>@Loc["agent.label_greeting"]</label>
                            <textarea class="shimmer-textarea" @bind="Greeting" rows="3" />
                        </div>
                        <div class="settings-field">
                            <label>@Loc["agent.label_alt_greetings"]</label>
                            <div class="alt-greetings-list">
                                @if (agent?.AlternativeGreetings != null)
                                {
                                    var idx = 0;
                                    foreach (var g in agent.AlternativeGreetings.ToList())
                                    {
                                        var i = idx++;
                                        <div class="alt-greeting-row">
                                            <textarea class="shimmer-textarea" rows="2"
                                                @bind="agent.AlternativeGreetings[i]" @bind:event="oninput" @bind:after="OnAltGreetingChanged"
                                                placeholder="@Loc["agent.alt_greeting_placeholder"]" />
                                            <button class="su-btn su-btn-sm su-btn-outline-danger alt-greeting-remove"
                                                @onclick="() => RemoveAltGreeting(i)" title="@Loc["agent.remove"]">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    }
                                }
                                <button class="su-btn su-btn-sm su-btn-outline" @onclick="AddAltGreeting">
                                    <i class="bi bi-plus-lg"></i> @Loc["agent.add_greeting"]
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="settings-group">
                        <h4><i class="bi bi-image"></i> @Loc["agent.section_avatar_bg"]</h4>
                        <div class="media-upload-row">
                            <div class="media-upload-item">
                                @if (agent!.AvatarGuid != null)
                                {
                                    <img id="avatar-preview" src="@AvatarPath" alt="avatar"/>
                                }
                                else
                                {
                                    <div id="avatar-preview" class="agent-avatar-placeholder" style="background-color: @GetAvatarColor(agent.Name)">
                                        @GetAvatarInitial(agent.Name)
                                    </div>
                                }
                                <InputFile OnChange="InputAvatar" accept="image/png" />
                            </div>
                            <div class="media-upload-item">
                                <span class="media-label">@Loc["agent.bg_image"]</span>
                                <InputFile OnChange="InputBackground" accept="image/png" />
                            </div>
                        </div>
                    </div>

                    <div class="settings-group">
                        <h4><i class="bi bi-diagram-3"></i> @Loc["agent.section_gen_config"]</h4>
                        <div class="settings-field">
                            <label>@Loc["agent.label_modifier_tree"]</label>
                            @if (!string.IsNullOrEmpty(agent?.ModifierTreeJson))
                            {
                                <div class="gen-config-status">
                                    <span class="gen-config-badge private">@Loc["agent.badge_private_tree"]</span>
                                    <span class="gen-config-hint">@Loc["agent.private_tree_hint"]</span>
                                </div>
                                <div style="margin-top:8px; display:flex; gap:8px;">
                                    <button class="su-btn su-btn-primary su-btn-sm" @onclick="EditPrivateTree">
                                        <i class="bi bi-pencil"></i> @Loc["agent.edit_private_tree"]
                                    </button>
                                    <button class="su-btn su-btn-outline su-btn-sm" @onclick="RevertToPreset">
                                        <i class="bi bi-arrow-counterclockwise"></i> @Loc["agent.revert_to_preset"]
                                    </button>
                                </div>
                            }
                            else
                            {
                                <div class="gen-config-status">
                                    <span class="gen-config-badge preset">@Loc["agent.badge_using_preset"]</span>
                                    <span class="gen-config-hint">@Loc["agent.using_preset_hint"]</span>
                                </div>
                                <div style="margin-top:8px; display:flex; gap:8px; align-items:center;">
                                    <select class="shimmer-input" style="flex:1;max-width:300px;" @bind="_selectedPresetId">
                                        <option value="">@Loc["agent.no_preset"]</option>
                                        @foreach (var p in _availablePresets)
                                        {
                                            <option value="@p.Id">@p.Name</option>
                                        }
                                    </select>
                                    <button class="su-btn su-btn-outline-primary su-btn-sm" @onclick="CreatePrivateTree">
                                        <i class="bi bi-pencil"></i> @Loc["agent.create_private_tree"]
                                    </button>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="settings-group">
                        <h4><i class="bi bi-puzzle"></i> @Loc["agent.section_plugins"]</h4>
                        <ShimmerChatLib.Components.PluginPanelContainer
                            PanelDisplayPlace="ShimmerChatLib.Panel.PanelDisplayPlace.Agent"
                            Parameters="AgentPluginParameters"/>
                    </div>

                    <div class="settings-actions">
                        <button class="su-btn su-btn-primary" @onclick="Export">
                            <i class="bi bi-download"></i> @Loc["agent.export_agent"]
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>


    </div>
}

<!--404-->
@if(agent == null)
{
    <h1>404</h1>
    <p>@Loc.Format("agent.not_exist", agentguid)</p>
}

@code {
    [Parameter]
    public string agentguid { get; set; } = string.Empty;

    private Agent? agent;
    string activeTab = "chats";

    private Dictionary<string, object> AgentPluginParameters => new()
    {
        ["AgentGuid"] = agent?.Guid ?? Guid.Empty,
        ["EventHandlerReg"] = (Action<ShimmerChatLib.Panel.IChatPanelEventHandler>)(handler =>
        {
            if (handler != null)
                _agentEventHandlers.Add(handler);
        })
    };

    List<ShimmerChatLib.Panel.IChatPanelEventHandler> _agentEventHandlers = [];
    string Name
    {
        get => agent?.Name ?? string.Empty;
        set
        {
            if (agent != null)
            {
                agent.Name = value;
                agent.Save(kvDataService);
            }
        }
    }
    string Greeting
    {
        get => agent?.Greeting ?? string.Empty;
        set
        {
            if (agent != null)
            {
                agent.Greeting = value;
                agent.Save(kvDataService);
            }
        }
    }

    string UserIntro
    {
        get => agent?.UserIntro ?? string.Empty;
        set
        {
            if (agent != null)
            {
                agent.UserIntro = value;
                agent.Save(kvDataService);
            }
        }
    }

    string TagsString
    {
        get => agent?.Tags != null ? string.Join(", ", agent.Tags) : string.Empty;
        set
        {
            if (agent != null)
            {
                if (!string.IsNullOrWhiteSpace(value))
                {
                    agent.Tags = value.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
                }
                else
                {
                    agent.Tags = new List<string>();
                }
                agent.Save(kvDataService);
            }
        }
    }

    string NewTagInput { get; set; } = "";
    bool ShowTagAutocomplete { get; set; } = false;
    List<string>? _allExistingTagsCache = null;

    List<string> AllExistingTags
    {
        get
        {
            if (_allExistingTagsCache != null)
                return _allExistingTagsCache;
            LoadAllTags();
            return _allExistingTagsCache!;
        }
    }

    void LoadAllTags()
    {
        var sw = Stopwatch.StartNew();
        var allGuids = Agent.GetAllAgentGuids(kvDataService);
        var allTags = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        int loadedAgents = 0;
        foreach (var guid in allGuids)
        {
            try
            {
                var a = Agent.Load(guid, kvDataService);
                loadedAgents++;
                if (a.Tags != null)
                {
                    foreach (var t in a.Tags)
                        allTags.Add(t);
                }
            }
            catch { }
        }
        _allExistingTagsCache = allTags.OrderBy(t => t).ToList();
        sw.Stop();
        PerfLog($"LoadAllTags done: allAgentGuids={allGuids.Count}, loadedAgents={loadedAgents}, totalTags={_allExistingTagsCache.Count}, elapsedMs={sw.ElapsedMilliseconds}");
    }

    List<string> TagSuggestions
    {
        get
        {
            var input = (NewTagInput ?? "").Trim();
            var all = AllExistingTags;
            if (agent?.Tags != null)
                all = all.Where(t => !agent.Tags.Contains(t)).ToList();
            if (string.IsNullOrEmpty(input))
                return all;
            return all.Where(t => t.Contains(input, StringComparison.OrdinalIgnoreCase)).ToList();
        }
    }

    void AddTag(string tag)
    {
        if (agent == null || string.IsNullOrWhiteSpace(tag))
            return;
        agent.Tags ??= new List<string>();
        if (!agent.Tags.Any(t => t.Equals(tag, StringComparison.OrdinalIgnoreCase)))
        {
            agent.Tags.Add(tag);
            agent.Save(kvDataService);
            if (_allExistingTagsCache != null && !_allExistingTagsCache.Contains(tag, StringComparer.OrdinalIgnoreCase))
                _allExistingTagsCache.Add(tag);
        }
        NewTagInput = "";
        ShowTagAutocomplete = false;
    }

    void RemoveTag(string tag)
    {
        if (agent?.Tags == null)
            return;
        agent.Tags.RemoveAll(t => t.Equals(tag, StringComparison.OrdinalIgnoreCase));
        agent.Save(kvDataService);
    }

    async Task OnTagKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddTag(NewTagInput);
        }
        else if (e.Key == "Escape")
        {
            ShowTagAutocomplete = false;
        }
    }

    async Task OnTagAutocompleteFocusOut()
    {
        await Task.Delay(200);
        ShowTagAutocomplete = false;
    }

    void SelectTagSuggestion(string tag)
    {
        AddTag(tag);
    }

    void AddAltGreeting()
    {
        if (agent == null) return;
        agent.AlternativeGreetings ??= new();
        agent.AlternativeGreetings.Add("");
        agent.Save(kvDataService);
    }

    void RemoveAltGreeting(int index)
    {
        if (agent?.AlternativeGreetings == null || index < 0 || index >= agent.AlternativeGreetings.Count) return;
        agent.AlternativeGreetings.RemoveAt(index);
        agent.Save(kvDataService);
    }

    void OnAltGreetingChanged()
    {
        agent?.Save(kvDataService);
    }

    string AvatarPath => $"/userimages/{agent!.AvatarGuid}.png";
    string BackgroudPath => $"/userimages/{agent!.BackgroundGuid}.png";

    static readonly string[] _avatarColors = new[]
    {
        "#5e6ad2", "#e74c3c", "#2ecc71", "#f39c12", "#1abc9c",
        "#3498db", "#9b59b6", "#e67e22", "#27ae60", "#c0392b",
    };

    static string GetAvatarColor(string name)
    {
        var hash = 0;
        foreach (var c in name ?? "?")
            hash = ((hash << 5) + hash) ^ c;
        return _avatarColors[Math.Abs(hash) % _avatarColors.Length];
    }

    static string GetAvatarInitial(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        return char.ToUpper(name.TrimStart()[0]).ToString();
    }

    bool virtualize = false;
    List<ChatSummary> allChatSummaries = new();
    List<ChatSummary> fullTextMatchedSummaries = new();
    List<ChatSummary> currentPageSummaries = new();
    int loadedPage = -1;
    int loadedPageSize = -1;

    string ChatSearchQuery { get; set; } = string.Empty;
    bool EnableFullTextSearch { get; set; } = false;
    bool IsSearchInProgress { get; set; } = false;
    CancellationTokenSource? searchCts;

    int CurrentPage { get; set; } = 1;
    int PageSize { get; set; } = 20;
    int[] PageSizeOptions { get; } = new[] { 10, 20, 50, 100 };

    IReadOnlyList<ChatSummary> FilteredChatSummaries
    {
        get
        {
            var query = (ChatSearchQuery ?? string.Empty).Trim();
            if (string.IsNullOrEmpty(query))
            {
                return allChatSummaries;
            }

            IEnumerable<ChatSummary> result = allChatSummaries.Where(s =>
                (s.Name?.Contains(query, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (s.LastMessagePreview?.Contains(query, StringComparison.OrdinalIgnoreCase) ?? false));

            if (EnableFullTextSearch && fullTextMatchedSummaries.Count > 0)
            {
                var idSet = fullTextMatchedSummaries.Select(s => s.Guid).ToHashSet();
                result = result.Union(allChatSummaries.Where(s => idSet.Contains(s.Guid)));
            }

            return result.ToList();
        }
    }

    bool IsSearchActive => !string.IsNullOrWhiteSpace(ChatSearchQuery) || EnableFullTextSearch;

    int EffectiveTotalCount => IsSearchActive
        ? FilteredChatSummaries.Count
        : (agent?.GetChatCount() ?? 0);

    int TotalPages => Math.Max(1, (int)Math.Ceiling((double)EffectiveTotalCount / PageSize));

    IReadOnlyList<ChatSummary> PagedChatSummaries
    {
        get
        {
            if (IsSearchActive)
            {
                return FilteredChatSummaries
                    .Skip((CurrentPage - 1) * PageSize)
                    .Take(PageSize)
                    .ToList();
            }

            if (loadedPage != CurrentPage || loadedPageSize != PageSize)
            {
                if (agent != null)
                {
                    currentPageSummaries = agent.GetChatSummariesRange(kvDataService, (CurrentPage - 1) * PageSize, PageSize);
                }
                else
                {
                    currentPageSummaries = new();
                }
                loadedPage = CurrentPage;
                loadedPageSize = PageSize;
            }

            return currentPageSummaries;
        }
    }

    bool CanUseVirtualizedList => virtualize && string.IsNullOrWhiteSpace(ChatSearchQuery) && !EnableFullTextSearch;

    const bool EnablePerfLog = true;
    string PerfNow() => DateTime.Now.ToString("HH:mm:ss.fff");
    void PerfLog(string message)
    {
        if (EnablePerfLog)
        {
            logger.Log( LogLevel.Information,$"[AgentPage][{PerfNow()}] {message}");
        }
    }

    protected override void OnInitialized()
    {
        if (bool.TryParse(kvDataService.Read("App", "virtualize"), out var virt))
        {
            virtualize = virt;
        }
    }

    protected override void OnParametersSet()
    {
        var swTotal = Stopwatch.StartNew();
        PerfLog($"OnParametersSet start: agentguid={agentguid}, virtualize={virtualize}");

        base.OnParametersSet();

        agent = null;

        var swAgentLoad = Stopwatch.StartNew();
        if (Guid.TryParse(agentguid, out var guid))
        {
            try
            {
                agent = Agent.Load(guid, kvDataService);
            }
            catch (Exception)
            {
                agent = null;
            }
        }
        swAgentLoad.Stop();
        PerfLog($"OnParametersSet Agent.Load done: found={(agent != null)}, elapsedMs={swAgentLoad.ElapsedMilliseconds}");

        // ShimmerChat 2.0: tools are now managed via GenerationManager + ToolManager
        LoadPresets();

        var swTags = Stopwatch.StartNew();
        LoadAllTags();
        swTags.Stop();
        PerfLog($"OnParametersSet LoadAllTags done: elapsedMs={swTags.ElapsedMilliseconds}");

        allChatSummaries = new();
        fullTextMatchedSummaries = new();
        currentPageSummaries = new();
        loadedPage = -1;

        CurrentPage = 1;
        swTotal.Stop();
        PerfLog($"OnParametersSet end: totalElapsedMs={swTotal.ElapsedMilliseconds}");
    }

    async Task OnChatSearchInput(ChangeEventArgs e)
    {
        ChatSearchQuery = e.Value?.ToString() ?? string.Empty;
        CurrentPage = 1;

        if (!string.IsNullOrWhiteSpace(ChatSearchQuery) && allChatSummaries.Count == 0)
        {
            LoadAllChatSummaries();
        }

        if (EnableFullTextSearch)
        {
            await RunFullTextSearchAsync();
        }
        else
        {
            fullTextMatchedSummaries = new();
        }

        await RefreshChatsAsync();
    }

    async Task OnEnableFullTextSearchChanged(ChangeEventArgs e)
    {
        EnableFullTextSearch = e.Value is bool b && b;
        CurrentPage = 1;

        if (EnableFullTextSearch)
        {
            if (allChatSummaries.Count == 0)
            {
                LoadAllChatSummaries();
            }
            await RunFullTextSearchAsync();
        }
        else
        {
            searchCts?.Cancel();
            fullTextMatchedSummaries = new();
            IsSearchInProgress = false;
        }

        await RefreshChatsAsync();
    }

    async Task RunFullTextSearchAsync()
    {
        var query = (ChatSearchQuery ?? string.Empty).Trim();
        if (string.IsNullOrEmpty(query) || agent == null)
        {
            fullTextMatchedSummaries = new();
            IsSearchInProgress = false;
            return;
        }

        searchCts?.Cancel();
        searchCts = new CancellationTokenSource();
        var token = searchCts.Token;

        IsSearchInProgress = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            if (allChatSummaries.Count == 0)
            {
                LoadAllChatSummaries();
            }

            var matches = await Task.Run(() =>
            {
                var result = new List<ChatSummary>();
                foreach (var summary in allChatSummaries)
                {
                    token.ThrowIfCancellationRequested();
                    var messages = messageStore.GetMessages(summary.Guid, 0, Math.Max(summary.MessageCount, 1));
                    if (messages.Any(m => (m.message?.Content?.Contains(query, StringComparison.OrdinalIgnoreCase) ?? false)))
                    {
                        result.Add(summary);
                    }
                }
                return result;
            }, token);

            fullTextMatchedSummaries = matches;
        }
        catch (OperationCanceledException)
        {
        }
        finally
        {
            IsSearchInProgress = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    void GoToPreviousPage()
    {
