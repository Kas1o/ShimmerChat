    private async void InputAvatar(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.ContentType != "image/png")
        {
            await PopupService.ShowAsync(Loc["agent.unsupported_file_type"]);
            return;
        }
        if (file.Size > 1024 * 1024 * 30) {
            await PopupService.ShowAsync(Loc["agent.file_too_large"]);
            return;
        }

        Stream stream = file.OpenReadStream(1024 * 1024 * 30, default);
        var guid = Guid.NewGuid();
        using (var localFile = File.Create($"{AppContext.BaseDirectory}/UserUploadImage/{guid}.png"))
        {
            await stream.CopyToAsync(localFile);
        }

        agent!.AvatarGuid = guid;
        agent!.Save(kvDataService);
        StateHasChanged();
    }
