@page "/contextmanager"
@using ShimmerChat.Components.SubComponents
@using ShimmerChatLib.Interface
@using ShimmerChatLib.Context
@inject NavigationManager Navigation
@inject IStringLocalizer<ContextManagerPage> l
@inject IContextModifierService contextModifierService
@inject IPopupService popupService
<h3>@l["TITLE"] </h3>

@if (apiSettings != null)
@if (apiSettings.Count == 0)
{
    <div class="alert alert-warning" style="margin-top: 20px;">
        <h4>@l["NO_API_SETTING_FOUND_TITLE"]</h4>
        <p>@l["NO_API_SETTING_FOUND_CONTENT"]</p>
        <button class="btn btn-primary" @onclick="NavigateToApiSettings">@l["GO_API_SETTING_BUTTON"]</button>
    </div>
}
else
{
    @if (UsingOpenAIAndTextCompletion)
    {
        <h5 style="color:red">
            @l["USE_OPENAI_TEXT_COMPLETION_WARNING"]
        </h5>
    }
}

<!-- 预设管理栏 -->
<div class="shimmer-group" style="margin-top:16px;">
    <h5>@l["PRESET_LABEL"]</h5>
    <select @bind="_selectedPresetId" class="form-select" style="max-width: 400px;">
        @foreach (var preset in contextModifierService.Presets)
        {
            <option value="@preset.Id">@preset.Name</option>
        }
    </select>
    <div style="margin-top: 8px;">
        <button class="btn btn-primary btn-sm" @onclick="ShowNewPresetDialog">@l["PRESET_NEW"]</button>
        <button class="btn btn-secondary btn-sm" style="margin-left: 5px;" @onclick="CloneCurrentPreset">@l["PRESET_CLONE"]</button>
        <button class="btn btn-secondary btn-sm" style="margin-left: 5px;" @onclick="ShowRenamePresetDialog">@l["PRESET_RENAME"]</button>
        <button class="btn btn-danger btn-sm" style="margin-left: 5px;" @onclick="() => DeleteCurrentPreset()"
                disabled="@(contextModifierService.Presets.Count <= 1)">@l["PRESET_DELETE"]</button>
    </div>
</div>

<!-- 预设命名弹窗 -->
@if (_showPresetNameDialog)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@_presetNameDialogTitle</h5>
                    <button type="button" class="btn-close" @onclick="HidePresetNameDialog"></button>
                </div>
                <div class="modal-body">
                    <input type="text" class="form-control" @bind="_presetNameInput"
                           @bind:event="oninput" placeholder="@l["PRESET_NAME_PLACEHOLDER"]" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="HidePresetNameDialog">@l["CANCEL"]</button>
                    <button type="button" class="btn btn-primary" @onclick="ConfirmPresetName"
                            disabled="@string.IsNullOrWhiteSpace(_presetNameInput)">@l["CONFIRM"]</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- 删除确认弹窗 -->
@if (_showDeleteConfirmDialog)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@l["PRESET_DELETE_CONFIRM_TITLE"]</h5>
                    <button type="button" class="btn-close" @onclick="HideDeleteConfirm"></button>
                </div>
                <div class="modal-body">
                    <p>@l["PRESET_DELETE_CONFIRM_MSG"] <strong>@contextModifierService.ActivePresetName</strong>?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="HideDeleteConfirm">@l["CANCEL"]</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDeletePreset">@l["CONFIRM_DELETE"]</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- 上下文修改器 -->
<div class="shimmer-group" style="margin-top:16px;">
    <h4>@l["CONTEXT_MODIFIER_TITLE"]</h4>
    <button class="btn btn-primary" style="margin:5px" @onclick="ShowAddModifierPopup">@l["CM_ADD"]</button>

    <h5>@l["ACTIVE_CM"]</h5>
    @if (contextModifierService.ActivatedModifiers.Any())
    {
        <div class="list-group" ondragover="event.preventDefault();" @ondrop="() => HandleDrop()">
            @foreach (var modifier in contextModifierService.ActivatedModifiers)
            {
                <div class="list-group-item d-flex justify-content-between align-items-center" 
                     draggable="true" 
                     @ondragstart="() => HandleDragStart(contextModifierService.ActivatedModifiers.IndexOf(modifier))"
                     @ondragover="() => HandleDragOver(contextModifierService.ActivatedModifiers.IndexOf(modifier))"
                     data-index="@contextModifierService.ActivatedModifiers.IndexOf(modifier)">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-grip-vertical" style="margin-right: 10px; cursor: move; color: #6c757d;"></i>
                        <div class="me-2">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" role="switch" 
                                       id="enableSwitch_@contextModifierService.ActivatedModifiers.IndexOf(modifier)" 
                                       @bind="modifier.IsEnabled">
                                <label class="form-check-label" for="enableSwitch_@contextModifierService.ActivatedModifiers.IndexOf(modifier)">
                                    <strong>@modifier.Name</strong>
                                </label>
                            </div>
                            @{
                                var preview = modifier.Config?.ToString() ?? "";
                            }
                            @if (!string.IsNullOrEmpty(preview))
                            {
                                <small class="d-block text-muted">@preview</small>
                            }
                        </div>
                    </div>
                    <div>
                        <button class="btn btn-outline-primary btn-sm me-2" @onclick="() => ShowEditModifierPopup(contextModifierService.ActivatedModifiers.IndexOf(modifier))">@l["EDIT"]</button>
                        <button class="btn btn-danger btn-sm" @onclick="() => RemoveModifier(contextModifierService.ActivatedModifiers.IndexOf(modifier))">@l["REMOVE"]</button>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">@l["NO_ACTIVE_CM"]</p>
    }
</div>

<button class="btn btn-primary" style="margin:5px" @onclick="SaveAll">@l["SAVE"]</button>

    @if (_showAddModifierPopup)
    {
        <AddContextModifierPopup @ref="_addModifierPopup" OnConfirm="(result) => OnAddModifierConfirmed(result)" OnClose="() => HideAddModifierPopup()" />
    }
    
    @if (_showEditModifierPopup)
    {
        <EditContextModifierPopup @ref="_editModifierPopup" 
                                  ModifierName="@_editingModifierName" 
                                  Config="@_editingModifierConfig"
                                  OnConfirm="(result) => OnEditModifierConfirmed(result)" 
                                  OnClose="() => HideEditModifierPopup()" />
    }

@code {
    [Inject]
    public required IKVDataService KVData { get; set; }

    List<ApiSetting>? apiSettings { get; set; }
    private int _selectedAPIIndex { get; set; }

    protected override void OnInitialized()
    {
        var apisettings = KVData.Read("ApiSettings", "apiSetting") ?? "null";
        apiSettings = Newtonsoft.Json.JsonConvert.DeserializeObject<List<ApiSetting>>(apisettings);
        var selectedIndex = KVData.Read("ApiSettings", "selectedAPIIndex") ?? "0";
        _selectedAPIIndex = int.Parse(selectedIndex);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(1);
            contextModifierService.LoadActivatedModifiers();
        }
    }

    private AddContextModifierPopup? _addModifierPopup;
    private EditContextModifierPopup? _editModifierPopup;

    private bool _showEditModifierPopup = false;
    private string? _editingModifierName;
    private ModifierConfig? _editingModifierConfig;
    private int _editingModifierIndex = -1;

    private bool UsingOpenAIAndTextCompletion =>
        apiSettings.Count > 0 && _selectedAPIIndex >= 0 && _selectedAPIIndex < apiSettings.Count
            ? (apiSettings[_selectedAPIIndex].CompletionType == ShimmerChatLib.CompletionType.TextCompletion) && (apiSettings[_selectedAPIIndex].Type == ApiSettingType.OpenAI)
            : false;

    private void SaveAll()
    {
        contextModifierService.SaveActivatedModifiers();
        Navigation.NavigateTo(Navigation.Uri, true);
    }

    private void NavigateToApiSettings()
    {
        Navigation.NavigateTo("/apisettings");
    }

    private bool _showAddModifierPopup = false;

    private void ShowAddModifierPopup()
    {
        _showAddModifierPopup = true;
    }

    private void HideAddModifierPopup()
    {
        _showAddModifierPopup = false;
    }

    private void OnAddModifierConfirmed(object result)
    {
        var modifierInfo = result as dynamic;
        if (modifierInfo != null)
        {
            string modifierName = modifierInfo.ModifierName;
            ModifierConfig config = modifierInfo.Config;
            contextModifierService.ActivateModifier(modifierName, config);
        }
        HideAddModifierPopup();
    }

    private void ShowEditModifierPopup(int index)
    {
        if (index >= 0 && index < contextModifierService.ActivatedModifiers.Count)
        {
            _editingModifierIndex = index;
            var modifier = contextModifierService.ActivatedModifiers[index];
            _editingModifierName = modifier.Name;
            _editingModifierConfig = modifier.Config;
            _showEditModifierPopup = true;
        }
    }

    private void HideEditModifierPopup()
    {
        _showEditModifierPopup = false;
        _editingModifierIndex = -1;
        _editingModifierName = null;
        _editingModifierConfig = null;
    }

    private void OnEditModifierConfirmed(object result)
    {
        var modifierInfo = result as dynamic;
        if (modifierInfo != null && _editingModifierIndex >= 0)
        {
            string modifierName = modifierInfo.ModifierName;
            ModifierConfig config = modifierInfo.Config;

            if (_editingModifierIndex < contextModifierService.ActivatedModifiers.Count && 
                contextModifierService.ActivatedModifiers[_editingModifierIndex].Name == modifierName)
            {
                contextModifierService.ActivatedModifiers[_editingModifierIndex].Config = config;
                contextModifierService.SaveActivatedModifiers();
            }
        }
        HideEditModifierPopup();
    }

    private int _dragIndex = -1;
    private int _dropTargetIndex = -1;

    private void HandleDragStart(int index)
    {
        _dragIndex = index;
    }

    private void HandleDragOver(int index)
    {
        _dropTargetIndex = index;
    }

    private void HandleDrop()
    {
        if (_dragIndex == -1 || _dropTargetIndex == -1 || _dragIndex == _dropTargetIndex)
            return;

        contextModifierService.ReorderActivatedModifier(_dragIndex, _dropTargetIndex);
        _dragIndex = -1;
        _dropTargetIndex = -1;
    }

    private void RemoveModifier(int modifierIdx)
    {
        contextModifierService.RemoveActivatedModifier(modifierIdx);
    }

    // ---- 预设管理 ----
    private string _selectedPresetId
    {
        get => contextModifierService.ActivePresetId;
        set
        {
            if (value != contextModifierService.ActivePresetId)
                contextModifierService.SwitchToPreset(value);
        }
    }

    private bool _showPresetNameDialog = false;
    private string _presetNameDialogTitle = "";
    private string _presetNameInput = "";
    private bool _presetNameIsRename = false;

    private bool _showDeleteConfirmDialog = false;

    private void ShowNewPresetDialog()
    {
        _presetNameIsRename = false;
        _presetNameInput = "";
        _presetNameDialogTitle = l["PRESET_NEW_TITLE"];
        _showPresetNameDialog = true;
    }

    private void ShowRenamePresetDialog()
    {
        _presetNameIsRename = true;
        _presetNameInput = contextModifierService.ActivePresetName;
        _presetNameDialogTitle = l["PRESET_RENAME_TITLE"];
        _showPresetNameDialog = true;
    }

    private void HidePresetNameDialog()
    {
        _showPresetNameDialog = false;
        _presetNameInput = "";
    }

    private void ConfirmPresetName()
    {
        if (string.IsNullOrWhiteSpace(_presetNameInput))
            return;

        if (_presetNameIsRename)
        {
            contextModifierService.RenamePreset(contextModifierService.ActivePresetId, _presetNameInput.Trim());
        }
        else
        {
            contextModifierService.CreatePreset(_presetNameInput.Trim());
        }
        HidePresetNameDialog();
    }

    private void CloneCurrentPreset()
    {
        var activePreset = contextModifierService.Presets
            .FirstOrDefault(p => p.Id == contextModifierService.ActivePresetId);
        if (activePreset == null)
            return;

        var baseName = activePreset.Name;
        var newName = baseName + " - Copy";
        var counter = 2;
        while (contextModifierService.Presets.Any(p => p.Name == newName))
        {
            newName = $"{baseName} - Copy ({counter})";
            counter++;
        }

        contextModifierService.CreatePreset(newName);

        var newPreset = contextModifierService.Presets
            .FirstOrDefault(p => p.Name == newName);
        if (newPreset != null)
        {
            newPreset.Modifiers = activePreset.Modifiers
                .Select(m => new ActivatedModifier { Name = m.Name, Config = m.Config, IsEnabled = m.IsEnabled })
                .ToList();
            contextModifierService.SaveActivatedModifiers();
        }
    }

    private void DeleteCurrentPreset()
    {
        if (contextModifierService.Presets.Count <= 1)
            return;
        _showDeleteConfirmDialog = true;
    }

    private void HideDeleteConfirm()
    {
        _showDeleteConfirmDialog = false;
    }

    private void ConfirmDeletePreset()
    {
        contextModifierService.DeletePreset(contextModifierService.ActivePresetId);
        _showDeleteConfirmDialog = false;
    }
}