@page "/misc"

@using Microsoft.JSInterop
@inject IKVDataService KVData
@inject IJSRuntime JS
@inject ILocService Loc

<h3>@Loc["misc.title"]</h3>

<div class="su-group">
	<h4>@Loc["misc.app_settings"]</h4>

	<input type="checkbox" id="throw-exception" @bind="_throwExceptionInsteadOfPopupErrorMessage" />
	<label for="throw-exception">@Loc["misc.throw_exception"]</label>
	
	<input type="checkbox" id="enable-notifications" @bind="_enableNotifications" />
	<label for="enable-notifications">@Loc["misc.enable_notifications"]</label>
	
	<button class="su-btn su-btn-outline-primary" @onclick="RequestNotificationPermission" style="margin-left: 10px;">@Loc["misc.request_notification_permission"]</button>
	<span style="margin-left: 10px;">@Loc["misc.current_status"] <strong>@notificationPermissionStatus</strong></span>

	<input type="checkbox" id="auto-scroll-down" @bind="_autoScrollDown" />
	<label for="auto-scroll-down">@Loc["misc.auto_scroll"]</label>

	<input type="checkbox" id="auto-scroll-down" @bind="_virtualize" />
	<label for="auto-scroll-down">@Loc["misc.virtualize"]</label>
</div>

<div class="su-group">
	<h4>@Loc["misc.display_settings"]</h4>

	<input type="checkbox" id="thinking-collapsed" @bind="_thinkingCollapsed" />
	<label for="thinking-collapsed">@Loc["misc.thinking_collapsed"]</label>

	<input type="checkbox" id="toolcall-collapsed" @bind="_toolCallCollapsed" />
	<label for="toolcall-collapsed">@Loc["misc.tool_call_collapsed"]</label>

	<input type="checkbox" id="toolresult-collapsed" @bind="_toolResultCollapsed" />
	<label for="toolresult-collapsed">@Loc["misc.tool_result_collapsed"]</label>
</div>

<div class="su-group">
	<h4>@Loc["misc.user_settings"]</h4>

	<label for="username">@Loc["misc.user_name"]</label>
	<input type="text" class="su-input" id="username" @bind="_UserName" />
</div>

@code {
	private bool _throwExceptionInsteadOfPopupErrorMessage
	{
		get => field;
		set
		{
			if (field == value) return;
			field = value;
			Save();
		}
	} = false;

	private bool _enableNotifications
	{
		get => field;
		set
		{
			if (field == value) return;
			field = value;
			Save();
		}
	} = false;

	private string _UserName
	{
		get => field;
		set
		{
			if (field == value) return;
			field = value;
			Save();
		}
	} = "";

	private bool _autoScrollDown
	{
		get => field;
		set
		{
			if (field == value) return;
			field = value;
			Save();
		}
	} = true;

	private bool _virtualize
	{
		get => field;
		set
		{
			if (field == value) return;
			field = value;
			Save();
		}
	} = true;

	private bool _thinkingCollapsed
	{
		get => field;
		set
		{
			if (field == value) return;
			field = value;
			Save();
		}
	} = true;

	private bool _toolCallCollapsed
	{
		get => field;
		set
		{
			if (field == value) return;
			field = value;
			Save();
		}
	} = true;

	private bool _toolResultCollapsed
	{
		get => field;
		set
		{
			if (field == value) return;
			field = value;
			Save();
		}
	} = true;


	private string notificationPermissionStatus = "";

	bool Initialized = false;
	private void Save()
	{
		if (!Initialized) return;
		KVData.Write("App", "throw_exception", _throwExceptionInsteadOfPopupErrorMessage ? "true": "false");
		KVData.Write("App", "enable_notifications", _enableNotifications ? "true": "false");
		KVData.Write("App", "auto_scroll_down", _autoScrollDown ? "true": "false");
		KVData.Write("App", "virtualize", _virtualize ? "true" : "false");
		KVData.Write("App", "thinking_collapsed", _thinkingCollapsed ? "true" : "false");
		KVData.Write("App", "toolcall_collapsed", _toolCallCollapsed ? "true" : "false");
		KVData.Write("App", "toolresult_collapsed", _toolResultCollapsed ? "true" : "false");
		KVData.Write("User", "username", _UserName);
	}

	protected override async Task OnInitializedAsync()
	{
		if(bool.TryParse(KVData.Read("App", "throw_exception"), out var result)){
			_throwExceptionInsteadOfPopupErrorMessage = result;
		}
		if(bool.TryParse(KVData.Read("App", "enable_notifications"), out var notificationResult)){
			_enableNotifications = notificationResult;
		}
		if (bool.TryParse(KVData.Read("App", "auto_scroll_down"), out var autoscroll))
		{
			_autoScrollDown = autoscroll;
		}
		if (bool.TryParse(KVData.Read("App", "virtualize"), out var virtualize))
		{
			_virtualize = virtualize;
		}
		if (bool.TryParse(KVData.Read("App", "thinking_collapsed"), out var thinkingCollapsed))
		{
			_thinkingCollapsed = thinkingCollapsed;
		}
		if (bool.TryParse(KVData.Read("App", "toolcall_collapsed"), out var toolCallCollapsed))
		{
			_toolCallCollapsed = toolCallCollapsed;
		}
		if (bool.TryParse(KVData.Read("App", "toolresult_collapsed"), out var toolResultCollapsed))
		{
			_toolResultCollapsed = toolResultCollapsed;
		}
		_UserName = KVData.Read("User", "username") ?? "";
		Initialized = true;
		
		// 获取当前通知权限状态
		var jsPermission = await JS.InvokeAsync<string>("eval", "Notification.permission");
		notificationPermissionStatus = jsPermission?.ToLowerInvariant() switch
		{
			"granted" => Loc["misc.notification_granted"],
			"denied" => Loc["misc.notification_denied"],
			_ => Loc["misc.notification_unknown"]
		};
		StateHasChanged();
	}
	
	private async Task RequestNotificationPermission()
	{
		var granted = await JS.InvokeAsync<bool>("requestNotificationPermission");
		if (granted)
		{
			notificationPermissionStatus = Loc["misc.notification_granted"];
			// 同时启用通知设置
			_enableNotifications = true;
		}
		else
		{
			notificationPermissionStatus = Loc["misc.notification_denied"];
		}
		StateHasChanged();
	}
}
