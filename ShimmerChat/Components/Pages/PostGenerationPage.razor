@page "/postgeneration"
@using ShimmerChatLib.Generation
@using ShimmerChatLib.Components
@using ShimmerChatBuiltin.Generation.Nodes
@inject NavigationManager Navigation
@inject IKVDataService KVData
@inject PostGenerationNodeSerializer Serializer
@inject INodeTypeCatalog NodeTypeCatalog
@inject IJSRuntime JS
@inject ILocService Loc

<h3>@Loc["post_gen.title"]</h3>

@if (_isAgentMode)
{
    <div class="su-alert su-alert-warning" style="margin-top:16px;">
        <strong>@Loc.Format("post_gen.editing_private_tree", _agentName)</strong>
        <button class="su-btn su-btn-sm su-btn-outline" style="margin-left:12px;" @onclick="BackToAgent">@Loc["post_gen.back_to_agent"]</button>
    </div>
}

@if (!_isAgentMode)
{
    <div class="su-group" style="margin-top:16px;">
        <h5>@Loc["post_gen.preset_management"]</h5>
        <select @bind="_selectedPresetId" class="su-select" style="max-width: 400px;">
            @foreach (var preset in _presets)
            {
                <option value="@preset.Id">@preset.Name @(preset.Id == DefaultPresetId ? Loc["post_gen.default_badge"] : "")</option>
            }
        </select>
        @if (_activePreset != null)
        {
            <div class="preset-id-row" style="margin-top: 6px; display: flex; align-items: center; gap: 6px; max-width: 400px;">
                <span style="font-size: 0.72em; color: #777; white-space: nowrap;">@Loc["post_gen.label_id"]</span>
                <code style="font-size: 0.72em; color: #999; font-family: monospace; overflow: hidden; text-overflow: ellipsis; flex: 1; cursor: pointer; user-select: all; padding: 2px 4px; background: rgba(255,255,255,0.03); border-radius: 3px;">
                    @_activePreset.Id
                </code>
                <button class="su-btn su-btn-sm su-btn-outline" style="font-size: 0.65em; padding: 1px 6px;" @onclick="CopyPresetId">@Loc["post_gen.copy_id"]</button>
            </div>
        }
        <div style="margin-top: 8px;">
            <button class="su-btn su-btn-primary su-btn-sm" @onclick="CreateNewPreset">@Loc["post_gen.new_preset"]</button>
            <button class="su-btn su-btn-secondary su-btn-sm" style="margin-left: 5px;" @onclick="StartRename"
                    disabled="@(_activePreset?.Id == DefaultPresetId)">@Loc["post_gen.rename"]</button>
            <button class="su-btn su-btn-secondary su-btn-sm" style="margin-left: 5px;" @onclick="CloneCurrentPreset">@Loc["post_gen.clone"]</button>
            <button class="su-btn su-btn-danger su-btn-sm" style="margin-left: 5px;" @onclick="DeleteCurrentPreset"
                    disabled="@(_presets.Count <= 1 || _activePreset?.Id == DefaultPresetId)">@Loc["Delete"]</button>
        </div>
    </div>
}

@if (_showNameDialog)
{
    <div class="su-modal-mask" @onclick="() => _showNameDialog = false">
        <div class="su-modal su-modal-sm" @onclick:stopPropagation="true">
            <div class="su-modal-header">
                @_nameDialogTitle
                <button class="su-btn-close" @onclick="() => _showNameDialog = false">&times;</button>
            </div>
            <div class="su-modal-body">
                <input type="text" class="su-input" @bind="_nameInput" @bind:event="oninput"
                       placeholder="@Loc["post_gen.preset_name_placeholder"]" />
            </div>
            <div class="su-modal-footer">
                <button class="su-btn su-btn-secondary" @onclick="() => _showNameDialog = false">@Loc["Cancel"]</button>
                <button class="su-btn su-btn-primary" @onclick="ConfirmName"
                        disabled="@string.IsNullOrWhiteSpace(_nameInput)">@Loc["post_gen.confirm"]</button>
            </div>
        </div>
    </div>
}

<div style="margin-top:16px;">
    <h4>@Loc["post_gen.modifier_tree"]</h4>
    @if (_isAgentMode)
    {
        <div class="su-card">
            <div class="su-card-body">
                <CascadingValue Value="_dragContext">
                <CascadingValue Value="_editorContext">
                    <TreeEditor Node="@_editingRoot" />
                </CascadingValue>
                </CascadingValue>
            </div>
        </div>
    }
    else if (_activePreset != null)
    {
        <div class="su-card">
            <div class="su-card-body">
                @if (_activePreset.Id == DefaultPresetId)
                {
                    <div class="su-alert su-alert-warning" style="margin-bottom: 12px;">
                        <strong>@Loc["post_gen.default_readonly"]</strong> @Loc["post_gen.default_readonly_hint"]
                    </div>
                    <div style="pointer-events: none; opacity: 0.7;">
                        <TreeEditor Node="@_editingRoot" />
                    </div>
                }
                else
                {
                    <CascadingValue Value="_dragContext">
                    <CascadingValue Value="_editorContext">
                        <TreeEditor Node="@_editingRoot" />
                    </CascadingValue>
                    </CascadingValue>
                }
            </div>
        </div>
    }
    else
    {
        <p>@Loc["post_gen.select_preset_first"]</p>
    }
</div>

<button class="su-btn su-btn-primary" style="margin:16px 5px;" @onclick="SaveAll"
        disabled="@(!_isAgentMode && _activePreset?.Id == DefaultPresetId)">@Loc["Save"]</button>

@code {
    [Parameter] [SupplyParameterFromQuery] public string? agent { get; set; }

    private const string PresetStorageKey = "post_generation_presets";
    private const string DefaultPresetId = "__default__";

    private List<PostGenerationPreset> _presets = new();
    private PostGenerationPreset? _activePreset;
    private ITreeNode _editingRoot = new PostSequenceNode { Name = "Root" };
    private TreeDragContext _dragContext = new();
    private TreeEditorContext _editorContext = default!;

    private bool _isAgentMode;
    private string _agentName = "";
    private Guid _agentGuid;

    private bool _showNameDialog;
    private string _nameDialogTitle = "";
    private string _nameInput = "";
    private string? _renameTargetId;

    private string _selectedPresetId
    {
        get => _activePreset?.Id ?? "";
        set
        {
            var preset = _presets.FirstOrDefault(p => p.Id == value);
            if (preset != null)
            {
                _activePreset = preset;
                _editingRoot = Serializer.Deserialize(preset.RootNodeJson)
                    ?? new PostSequenceNode { Name = "Root" };
            }
        }
    }

    protected override void OnInitialized()
    {
        _editorContext = new TreeEditorContext(Serializer, NodeTypeCatalog, typeof(IPostGenerationNode));

        if (!string.IsNullOrEmpty(agent) && Guid.TryParse(agent, out _agentGuid))
        {
            _isAgentMode = true;
            var ag = Agent.Load(_agentGuid, KVData);
            _agentName = ag.Name;
            _editingRoot = string.IsNullOrEmpty(ag.PostGenerationTreeJson)
                ? new PostSequenceNode { Name = "Root" }
                : Serializer.Deserialize(ag.PostGenerationTreeJson)
                    ?? new PostSequenceNode { Name = "Root" };
            return;
        }

        LoadPresets();
        if (_presets.Count == 0)
        {
            _presets.Add(new PostGenerationPreset { Id = DefaultPresetId, Name = "Default",
                RootNodeJson = Serializer.Serialize(new PostSequenceNode { Name = "Root" }) });
        }
        _activePreset = _presets[0];
        _editingRoot = Serializer.Deserialize(_activePreset.RootNodeJson)
            ?? new PostSequenceNode { Name = "Root" };
    }

    private void LoadPresets()
    {
        var json = KVData.Read("PostGenerationManager", PresetStorageKey);
        _presets = string.IsNullOrEmpty(json)
            ? new()
            : Newtonsoft.Json.JsonConvert.DeserializeObject<List<PostGenerationPreset>>(json) ?? new();
    }

    private void SavePresets()
    {
        KVData.Write("PostGenerationManager", PresetStorageKey,
            Newtonsoft.Json.JsonConvert.SerializeObject(_presets));
    }

    private void CreateNewPreset()
    {
        _renameTargetId = null;
        _nameInput = "";
        _nameDialogTitle = Loc["post_gen.dialog_new_preset"];
        _showNameDialog = true;
    }

    private void StartRename()
    {
        if (_activePreset == null || _activePreset.Id == DefaultPresetId) return;
        _renameTargetId = _activePreset.Id;
        _nameInput = _activePreset.Name;
        _nameDialogTitle = Loc["post_gen.dialog_rename_preset"];
        _showNameDialog = true;
    }

    private void CloneCurrentPreset()
    {
        if (_activePreset == null) return;
        var newName = _activePreset.Name + " (Copy)";
        var counter = 2;
        while (_presets.Any(p => p.Name == newName))
        {
            newName = $"{_activePreset.Name} (Copy {counter})";
            counter++;
        }
        var clone = new PostGenerationPreset { Name = newName, RootNodeJson = _activePreset.RootNodeJson };
        _presets.Add(clone);
        _activePreset = clone;
        _editingRoot = Serializer.Deserialize(clone.RootNodeJson)
            ?? new PostSequenceNode { Name = "Root" };
    }

    private void DeleteCurrentPreset()
    {
        if (_presets.Count <= 1 || _activePreset == null || _activePreset.Id == DefaultPresetId)
            return;
        _presets.Remove(_activePreset);
        _activePreset = _presets[0];
        _editingRoot = Serializer.Deserialize(_activePreset.RootNodeJson)
            ?? new PostSequenceNode { Name = "Root" };
        SavePresets();
    }

    private void ConfirmName()
    {
        if (string.IsNullOrWhiteSpace(_nameInput)) return;

        if (_renameTargetId != null)
        {
            var target = _presets.FirstOrDefault(p => p.Id == _renameTargetId);
            if (target != null) target.Name = _nameInput.Trim();
        }
        else
        {
            var newPreset = new PostGenerationPreset { Name = _nameInput.Trim() };
            _presets.Add(newPreset);
            _activePreset = newPreset;
            _editingRoot = new PostSequenceNode { Name = "Root" };
        }

        _showNameDialog = false;
        _renameTargetId = null;
        SavePresets();
    }

    private void SaveAll()
    {
        if (_editingRoot == null) return;

        if (_isAgentMode)
        {
            var ag = Agent.Load(_agentGuid, KVData);
            ag.PostGenerationTreeJson = Serializer.Serialize(_editingRoot);
            ag.Save(KVData);
            return;
        }

        if (_activePreset != null && _activePreset.Id != DefaultPresetId)
        {
            _activePreset.RootNodeJson = Serializer.Serialize(_editingRoot);
            SavePresets();
        }
    }

    private void BackToAgent()
    {
        Navigation.NavigateTo($"/agent/{_agentGuid}");
    }

    private async Task CopyPresetId()
    {
        if (_activePreset != null)
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _activePreset.Id);
        }
    }
}
