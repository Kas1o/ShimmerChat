@page "/thememanager"
@using ShimmerChatLib.Interface
@using ShimmerChatLib.Models
@inject IThemeService ThemeService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<div class="theme-manager">
    <h2>Theme Manager</h2>

    <div class="theme-actions">
        <button class="su-btn su-btn-primary" @onclick="CreateNewTheme">Create Theme</button>
        <div class="import-btn" style="position:relative;display:inline-block">
            <button class="su-btn su-btn-secondary">Import</button>
            <InputFile OnChange="@OnImportFileSelected" accept=".json" style="position:absolute;inset:0;opacity:0;cursor:pointer" />
        </div>
        <button class="su-btn su-btn-secondary" @onclick="ExportCurrentTheme" disabled="@(selectedTheme == null)">Export</button>
    </div>

    <div class="theme-list">
        <h3>Available Themes</h3>
        <div class="theme-grid">
            @foreach (var theme in themes)
            {
                <div class="theme-card @(theme.Id == ThemeService.CurrentTheme.Id ? "active" : "")" @onclick="() => SelectTheme(theme.Id)">
                    <div class="theme-preview" style="background: @theme.Surface1; color: @theme.Text0; border: 1px solid @theme.Border0;">
                        <h4>@theme.Name</h4>
                        <p>@theme.Description</p>
                        <div class="color-preview">
                            <div class="color-box" style="background: @theme.Accent;" title="Accent"></div>
                            <div class="color-box" style="background: @theme.Success;" title="Success"></div>
                            <div class="color-box" style="background: @theme.Danger;" title="Danger"></div>
                        </div>
                        <div class="theme-meta">
                            <small>@(theme.IsBuiltIn ? "Built-in" : "Custom") @(theme.IsDefault ? " | Default" : "") @(theme.IsDarkMode ? " | Dark" : " | Light")</small>
                        </div>
                    </div>
                    <div class="theme-card-actions">
                        @if (!theme.IsBuiltIn)
                        {
                            <button class="su-btn su-btn-sm su-btn-outline" @onclick="() => EditTheme(theme.Id)" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="su-btn su-btn-sm su-btn-outline" @onclick="() => DeleteTheme(theme.Id)" title="Delete" disabled="@theme.IsDefault">
                                <i class="bi bi-trash"></i>
                            </button>
                        }
                        <button class="su-btn su-btn-sm su-btn-outline" @onclick="() => DuplicateTheme(theme.Id)" title="Duplicate">
                            <i class="bi bi-files"></i>
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>

    @if (showEditor && editingTheme != null)
    {
        <div class="theme-editor-overlay" @onclick="CancelEdit">
            <div class="theme-editor" @onclick:stopPropagation="true">
                <h3>@(editingTheme.IsBuiltIn ? "View Theme" : editingTheme.Id == "new" ? "Create Theme" : "Edit Theme")</h3>

                <div class="su-form-group"><label>Name:</label><input type="text" class="su-input" @bind="editingTheme.Name" /></div>
                <div class="su-form-group"><label>Description:</label><input type="text" class="su-input" @bind="editingTheme.Description" /></div>
                <div style="display:flex;gap:16px;margin-bottom:8px">
                    <label style="display:flex;align-items:center;gap:4px"><input type="checkbox" @bind="editingTheme.IsDefault" /> Default</label>
                    <label style="display:flex;align-items:center;gap:4px"><input type="checkbox" @bind="editingTheme.IsDarkMode" /> Dark mode</label>
                </div>

                <h4>Surface</h4>
                <div class="color-settings-grid">
                    @ColorField("Page bg", editingTheme.Surface0, v => editingTheme.Surface0 = v)
                    @ColorField("Card / Panel", editingTheme.Surface1, v => editingTheme.Surface1 = v)
                    @ColorField("Elevated", editingTheme.Surface2, v => editingTheme.Surface2 = v)
                    @ColorField("Input / Alt", editingTheme.Surface3, v => editingTheme.Surface3 = v)
                </div>

                <h4>Text</h4>
                <div class="color-settings-grid">
                    @ColorField("Primary", editingTheme.Text0, v => editingTheme.Text0 = v)
                    @ColorField("Secondary", editingTheme.Text1, v => editingTheme.Text1 = v)
                    @ColorField("Tertiary", editingTheme.Text2, v => editingTheme.Text2 = v)
                </div>

                <h4>Border</h4>
                <div class="color-settings-grid">
                    @ColorField("Primary", editingTheme.Border0, v => editingTheme.Border0 = v)
                    @ColorField("Subtle", editingTheme.Border1, v => editingTheme.Border1 = v)
                </div>

                <h4>Accent</h4>
                <div class="color-settings-grid">
                    @ColorField("Base", editingTheme.Accent, v => editingTheme.Accent = v)
                    @ColorField("Hover", editingTheme.AccentHover, v => editingTheme.AccentHover = v)
                    @ColorField("Soft bg", editingTheme.AccentSoft, v => editingTheme.AccentSoft = v)
                </div>

                <h4>Semantic</h4>
                <div class="color-settings-grid">
                    @ColorField("Success", editingTheme.Success, v => editingTheme.Success = v)
                    @ColorField("Success bg", editingTheme.SuccessSoft, v => editingTheme.SuccessSoft = v)
                    @ColorField("Warning", editingTheme.Warning, v => editingTheme.Warning = v)
                    @ColorField("Warning bg", editingTheme.WarningSoft, v => editingTheme.WarningSoft = v)
                    @ColorField("Danger", editingTheme.Danger, v => editingTheme.Danger = v)
                    @ColorField("Danger bg", editingTheme.DangerSoft, v => editingTheme.DangerSoft = v)
                    @ColorField("Info", editingTheme.Info, v => editingTheme.Info = v)
                    @ColorField("Info bg", editingTheme.InfoSoft, v => editingTheme.InfoSoft = v)
                </div>

                <h4>Node Colors</h4>
                <div class="color-settings-grid">
                    @ColorField("Flow", editingTheme.NodeFlow, v => editingTheme.NodeFlow = v)
                    @ColorField("Branch", editingTheme.NodeBranch, v => editingTheme.NodeBranch = v)
                    @ColorField("Link", editingTheme.NodeLink, v => editingTheme.NodeLink = v)
                    @ColorField("Fragment", editingTheme.NodeFragment, v => editingTheme.NodeFragment = v)
                    @ColorField("Prompt", editingTheme.NodePrompt, v => editingTheme.NodePrompt = v)
                    @ColorField("Tool", editingTheme.NodeTool, v => editingTheme.NodeTool = v)
                    @ColorField("Memory", editingTheme.NodeMemory, v => editingTheme.NodeMemory = v)
                    @ColorField("Config", editingTheme.NodeConfig, v => editingTheme.NodeConfig = v)
                    @ColorField("SubAgent", editingTheme.NodeSubagent, v => editingTheme.NodeSubagent = v)
                    @ColorField("Debug", editingTheme.NodeDebug, v => editingTheme.NodeDebug = v)
                </div>

                <h4>Shadows / Radii / Spacing</h4>
                <div class="su-form-group"><label>Shadow sm:</label><input type="text" class="su-input" @bind="editingTheme.ShadowSm" /></div>
                <div class="su-form-group"><label>Shadow md:</label><input type="text" class="su-input" @bind="editingTheme.ShadowMd" /></div>
                <div class="su-form-group"><label>Shadow lg:</label><input type="text" class="su-input" @bind="editingTheme.ShadowLg" /></div>
                <div class="su-form-group"><label>Radius sm:</label><input type="text" class="su-input" @bind="editingTheme.RadiusSm" /></div>
                <div class="su-form-group"><label>Radius md:</label><input type="text" class="su-input" @bind="editingTheme.RadiusMd" /></div>
                <div class="su-form-group"><label>Radius lg:</label><input type="text" class="su-input" @bind="editingTheme.RadiusLg" /></div>
                <div style="display:flex;gap:8px">
                    <div class="su-form-group"><label>Space 1:</label><input type="text" class="su-input" @bind="editingTheme.Space1" /></div>
                    <div class="su-form-group"><label>Space 2:</label><input type="text" class="su-input" @bind="editingTheme.Space2" /></div>
                    <div class="su-form-group"><label>Space 4:</label><input type="text" class="su-input" @bind="editingTheme.Space4" /></div>
                    <div class="su-form-group"><label>Space 6:</label><input type="text" class="su-input" @bind="editingTheme.Space6" /></div>
                    <div class="su-form-group"><label>Space 10:</label><input type="text" class="su-input" @bind="editingTheme.Space10" /></div>
                </div>

                <h4>Typography</h4>
                <div class="su-form-group"><label>Font sans:</label><input type="text" class="su-input" @bind="editingTheme.FontSans" /></div>
                <div class="su-form-group"><label>Font mono:</label><input type="text" class="su-input" @bind="editingTheme.FontMono" /></div>
                <div style="display:flex;gap:8px">
                    <div class="su-form-group"><label>xs:</label><input type="text" class="su-input" @bind="editingTheme.FontXs" /></div>
                    <div class="su-form-group"><label>sm:</label><input type="text" class="su-input" @bind="editingTheme.FontSm" /></div>
                    <div class="su-form-group"><label>base:</label><input type="text" class="su-input" @bind="editingTheme.FontBase" /></div>
                    <div class="su-form-group"><label>md:</label><input type="text" class="su-input" @bind="editingTheme.FontMd" /></div>
                    <div class="su-form-group"><label>lg:</label><input type="text" class="su-input" @bind="editingTheme.FontLg" /></div>
                </div>

                <h4>Custom CSS</h4>
                <div class="form-group">
                    <textarea class="su-input custom-css" @bind="editingTheme.CustomCss" placeholder="Custom CSS overrides..."></textarea>
                </div>

                <div class="editor-actions">
                    <button class="su-btn su-btn-primary" @onclick="SaveTheme">Save</button>
                    <button class="su-btn su-btn-secondary" @onclick="CancelEdit">Cancel</button>
                    @if (editingTheme.Id != "new" && !editingTheme.IsBuiltIn)
                    {
                        <button class="su-btn su-btn-danger" @onclick="DeleteCurrentTheme">Delete</button>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Theme> themes = [];
    private bool showEditor;
    private Theme? editingTheme;
    private string? selectedTheme;

    protected override void OnInitialized()
    {
        LoadThemes();
        ThemeService.OnThemeChanged += _ => InvokeAsync(StateHasChanged);
    }

    private void LoadThemes() => themes = ThemeService.AvailableThemes.ToList();

    private void SelectTheme(string id) { ThemeService.SetTheme(id); selectedTheme = id; LoadThemes(); }

    private void CreateNewTheme()
    {
        editingTheme = new Theme { Id = "new", Name = "New Theme", IsBuiltIn = false };
        showEditor = true;
    }

    private void EditTheme(string id)
    {
        var t = themes.FirstOrDefault(x => x.Id == id);
        if (t?.IsBuiltIn == false) { editingTheme = t.Clone(); showEditor = true; }
    }

    private void SaveTheme()
    {
        if (editingTheme == null) return;
        if (editingTheme.Id == "new") { editingTheme.Id = Guid.NewGuid().ToString(); ThemeService.CreateTheme(editingTheme); }
        else ThemeService.UpdateTheme(editingTheme);
        SelectTheme(editingTheme.Id);
        showEditor = false; editingTheme = null;
    }

    private void CancelEdit() { showEditor = false; editingTheme = null; }

    private async Task DeleteTheme(string id)
    {
        var t = themes.FirstOrDefault(x => x.Id == id);
        if (t is { IsBuiltIn: false, IsDefault: false } && await JSRuntime.InvokeAsync<bool>("confirm", $"Delete '{t.Name}'?"))
        { ThemeService.DeleteTheme(id); LoadThemes(); }
    }

    private async Task DeleteCurrentTheme()
    {
        if (editingTheme is { IsBuiltIn: false, IsDefault: false } && await JSRuntime.InvokeAsync<bool>("confirm", $"Delete '{editingTheme.Name}'?"))
        { ThemeService.DeleteTheme(editingTheme.Id); LoadThemes(); showEditor = false; editingTheme = null; }
    }

    private RenderFragment ColorField(string label, string value, Action<string> setter) => builder =>
    {
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "su-form-group");
        builder.OpenElement(2, "label");
        builder.AddContent(3, label + ":");
        builder.CloseElement();
        builder.OpenElement(4, "input");
        builder.AddAttribute(5, "type", "color");
        builder.AddAttribute(6, "class", "su-input color-picker");
        builder.AddAttribute(7, "value", value);
        builder.AddAttribute(8, "onchange", EventCallback.Factory.Create<string>(this, v => { setter(v); StateHasChanged(); }));
        builder.CloseElement();
        builder.OpenElement(9, "input");
        builder.AddAttribute(10, "type", "text");
        builder.AddAttribute(11, "class", "su-input");
        builder.AddAttribute(12, "value", value);
        builder.AddAttribute(13, "onchange", EventCallback.Factory.Create<string>(this, v => { setter(v); StateHasChanged(); }));
        builder.CloseElement();
        builder.CloseElement();
    };

    private void DuplicateTheme(string id)
    {
        var t = themes.FirstOrDefault(x => x.Id == id); if (t == null) return;
        var copy = t.Clone(); copy.Id = Guid.NewGuid().ToString(); copy.Name = t.Name + " (Copy)";
        copy.IsDefault = false; copy.IsBuiltIn = false;
        ThemeService.CreateTheme(copy); LoadThemes();
    }

    private async Task OnImportFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null || (!file.Name.EndsWith(".json", StringComparison.OrdinalIgnoreCase) && file.ContentType != "application/json"))
        { await JSRuntime.InvokeVoidAsync("alert", "Please select a .json file."); return; }
        if (file.Size > 1024 * 1024) { await JSRuntime.InvokeVoidAsync("alert", "File too large (max 1MB)."); return; }
        try
        {
            using var stream = file.OpenReadStream(1024 * 1024);
            using var reader = new StreamReader(stream);
            ThemeService.ImportTheme(await reader.ReadToEndAsync());
            LoadThemes(); await JSRuntime.InvokeVoidAsync("alert", $"Imported '{file.Name}'.");
        }
        catch (Exception ex) { await JSRuntime.InvokeVoidAsync("alert", $"Import failed: {ex.Message}"); }
    }

    private async Task ExportCurrentTheme()
    {
        if (selectedTheme == null) return;
        var json = ThemeService.ExportTheme(selectedTheme);
        var bytes = System.Text.Encoding.UTF8.GetBytes(json);
        using var ms = new MemoryStream(bytes);
        using var streamRef = new DotNetStreamReference(ms);
        await JSRuntime.InvokeVoidAsync("downloadFileFromStream", "theme.json", streamRef);
    }

    public void Dispose() => ThemeService.OnThemeChanged -= _ => InvokeAsync(StateHasChanged);
}
