@page "/thememanager"
@using ShimmerChatLib.Interface
@using ShimmerChatLib.Models
@inject IThemeService ThemeService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject ILocService Loc

<div class="theme-manager">
    <h2>@Loc["theme.title"]</h2>

    <div class="theme-actions">
        <button class="su-btn su-btn-primary" @onclick="CreateNewTheme">@Loc["theme.create"]</button>
        <div class="import-btn" style="position:relative;display:inline-block">
            <button class="su-btn su-btn-secondary">@Loc["theme.import"]</button>
            <InputFile OnChange="@OnImportFileSelected" accept=".json" style="position:absolute;inset:0;opacity:0;cursor:pointer" />
        </div>
        <button class="su-btn su-btn-secondary" @onclick="ExportCurrentTheme" disabled="@(selectedTheme == null)">@Loc["theme.export"]</button>
    </div>

    <div class="theme-list">
        <h3>@Loc["theme.available"]</h3>
        <div class="theme-grid">
            @foreach (var theme in themes)
            {
                <div class="theme-card @(theme.Id == ThemeService.CurrentTheme.Id ? "active" : "")" @onclick="() => SelectTheme(theme.Id)">
                    <div class="theme-preview" style="background: @theme.Surface1; color: @theme.Text0; border: 1px solid @theme.Border0;">
                        <h4>@theme.Name</h4>
                        <p>@theme.Description</p>
                        <div class="color-preview">
                            <div class="color-box" style="background: @theme.Accent;" title="Accent"></div>
                            <div class="color-box" style="background: @theme.Success;" title="Success"></div>
                            <div class="color-box" style="background: @theme.Danger;" title="Danger"></div>
                        </div>
                        <div class="theme-meta">
                            <small>@(theme.IsBuiltIn ? Loc["theme.built_in"] : Loc["theme.custom"]) @(theme.IsDefault ? $" | {Loc["theme.is_default_label"]}" : "") @(theme.IsDarkMode ? $" | {Loc["theme.dark_mode_label"]}" : $" | {Loc["theme.light_mode_label"]}")</small>
                        </div>
                    </div>
                    <div class="theme-card-actions">
                        @if (!theme.IsBuiltIn)
                        {
                            <button class="su-btn su-btn-sm su-btn-outline" @onclick="() => EditTheme(theme.Id)" title="@Loc["theme.edit"]">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="su-btn su-btn-sm su-btn-outline" @onclick="() => DeleteTheme(theme.Id)" title="@Loc["theme.delete"]" disabled="@theme.IsDefault">
                                <i class="bi bi-trash"></i>
                            </button>
                        }
                        <button class="su-btn su-btn-sm su-btn-outline" @onclick="() => DuplicateTheme(theme.Id)" title="@Loc["theme.duplicate"]">
                            <i class="bi bi-files"></i>
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>

    @if (showEditor && editingTheme != null)
    {
        <div class="theme-editor-overlay" @onclick="CancelEdit">
            <div class="theme-editor" @onclick:stopPropagation="true">
                <h3>@(editingTheme.IsBuiltIn ? Loc["theme.view"] : editingTheme.Id == "new" ? Loc["theme.create"] : Loc["theme.edit"])</h3>

                <div class="su-form-group"><label>@Loc["theme.label_name"]</label><input type="text" class="su-input" @bind="editingTheme.Name" /></div>
                <div class="su-form-group"><label>@Loc["theme.label_description"]</label><input type="text" class="su-input" @bind="editingTheme.Description" /></div>
                <div style="display:flex;gap:16px;margin-bottom:8px">
                    <label style="display:flex;align-items:center;gap:4px"><input type="checkbox" @bind="editingTheme.IsDefault" /> @Loc["theme.is_default"]</label>
                    <label style="display:flex;align-items:center;gap:4px"><input type="checkbox" @bind="editingTheme.IsDarkMode" /> @Loc["theme.dark_mode"]</label>
                </div>

                <h4>@Loc["theme.css.surface"]</h4>
                <div class="color-settings-grid">
                    @ColorField(Loc["theme.css.page_bg"], editingTheme.Surface0, v => editingTheme.Surface0 = v)
                    @ColorField(Loc["theme.css.card_panel"], editingTheme.Surface1, v => editingTheme.Surface1 = v)
                    @ColorField(Loc["theme.css.elevated"], editingTheme.Surface2, v => editingTheme.Surface2 = v)
                    @ColorField(Loc["theme.css.input_alt"], editingTheme.Surface3, v => editingTheme.Surface3 = v)
                </div>

                <h4>@Loc["theme.css.text"]</h4>
                <div class="color-settings-grid">
                    @ColorField(Loc["theme.css.primary"], editingTheme.Text0, v => editingTheme.Text0 = v)
                    @ColorField(Loc["theme.css.secondary"], editingTheme.Text1, v => editingTheme.Text1 = v)
                    @ColorField(Loc["theme.css.tertiary"], editingTheme.Text2, v => editingTheme.Text2 = v)
                </div>

                <h4>@Loc["theme.css.border"]</h4>
                <div class="color-settings-grid">
                    @ColorField(Loc["theme.css.primary"], editingTheme.Border0, v => editingTheme.Border0 = v)
                    @ColorField(Loc["theme.css.subtle"], editingTheme.Border1, v => editingTheme.Border1 = v)
                </div>

                <h4>@Loc["theme.css.accent"]</h4>
                <div class="color-settings-grid">
                    @ColorField(Loc["theme.css.base"], editingTheme.Accent, v => editingTheme.Accent = v)
                    @ColorField(Loc["theme.css.hover"], editingTheme.AccentHover, v => editingTheme.AccentHover = v)
                    @ColorField(Loc["theme.css.soft_bg"], editingTheme.AccentSoft, v => editingTheme.AccentSoft = v)
                </div>

                <h4>@Loc["theme.css.semantic"]</h4>
                <div class="color-settings-grid">
                    @ColorField(Loc["theme.css.success"], editingTheme.Success, v => editingTheme.Success = v)
                    @ColorField(Loc["theme.css.success_bg"], editingTheme.SuccessSoft, v => editingTheme.SuccessSoft = v)
                    @ColorField(Loc["theme.css.warning"], editingTheme.Warning, v => editingTheme.Warning = v)
                    @ColorField(Loc["theme.css.warning_bg"], editingTheme.WarningSoft, v => editingTheme.WarningSoft = v)
                    @ColorField(Loc["theme.css.danger"], editingTheme.Danger, v => editingTheme.Danger = v)
                    @ColorField(Loc["theme.css.danger_bg"], editingTheme.DangerSoft, v => editingTheme.DangerSoft = v)
                    @ColorField(Loc["theme.css.info"], editingTheme.Info, v => editingTheme.Info = v)
                    @ColorField(Loc["theme.css.info_bg"], editingTheme.InfoSoft, v => editingTheme.InfoSoft = v)
                </div>

                <h4>@Loc["theme.css.node_colors"]</h4>
                <div class="color-settings-grid">
                    @ColorField(Loc["theme.css.flow"], editingTheme.NodeFlow, v => editingTheme.NodeFlow = v)
                    @ColorField(Loc["theme.css.branch"], editingTheme.NodeBranch, v => editingTheme.NodeBranch = v)
                    @ColorField(Loc["theme.css.link"], editingTheme.NodeLink, v => editingTheme.NodeLink = v)
                    @ColorField(Loc["theme.css.fragment"], editingTheme.NodeFragment, v => editingTheme.NodeFragment = v)
                    @ColorField(Loc["theme.css.prompt"], editingTheme.NodePrompt, v => editingTheme.NodePrompt = v)
                    @ColorField(Loc["theme.css.tool"], editingTheme.NodeTool, v => editingTheme.NodeTool = v)
                    @ColorField(Loc["theme.css.memory"], editingTheme.NodeMemory, v => editingTheme.NodeMemory = v)
                    @ColorField(Loc["theme.css.config"], editingTheme.NodeConfig, v => editingTheme.NodeConfig = v)
                    @ColorField(Loc["theme.css.subagent"], editingTheme.NodeSubagent, v => editingTheme.NodeSubagent = v)
                    @ColorField(Loc["theme.css.debug"], editingTheme.NodeDebug, v => editingTheme.NodeDebug = v)
                </div>

                <h4>@Loc["theme.css.shadows_radii_spacing"]</h4>
                <div class="su-form-group"><label>@Loc["theme.css.shadow_sm"]:</label><input type="text" class="su-input" @bind="editingTheme.ShadowSm" /></div>
                <div class="su-form-group"><label>@Loc["theme.css.shadow_md"]:</label><input type="text" class="su-input" @bind="editingTheme.ShadowMd" /></div>
                <div class="su-form-group"><label>@Loc["theme.css.shadow_lg"]:</label><input type="text" class="su-input" @bind="editingTheme.ShadowLg" /></div>
                <div class="su-form-group"><label>@Loc["theme.css.radius_sm"]:</label><input type="text" class="su-input" @bind="editingTheme.RadiusSm" /></div>
                <div class="su-form-group"><label>@Loc["theme.css.radius_md"]:</label><input type="text" class="su-input" @bind="editingTheme.RadiusMd" /></div>
                <div class="su-form-group"><label>@Loc["theme.css.radius_lg"]:</label><input type="text" class="su-input" @bind="editingTheme.RadiusLg" /></div>
                <div style="display:flex;gap:8px">
                    <div class="su-form-group"><label>@Loc["theme.css.space_1"]:</label><input type="text" class="su-input" @bind="editingTheme.Space1" /></div>
                    <div class="su-form-group"><label>@Loc["theme.css.space_2"]:</label><input type="text" class="su-input" @bind="editingTheme.Space2" /></div>
                    <div class="su-form-group"><label>@Loc["theme.css.space_4"]:</label><input type="text" class="su-input" @bind="editingTheme.Space4" /></div>
                    <div class="su-form-group"><label>@Loc["theme.css.space_6"]:</label><input type="text" class="su-input" @bind="editingTheme.Space6" /></div>
                    <div class="su-form-group"><label>@Loc["theme.css.space_10"]:</label><input type="text" class="su-input" @bind="editingTheme.Space10" /></div>
                </div>

                <h4>@Loc["theme.css.typography"]</h4>
                <div class="su-form-group"><label>@Loc["theme.css.font_sans"]:</label><input type="text" class="su-input" @bind="editingTheme.FontSans" /></div>
                <div class="su-form-group"><label>@Loc["theme.css.font_mono"]:</label><input type="text" class="su-input" @bind="editingTheme.FontMono" /></div>
                <div style="display:flex;gap:8px">
                    <div class="su-form-group"><label>@Loc["theme.css.font_xs"]:</label><input type="text" class="su-input" @bind="editingTheme.FontXs" /></div>
                    <div class="su-form-group"><label>@Loc["theme.css.font_sm"]:</label><input type="text" class="su-input" @bind="editingTheme.FontSm" /></div>
                    <div class="su-form-group"><label>@Loc["theme.css.font_base"]:</label><input type="text" class="su-input" @bind="editingTheme.FontBase" /></div>
                    <div class="su-form-group"><label>@Loc["theme.css.font_md"]:</label><input type="text" class="su-input" @bind="editingTheme.FontMd" /></div>
                    <div class="su-form-group"><label>@Loc["theme.css.font_lg"]:</label><input type="text" class="su-input" @bind="editingTheme.FontLg" /></div>
                </div>

                <h4>@Loc["theme.css.custom_css"]</h4>
                <div class="form-group">
                    <textarea class="su-input custom-css" @bind="editingTheme.CustomCss" placeholder="@Loc["theme.custom_css_placeholder"]"></textarea>
                </div>

                <div class="editor-actions">
                    <button class="su-btn su-btn-primary" @onclick="SaveTheme">@Loc["Save"]</button>
                    <button class="su-btn su-btn-secondary" @onclick="CancelEdit">@Loc["Cancel"]</button>
                    @if (editingTheme.Id != "new" && !editingTheme.IsBuiltIn)
                    {
                        <button class="su-btn su-btn-danger" @onclick="DeleteCurrentTheme">@Loc["Delete"]</button>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Theme> themes = [];
    private bool showEditor;
    private Theme? editingTheme;
    private string? selectedTheme;

    protected override void OnInitialized()
    {
        LoadThemes();
        ThemeService.OnThemeChanged += _ => InvokeAsync(StateHasChanged);
    }

    private void LoadThemes() => themes = ThemeService.AvailableThemes.ToList();

    private void SelectTheme(string id) { ThemeService.SetTheme(id); selectedTheme = id; LoadThemes(); }

    private void CreateNewTheme()
    {
        editingTheme = new Theme { Id = "new", Name = Loc["theme.default_name"], IsBuiltIn = false };
        showEditor = true;
    }

    private void EditTheme(string id)
    {
        var t = themes.FirstOrDefault(x => x.Id == id);
        if (t?.IsBuiltIn == false) { editingTheme = t.Clone(); showEditor = true; }
    }

    private void SaveTheme()
    {
        if (editingTheme == null) return;
        if (editingTheme.Id == "new") { editingTheme.Id = Guid.NewGuid().ToString(); ThemeService.CreateTheme(editingTheme); }
        else ThemeService.UpdateTheme(editingTheme);
        SelectTheme(editingTheme.Id);
        showEditor = false; editingTheme = null;
    }

    private void CancelEdit() { showEditor = false; editingTheme = null; }

    private async Task DeleteTheme(string id)
    {
        var t = themes.FirstOrDefault(x => x.Id == id);
        if (t is { IsBuiltIn: false, IsDefault: false } && await JSRuntime.InvokeAsync<bool>("confirm", Loc.Format("theme.delete_confirm", t.Name)))
        { ThemeService.DeleteTheme(id); LoadThemes(); }
    }

    private async Task DeleteCurrentTheme()
    {
        if (editingTheme is { IsBuiltIn: false, IsDefault: false } && await JSRuntime.InvokeAsync<bool>("confirm", Loc.Format("theme.delete_confirm", editingTheme.Name)))
        { ThemeService.DeleteTheme(editingTheme.Id); LoadThemes(); showEditor = false; editingTheme = null; }
    }

    private RenderFragment ColorField(string label, string value, Action<string> setter) => builder =>
    {
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "su-form-group");
        builder.OpenElement(2, "label");
        builder.AddContent(3, label + ":");
        builder.CloseElement();
        builder.OpenElement(4, "input");
        builder.AddAttribute(5, "type", "color");
        builder.AddAttribute(6, "class", "su-input color-picker");
        builder.AddAttribute(7, "value", value);
        builder.AddAttribute(8, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, e => { var v = e.Value?.ToString(); if (v != null) { setter(v); StateHasChanged(); } }));
        builder.CloseElement();
        builder.OpenElement(9, "input");
        builder.AddAttribute(10, "type", "text");
        builder.AddAttribute(11, "class", "su-input");
        builder.AddAttribute(12, "value", value);
        builder.AddAttribute(13, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, e => { var v = e.Value?.ToString(); if (v != null) { setter(v); StateHasChanged(); } }));
        builder.CloseElement();
        builder.CloseElement();
    };

    private void DuplicateTheme(string id)
    {
        var t = themes.FirstOrDefault(x => x.Id == id); if (t == null) return;
        var copy = t.Clone(); copy.Id = Guid.NewGuid().ToString(); copy.Name = Loc.Format("theme.copy_suffix", t.Name);
        copy.IsDefault = false; copy.IsBuiltIn = false;
        ThemeService.CreateTheme(copy); LoadThemes();
    }

    private async Task OnImportFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null || (!file.Name.EndsWith(".json", StringComparison.OrdinalIgnoreCase) && file.ContentType != "application/json"))
        { await JSRuntime.InvokeVoidAsync("alert", Loc["theme.alert_select_json"]); return; }
        if (file.Size > 1024 * 1024) { await JSRuntime.InvokeVoidAsync("alert", Loc["theme.alert_file_too_large"]); return; }
        try
        {
            using var stream = file.OpenReadStream(1024 * 1024);
            using var reader = new StreamReader(stream);
            ThemeService.ImportTheme(await reader.ReadToEndAsync());
            LoadThemes(); await JSRuntime.InvokeVoidAsync("alert", Loc.Format("theme.alert_imported", file.Name));
        }
        catch (Exception ex) { await JSRuntime.InvokeVoidAsync("alert", Loc.Format("theme.alert_import_failed", ex.Message)); }
    }

    private async Task ExportCurrentTheme()
    {
        if (selectedTheme == null) return;
        var json = ThemeService.ExportTheme(selectedTheme);
        var bytes = System.Text.Encoding.UTF8.GetBytes(json);
        using var ms = new MemoryStream(bytes);
        using var streamRef = new DotNetStreamReference(ms);
        await JSRuntime.InvokeVoidAsync("downloadFileFromStream", "theme.json", streamRef);
    }

    public void Dispose() => ThemeService.OnThemeChanged -= _ => InvokeAsync(StateHasChanged);
}
