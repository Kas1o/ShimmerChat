@using ShimmerChat.Singletons
@using ShimmerChatLib.Context

<div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1050;">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">添加上下文修改器</h5>
                <button type="button" class="btn-close" @onclick="Cancel"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="modifier-select" class="form-label">选择上下文修改器</label>
                    <select id="modifier-select" @bind="_selectedModifierName" class="form-select">
                        <option value="">请选择...</option>
                        @foreach (var modifier in _contextModifierService.LoadedModifiers)
                        {
                            <option value="@modifier.info.Name">@modifier.info.Name - @modifier.info.Description</option>
                        }
                    </select>
                </div>

                @if (_selectedModifier != null)
                {
                    <div class="mb-3">
                        <label class="form-label">配置</label>
                    <ConfigEditor @ref="_configEditor"
                                  Config="_currentConfig"
                                  Modifier="_selectedModifier"
                                  OnConfigChanged="OnConfigChanged"
                                  OnErrorsChanged="OnErrorsChanged" />
                    </div>

                    @if (!_isValid)
                    {
                        <small class="text-danger">@_errorMessage</small>
                    }
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="Cancel">取消</button>
                <button type="button" class="btn btn-primary" @onclick="Confirm"
                        disabled="@(string.IsNullOrEmpty(_selectedModifierName) || !_isValid)">
                    添加
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Inject] private IContextModifierService _contextModifierService { get; set; } = null!;

    [Parameter]
    public EventCallback<object> OnConfirm { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private string? _selectedModifierName;
    private IContextModifier? _selectedModifier;
    private ModifierConfig _currentConfig = new LegacyModifierConfig { Value = "" };
    private ConfigEditor? _configEditor;
    private bool _isValid = true;
    private string _errorMessage = "";

    protected override void OnParametersSet()
    {
        _selectedModifier = _contextModifierService.LoadedModifiers
            .FirstOrDefault(m => m.info.Name == _selectedModifierName);

        if (_selectedModifier != null && _currentConfig.GetType() != _selectedModifier.ConfigType)
        {
            _currentConfig = (ModifierConfig)Activator.CreateInstance(_selectedModifier.ConfigType)!;
        }
    }

    private async Task OnConfigChanged(ModifierConfig config)
    {
        _currentConfig = config;
        await Task.CompletedTask;
    }

    private void OnErrorsChanged(Dictionary<string, string> errors)
    {
        _isValid = errors.Count == 0;
        _errorMessage = string.Join("; ", errors.Values);
    }

    private async Task Confirm()
    {
        if (!string.IsNullOrEmpty(_selectedModifierName))
        {
            var result = new { ModifierName = _selectedModifierName, Config = _currentConfig };
            await OnConfirm.InvokeAsync(result);
            await OnClose.InvokeAsync();
        }
    }

    private async Task Cancel()
    {
        await OnClose.InvokeAsync();
    }
}
