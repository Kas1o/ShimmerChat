@using ShimmerChat.Singletons
@using ShimmerChatLib.Interface

<div class="su-modal-mask" @onclick="Cancel">
    <div class="su-modal" @onclick:stopPropagation="true">
        <div class="su-modal-header">
            添加消息渲染修改器
            <button class="su-btn-close" @onclick="Cancel">&times;</button>
        </div>
        <div class="su-modal-body">
            <div class="su-mb-3">
                <label for="modifier-select" class="su-label">选择修改器</label>
                <select id="modifier-select" @bind="_selectedModifierName" class="su-select">
                    <option value="">请选择...</option>
                    @foreach (var modifier in _messageDisplayService.LoadedModifiers)
                    {
                        <option value="@modifier.Info.Name">@modifier.Info.Name - @modifier.Info.Description</option>
                    }
                </select>
            </div>
            
            <div class="su-mb-3">
                <label for="modifier-input" class="su-label">输入值 (可选配置)</label>
                <textarea id="modifier-input" @bind="_modifierInput" class="su-input" rows="3" placeholder="输入配置值..."></textarea>
            </div>
        </div>
        <div class="su-modal-footer">
            <button class="su-btn su-btn-secondary" @onclick="Cancel">取消</button>
            <button class="su-btn su-btn-primary" @onclick="Confirm" disabled="@string.IsNullOrEmpty(_selectedModifierName)">添加</button>
        </div>
    </div>
</div>

@code {
    [Inject] private IMessageDisplayService _messageDisplayService { get; set; } = null!;
    
    [Parameter]
    public EventCallback<object> OnConfirm { get; set; }
    
    [Parameter]
    public EventCallback OnClose { get; set; }
    
    private string? _selectedModifierName;
    private string _modifierInput = string.Empty;
    
    private async Task Confirm()
    {
        if (!string.IsNullOrEmpty(_selectedModifierName))
        {
            var result = new { ModifierName = _selectedModifierName, InputValue = _modifierInput };
            await OnConfirm.InvokeAsync(result);
            await OnClose.InvokeAsync();
        }
    }
    
    private async Task Cancel()
    {
        await OnClose.InvokeAsync();
    }
}