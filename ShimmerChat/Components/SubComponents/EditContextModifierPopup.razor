@using ShimmerChat.Singletons
@using ShimmerChatLib.Context

<div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1050;">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">编辑上下文修改器</h5>
                <button type="button" class="btn-close" @onclick="Cancel"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <strong>@_modifierName</strong>
                    @if (_modifier != null)
                    {
                        <small class="d-block text-muted">@_modifier.info.Description</small>
                    }
                </div>

                @if (_modifier != null)
                {
                    <div class="mb-3">
                        <label class="form-label">配置</label>
                        <ConfigEditor @ref="_configEditor"
                                      Config="_currentConfig"
                                      Modifier="_modifier"
                                      OnConfigChanged="OnConfigChanged"
                                      OnErrorsChanged="OnErrorsChanged" />
                    </div>

                    @if (!_isValid)
                    {
                        <small class="text-danger">@_errorMessage</small>
                    }
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="Cancel">取消</button>
                <button type="button" class="btn btn-success" @onclick="Confirm" disabled="@(!_isValid)">更新</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Inject] private IContextModifierService _contextModifierService { get; set; } = null!;

    [Parameter]
    public EventCallback<object> OnConfirm { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public string? ModifierName { get; set; }

    [Parameter]
    public ModifierConfig? Config { get; set; }

    private string? _modifierName;
    private IContextModifier? _modifier;
    private ModifierConfig _currentConfig = new LegacyModifierConfig { Value = "" };
    private ConfigEditor? _configEditor;
    private bool _isValid = true;
    private string _errorMessage = "";

    protected override void OnParametersSet()
    {
        _modifierName = ModifierName;

        _modifier = _contextModifierService.LoadedModifiers
            .FirstOrDefault(m => m.info.Name == _modifierName);

        _currentConfig = Config ?? new LegacyModifierConfig { Value = "" };

        if (_modifier != null
            && _modifier.ConfigType != typeof(LegacyModifierConfig)
            && _currentConfig.GetType() != _modifier.ConfigType)
        {
            _currentConfig = (ModifierConfig)Activator.CreateInstance(_modifier.ConfigType)!;
        }
    }

    private async Task OnConfigChanged(ModifierConfig config)
    {
        _currentConfig = config;
        await Task.CompletedTask;
    }

    private void OnErrorsChanged(Dictionary<string, string> errors)
    {
        _isValid = errors.Count == 0;
        _errorMessage = string.Join("; ", errors.Values);
    }

    private async Task Confirm()
    {
        if (!string.IsNullOrEmpty(_modifierName))
        {
            var result = new { ModifierName = _modifierName, Config = _currentConfig };
            await OnConfirm.InvokeAsync(result);
            await OnClose.InvokeAsync();
        }
    }

    private async Task Cancel()
    {
        await OnClose.InvokeAsync();
    }
}
