@using ShimmerChat.Singletons
@using ShimmerChatLib.Interface
@inject ILocService Loc

<div class="su-modal-mask" @onclick="Cancel">
    <div class="su-modal" @onclick:stopPropagation="true">
        <div class="su-modal-header">
            @Loc["sub.edit_modifier_title"]
            <button class="su-btn-close" @onclick="Cancel">&times;</button>
        </div>
        <div class="su-modal-body">
            <div class="su-mb-3">
                <label for="modifier-name" class="su-label">@Loc["sub.modifier_name"]</label>
                <input id="modifier-name" type="text" class="su-input" value="@_modifierName" readonly />
            </div>
            
            <div class="su-mb-3">
                <label for="modifier-input" class="su-label">@Loc["sub.config_value"]</label>
                <textarea id="modifier-input" @bind="_modifierInput" class="su-input" rows="3" placeholder="@Loc["sub.config_value_placeholder"]">@_modifierInput</textarea>
            </div>
        </div>
        <div class="su-modal-footer">
            <button class="su-btn su-btn-secondary" @onclick="Cancel">@Loc["Cancel"]</button>
            <button class="su-btn su-btn-success" @onclick="Confirm">@Loc["sub.update"]</button>
        </div>
    </div>
</div>

@code {
    [Inject] private IMessageDisplayService _messageDisplayService { get; set; } = null!;
    
    [Parameter]
    public EventCallback<object> OnConfirm { get; set; }
    
    [Parameter]
    public EventCallback OnClose { get; set; }
    
    [Parameter]
    public string? ModifierName { get; set; }
    
    [Parameter]
    public string ModifierValue { get; set; } = string.Empty;
    
    private string? _modifierName;
    private string _modifierInput = string.Empty;
    
    protected override void OnParametersSet()
    {
        _modifierName = ModifierName;
        _modifierInput = ModifierValue;
    }
    
    private async Task Confirm()
    {
        if (!string.IsNullOrEmpty(_modifierName))
        {
            var result = new { ModifierName = _modifierName, InputValue = _modifierInput };
            await OnConfirm.InvokeAsync(result);
            await OnClose.InvokeAsync();
        }
    }
    
    private async Task Cancel()
    {
        await OnClose.InvokeAsync();
    }
}