@using Newtonsoft.Json.Linq

<div class="json-tree-node su-ms-2">
    @if (Token is JObject jObject)
    {
        <div class="su-flex su-items-center">
            <span class="su-text-1 su-me-2"
                  style="width: 20px; cursor: pointer;"
                  @onclick="ToggleExpand">
                @if (_isExpanded)
                {
                    <small>▼</small>
                }
                else
                {

                    <small>▶</small>
                }
            </span>
            <span class="su-text-2 su-text-xs su-me-2">Object</span>
            @if (!_isExpanded)
            {
                <span class="su-text-2 su-text-xs su-font-italic">{ @jObject.Count properties }</span>
            }
        </div>

        @if (_isExpanded)
        {
            <div class="su-border-start su-ps-3 su-mt-1">
                @foreach (var property in jObject.Properties())
                {
                    <div class="su-mb-1">
                        <span class="su-font-bold su-text-accent su-select-none">@property.Name</span>:
                        <JsonTreeView Token="property.Value"
                                      CurrentLevel="@(CurrentLevel + 1)"
                                      DefaultExpandLevel="DefaultExpandLevel" />
                    </div>
                }
            </div>
        }
    }
    else if (Token is JArray jArray)
    {
        <div class="su-flex su-items-center">
            <span class="su-text-1 su-me-2"
                  style="width: 20px; cursor: pointer;"
                  @onclick="ToggleExpand">
                @if (_isExpanded)
                {
                    <small>▼</small>
                }
                else
                {

                    <small>▶</small>
                }
            </span>
            <span class="su-text-2 su-text-xs su-me-2">Array[@jArray.Count]</span>
            @if (!_isExpanded)
            {
                <span class="su-text-2 su-text-xs su-font-italic">[ ... ]</span>
            }
        </div>

        @if (_isExpanded)
        {
            <div class="su-border-start su-ps-3 su-mt-1">
                @for (int i = 0; i < jArray.Count; i++)
                {
                    <div class="su-mb-1">
                        <span class="su-text-2 su-text-xs su-select-none">[@i]</span>:
                        <JsonTreeView Token="jArray[i]"
                                      CurrentLevel="@(CurrentLevel + 1)"
                                      DefaultExpandLevel="DefaultExpandLevel" />
                    </div>
                }
            </div>
        }
    }
    else if (Token is JValue jValue)
    {
        <span class="json-value @GetTypeClass(jValue)">
            @GetValueString(jValue)
        </span>
    }
    else
    {
        <span class="su-text-2">Unknown Type</span>
    }
</div>

@code
{
    [Parameter] public JToken Token { get; set; }
    [Parameter] public int CurrentLevel { get; set; } = 0;
    [Parameter] public int DefaultExpandLevel { get; set; } = 2;

    private bool _isExpanded;

    protected override void OnInitialized()
    {
        _isExpanded = CurrentLevel < DefaultExpandLevel;
    }

    private void ToggleExpand()
    {
        _isExpanded = !_isExpanded;
        StateHasChanged();
    }

    private string GetTypeClass(JValue value)
    {
        return value.Type switch
        {
            JTokenType.String => "su-text-success su-font-mono",
            JTokenType.Integer or JTokenType.Float => "su-text-accent su-font-mono",
            JTokenType.Boolean => "su-text-danger su-font-mono",
            JTokenType.Null or JTokenType.Undefined => "su-text-2 su-font-mono",
            _ => "su-text-0 su-font-mono"
        };
    }

    private string GetValueString(JValue value)
    {
        return value.Type switch
        {
            JTokenType.String => $""""{value.Value<string>()}"""",
            JTokenType.Integer => value.Value<long>().ToString(),
            JTokenType.Float => value.Value<double>().ToString(),
            JTokenType.Boolean => value.Value<bool>().ToString().ToLower(),
            JTokenType.Null => "null",
            JTokenType.Undefined => "undefined",
            _ => value.ToString()
        };
    }
}