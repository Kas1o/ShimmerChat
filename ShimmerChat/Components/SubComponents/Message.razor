@using Markdig
@using Markdig.Extensions.Tables
@using ShimmerChatLib
@using SharperLLM.Util

@inject ILocService Loc
@inject IJSRuntime JS
@inject IMessageDisplayService MessageDisplayService
@inject IKVDataService KVData
@inject IMessageStoreService messageStore

<div class="chat-msg @MsgClass">
	<div class="chat-msg-head">
		<span class="chat-msg-sender">
			@sender
			@if (message.HasMultipleVersions)
			{
				<span class="chat-msg-ver">@(message.CurrentVersionIndex + 1)/@message.Versions.Count</span>
				<button class="chat-msg-ver-btn" @onclick="() => NavigateToPreviousVersion()" disabled="@(message.CurrentVersionIndex <= 0)">◂</button>
				<button class="chat-msg-ver-btn" @onclick="() => NavigateToNextVersion()" disabled="@(message.CurrentVersionIndex >= message.Versions.Count - 1)">▸</button>
			}
			@if (message.IsStreaming)
			{
				<span class="chat-msg-streaming">streaming…</span>
			}
		</span>
		<span class="chat-msg-actions">
			@if (message.sender == ShimmerChatLib.Sender.AI && !message.IsStreaming)
			{
				<button class="chat-msg-act" @onclick="RegenerateFromThisMessage">@Loc["BUTTON_REGENERATE"]</button>
				if (IsContinuationEnabled())
				{
					<button class="chat-msg-act" @onclick="ContinueFromThisMessage">@Loc["BUTTON_CONTINUE"]</button>
				}
			}
			<button class="chat-msg-act" @onclick="CopyContentToClipboard">@Loc["BUTTON_COPY"]</button>
			@if (!message.IsStreaming)
			{
				<button class="chat-msg-act" @onclick="EnterEditMode">@Loc["BUTTON_EDIT"]</button>
			}
			<button class="chat-msg-act chat-msg-act-del" @onclick="OnDeleteClick" title="@Loc["BUTTON_DELETE_FROM_TIP"]">@Loc["BUTTON_DELETE"]</button>
		</span>
	</div>

	@if (isEditMode)
	{
		<div class="chat-msg-edit">
			<label>Thinking:</label>
			<textarea @bind="editThinking" rows="3" class="su-input su-mb-2"></textarea>
			<label>Content:</label>
			<textarea @bind="editContent" rows="4" class="su-input su-mb-2"></textarea>
			<button class="su-btn su-btn-success su-btn-sm" @onclick="SaveEdit">@Loc["BUTTON_SAVE"]</button>
			<button class="su-btn su-btn-sm" @onclick="CancelEdit">@Loc["BUTTON_CANCEL"]</button>
		</div>
	}
	else
	{
		@if (!string.IsNullOrEmpty(CurrentMessageContent?.thinking))
		{
			<details class="chat-msg-thinking" open="@(!_thinkingCollapsed)">
				<summary>Thinking…</summary>
				<div class="chat-msg-thinking-body">@DisplayThinking</div>
			</details>
		}

		@if (message.sender == ShimmerChatLib.Sender.ToolResult)
		{
			<details class="chat-msg-tool-result" open="@(!_toolResultCollapsed)">
				<summary class="chat-msg-tool-summary">@Loc["ToolResult"]</summary>
				<div class="chat-msg-body">
					@DisplayContent
				</div>
			</details>
		}
		else
		{
			<div class="chat-msg-body">
				@DisplayContent
				@if (message.IsStreaming)
				{
					<span class="chat-msg-cursor">▌</span>
				}
			</div>
		}
	}

	@if (CurrentMessageContent?.toolCalls is { Count: > 0 })
	{
		<ToolCallMessage message="message" />
	}
</div>

@code {
	string MsgClass => message.sender switch
	{
		ShimmerChatLib.Sender.User => "chat-msg-user",
		ShimmerChatLib.Sender.ToolResult => "chat-msg-tool",
		_ => "chat-msg-ai"
	};

	[Parameter] public Action Delete { get; set; } = null;
	[Parameter] public Action MakeDirty { get; set; } = null!;
	[Parameter] public Action RegenerateFrom { get; set; } = null!;
	[Parameter] public Action ContinueFrom { get; set; } = null!;
	[Parameter] public Action DeleteFrom { get; set; } = null!;
	[Parameter] public ShimmerChatLib.Message message { get; set; } = null!;
	[Parameter] public string AgentName { get; set; } = "EmptyName";
	[Parameter] public Chat? Chat { get; set; }
	[Parameter] public Agent? Agent { get; set; }

	bool isEditMode = false;
	string editContent = string.Empty;
	string editThinking = string.Empty;

	ChatMessage CurrentMessageContent => message.CurrentVersion;
	string stringContent => CurrentMessageContent?.Content ?? string.Empty;
	MarkupString DisplayContent => MessageDisplayService.Render(stringContent, Chat, Agent);
	MarkupString DisplayThinking => MessageDisplayService.Render(CurrentMessageContent?.thinking ?? string.Empty, Chat, Agent);
	string imageContent => CurrentMessageContent?.ImageBase64 ?? string.Empty;

	string sender => message.sender switch
	{
		ShimmerChatLib.Sender.User => KVData.Read("User", "username") ?? "User",
		ShimmerChatLib.Sender.AI => AgentName,
		ShimmerChatLib.Sender.ToolResult => Loc["ToolResult"],
		var other => other
	};

	protected override void OnInitialized() { base.OnInitialized(); SubscribeToMessageEvents(); }
	protected override void OnParametersSet() { base.OnParametersSet(); SubscribeToMessageEvents(); }

	private void SubscribeToMessageEvents()
	{
		message.ContentChanged -= HandleContentChanged;
		message.StreamingStateChanged -= HandleStreamingStateChanged;
		message.VersionChanged -= HandleVersionChanged;
		message.ContentChanged += HandleContentChanged;
		message.StreamingStateChanged += HandleStreamingStateChanged;
		message.VersionChanged += HandleVersionChanged;
	}

	private void HandleContentChanged(object? sender, EventArgs e) => InvokeAsync(StateHasChanged);
	private void HandleStreamingStateChanged(object? sender, EventArgs e) => InvokeAsync(StateHasChanged);
	private void HandleVersionChanged(object? sender, EventArgs e) => InvokeAsync(StateHasChanged);

	public void Dispose()
	{
		if (message != null)
		{
			message.ContentChanged -= HandleContentChanged;
			message.StreamingStateChanged -= HandleStreamingStateChanged;
			message.VersionChanged -= HandleVersionChanged;
		}
	}

	private void NavigateToPreviousVersion() { if (message.CurrentVersionIndex > 0) { message.CurrentVersionIndex--; MakeDirty?.Invoke(); } }
	private void NavigateToNextVersion() { if (message.CurrentVersionIndex < message.Versions.Count - 1) { message.CurrentVersionIndex++; MakeDirty?.Invoke(); } }

	void DeleteThisMessage() => Delete();
	void OnDeleteClick(MouseEventArgs e) { if (e.ShiftKey) DeleteFrom(); else Delete(); }
	void RegenerateFromThisMessage() => RegenerateFrom?.Invoke();
	void ContinueFromThisMessage() => ContinueFrom?.Invoke();

	bool IsContinuationEnabled()
	{
		var value = KVData.Read("MiscSettings", "enableContinue") ?? "false";
		return bool.TryParse(value, out var enabled) && enabled;
	}

	private bool _thinkingCollapsed
	{
		get
		{
			var value = KVData.Read("App", "thinking_collapsed") ?? "true";
			return !bool.TryParse(value, out var b) || b;
		}
	}

	private bool _toolResultCollapsed
	{
		get
		{
			var value = KVData.Read("App", "toolresult_collapsed") ?? "true";
			return !bool.TryParse(value, out var b) || b;
		}
	}

	async Task CopyContentToClipboard() => await JS.InvokeVoidAsync("copyTextToClipboard", stringContent);

	void EnterEditMode()
	{
		if (isEditMode || message.IsStreaming) { CancelEdit(); return; }
		isEditMode = true; editContent = stringContent; editThinking = CurrentMessageContent?.thinking ?? string.Empty;
	}

	void SaveEdit()
	{
		if (CurrentMessageContent != null) { CurrentMessageContent.Content = editContent; CurrentMessageContent.thinking = editThinking; }
		isEditMode = false; Chat?.SaveMessage(messageStore, message); MakeDirty?.Invoke();
	}

	void CancelEdit() => isEditMode = false;
}
