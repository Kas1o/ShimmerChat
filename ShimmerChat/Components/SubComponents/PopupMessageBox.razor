@using ShimmerChatLib.Models
@implements IDisposable


@if (_options != null)
{
    <div class="su-modal-mask" @onclick="Cancel">
        <div class="su-modal" @onclick:stopPropagation="true">
            <div class="su-modal-header">
                @_options.Title
                <button class="su-btn-close" @onclick="Cancel">&times;</button>
            </div>
            <div class="su-modal-body">
                @_options.Message
            </div>
            <div class="su-modal-footer">
                @if (_options.ShowCancel)
                {
                    <button class="su-btn su-btn-secondary" @onclick="Cancel">@_options.CancelText</button>
                }
                <button class="su-btn su-btn-primary" @onclick="Confirm">@_options.ConfirmText</button>
            </div>
        </div>
    </div>

}

@code {
    [Inject] private IPopupService? PopupService { get; set; }

    private PopupOptions? _options;

    private Action<PopupOptions?>? _onShowHandler;
    private Action? _onHideHandler;

    protected override void OnInitialized()
    {
        if (PopupService != null)
        {
            _onShowHandler = options => InvokeAsync(() =>
            {
                _options = options;
                StateHasChanged();
            });

            _onHideHandler = () => InvokeAsync(() =>
            {
                _options = null;
                StateHasChanged();
            });

            PopupService.OnShow += _onShowHandler;
            PopupService.OnHide += _onHideHandler;
        }
    }

    public void Dispose()
    {
        if (PopupService != null)
        {
            if (_onShowHandler != null) PopupService.OnShow -= _onShowHandler;
            if (_onHideHandler != null) PopupService.OnHide -= _onHideHandler;
        }
    }

    private void Confirm() => PopupService?.Confirm();
    private void Cancel() => PopupService?.Cancel();
}