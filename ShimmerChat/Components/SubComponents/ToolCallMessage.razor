@using Newtonsoft.Json.Linq
@inject IKVDataService KVData

<div class="toolcalls">
    @foreach (var tc in message?.message?.toolCalls ?? [])
    {
        <details class="tc-item" open="@(!_toolCallCollapsed)">
            <summary class="tc-summary">
                <span class="tc-badge">@tc.name</span>
            </summary>
            @if (!string.IsNullOrEmpty(tc.arguments))
            {
                <div class="tc-args">
                    <JsonTreeView Token="ParseArgs(tc.arguments)" DefaultExpandLevel="1" />
                </div>
            }
        </details>
    }
</div>

@code {
    [Parameter] public ShimmerChatLib.Message message { get; set; } = null!;

    private bool _toolCallCollapsed
    {
        get
        {
            var value = KVData.Read("App", "toolcall_collapsed") ?? "true";
            return !bool.TryParse(value, out var b) || b;
        }
    }

    private static JToken ParseArgs(string args)
    {
        try { return JToken.Parse(args); }
        catch { return JValue.CreateString(args); }
    }
}
