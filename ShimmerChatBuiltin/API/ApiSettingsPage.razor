@using ShimmerChatLib;
@using ShimmerChatLib.Panel
@attribute [PluginPanelAttribute("panel.api_settings", "panel.api_settings.desc", PanelDisplayPlace.Settings, Order = 1)]
@inject NavigationManager Navigation
@inject ILocService Loc

<h3>@Loc["Api Settings"]</h3>
<h4>@Loc["ApiConfigs Profile:"]</h4>
<select @bind="_selectedIndex" class="su-select">
    @for (int i = 0; i < apiSettings.Count; i++)
    {
        <option value="@i">@apiSettings[i].Name</option>
    }
</select>
<button class="su-btn su-btn-primary" style="margin:5px" @onclick="CreateNewApiConfig">@Loc["Create New Api Setting Profile"]</button>
<button class="su-btn su-btn-secondary" style="margin:5px" @onclick="CloneCurrentApiConfig">@Loc["Clone Current Api Setting Profile"]</button>

@if (topAPISetting != null)
{
    <h4>@Loc["Profile Settings:"]</h4>
    <div class="shimmer-group">
        <h5>@Loc["Profile Name:"]</h5>
        <input @bind="topAPISetting.Name" class="shimmer-input" />
        <h5>@Loc["Api Type:"]</h5>
        <select @bind="topAPISetting.Type" class="su-select">
            <option value="@ApiConfigType.Kobold">kobold</option>
            <option value="@ApiConfigType.OpenAI">openai</option>
            <option value="@ApiConfigType.DeepSeek">deepseek</option>
            <option value="@ApiConfigType.Ollama">ollama</option>
            <option value="@ApiConfigType.OpenAIText">openai (text)</option>
            <option value="@ApiConfigType.Pseudo">pseudo</option>
        </select>
        
        @if (topAPISetting.Type == ApiConfigType.Pseudo)
        {
            <div class="su-alert su-alert-info" style="margin-top: 12px; padding: 12px; background-color: #e8f4fd; border: 1px solid #b6d4fe; border-radius: 4px;">
                <strong>@Loc["PseudoAPI Info Title"]</strong><br/>
                @Loc["PseudoAPI Info Description"]
            </div>
        }
        
        @if (topAPISetting.Type == ApiConfigType.OpenAIText)
        {
            <div class="su-alert su-alert-warning" style="margin-top: 12px; padding: 12px; background-color: #fff3cd; border: 1px solid #ffc107; border-radius: 4px;">
                <strong>@Loc["OpenAIText Warning Title"]</strong><br/>
                @Loc["OpenAIText Warning Description"]
            </div>
        }

        <!-- Text Completion Settings (shown for text-based APIs) -->
        @if (topAPISetting.Type == ApiConfigType.Kobold || topAPISetting.Type == ApiConfigType.Ollama || topAPISetting.Type == ApiConfigType.OpenAIText)
        {
            <h5>@Loc["Text Completion Settings:"]</h5>
            <select @bind="topAPISetting.SelectedTextCompletionSettingIndex" class="su-select">
                @for (int i = 0; i < (topAPISetting.TextCompletionSettings?.Count ?? 0); i++)
                {
                    <option value="@i">@(topAPISetting.TextCompletionSettings?[i]?.name ?? "Unnamed")</option>
                }
            </select>
            <button class="su-btn su-btn-primary" style="margin:5px" @onclick="CreateNewTextCompletionSetting">@Loc["Create New Text Completion Setting Profile"]</button>
            
            @if (topAPISetting.TextCompletionSettings != null && topAPISetting.SelectedTextCompletionSettingIndex >= 0 && topAPISetting.SelectedTextCompletionSettingIndex < topAPISetting.TextCompletionSettings.Count)
            {
                var currentTextSetting = topAPISetting.TextCompletionSettings[topAPISetting.SelectedTextCompletionSettingIndex];
                <div class="shimmer-group" style="margin-top:16px;">
                    <h5>@Loc["NAME:"]</h5>
                    <textarea class="su-input" rows="2" @bind="currentTextSetting.name"></textarea>
                    <h5>@Loc["SYSTEM_MESSAGE_TEMPLATE"]</h5>
                    <textarea placeholder="@Loc["TEMPLATE_PLACEHOLDER"]" class="su-input" rows="2" @bind="currentTextSetting.SystemMessageTemplate"></textarea>
                    <h5>@Loc["USER_MESSAGE_TEMPLATE"]</h5>
                    <textarea placeholder="@Loc["TEMPLATE_PLACEHOLDER"]" class="su-input" rows="2" @bind="currentTextSetting.UserMessageTemplate"></textarea>
                    <h5>@Loc["AGENT_MESSAGE_TEMPLATE"]</h5>
                    <textarea placeholder="@Loc["TEMPLATE_PLACEHOLDER"]" class="su-input" rows="2" @bind="currentTextSetting.CharMessageTemplate"></textarea>
                </div>
            }
        }
        
        <h5>@Loc["Configs:"]</h5>
        <div class="shimmer-group">
            @if (topAPISetting.Type == ApiConfigType.Kobold)
            {
                <div class="shimmer-group">
                    <h5>@Loc["Basic Settings"]</h5>
                    <label>@Loc["API URL"]</label>
                    <input class="shimmer-input" @bind="topAPISetting.KoboldUrl" />
                    <label>@Loc["Temperature"]</label>
                    <input type="number" step="0.01" min="0" max="2" class="shimmer-input" @bind="topAPISetting.KoboldConf.temperature" />
                </div>

                <div class="shimmer-group">
                    <h5>@Loc["Context & Length"]</h5>
                    <label>@Loc["Max Context Length"]</label>
                    <input type="number" class="shimmer-input" @bind="topAPISetting.KoboldConf.max_context_length" />
                    <label>@Loc["Max Length"]</label>
                    <input type="number" class="shimmer-input" @bind="topAPISetting.KoboldConf.max_length" />
                </div>

                <div class="shimmer-group">
                    <h5>@Loc["Repetition Penalty"]</h5>
                    <label>@Loc["Repetition Penalty"]</label>
                    <input type="number" step="0.01" min="1" max="2" class="shimmer-input" @bind="topAPISetting.KoboldConf.rep_pen" />
                    <label>@Loc["Repetition Penalty Range"]</label>
                    <input type="number" class="shimmer-input" @bind="topAPISetting.KoboldConf.rep_pen_range" />
                </div>

                <div class="shimmer-group">
                    <h5>@Loc["Sampling Settings"]</h5>
                    <label>@Loc["Sampler Seed"]</label>
                    <input type="number" class="shimmer-input" @bind="topAPISetting.KoboldConf.sampler_seed" />
                    <label>@Loc["Top K"]</label>
                    <input type="number" class="shimmer-input" @bind="topAPISetting.KoboldConf.top_k" />
                    <label>@Loc["Top P"]</label>
                    <input type="number" step="0.01" min="0" max="1" class="shimmer-input" @bind="topAPISetting.KoboldConf.top_p" />
                    <label>@Loc["Top A"]</label>
                    <input type="number" step="0.01" min="0" max="1" class="shimmer-input" @bind="topAPISetting.KoboldConf.top_a" />
                    <label>@Loc["Min P"]</label>
                    <input type="number" step="0.01" min="0" max="1" class="shimmer-input" @bind="topAPISetting.KoboldConf.min_p" />
                    <label>@Loc["Typical"]</label>
                    <input type="number" step="0.01" min="0" max="1" class="shimmer-input" @bind="topAPISetting.KoboldConf.typical" />
                    <label>@Loc["TFS (Tail Free Sampling)"]</label>
                    <input type="number" step="0.01" min="0" max="1" class="shimmer-input" @bind="topAPISetting.KoboldConf.tfs" />
                </div>

                <div class="shimmer-group">
                    <h5>@Loc["Dynamic Temperature"]</h5>
                    <label>@Loc["Dynatemp Range"]</label>
                    <input type="number" step="0.01" min="0" max="1" class="shimmer-input" @bind="topAPISetting.KoboldConf.dynatemp_range" />
                    <label>@Loc["Dynatemp Exponent"]</label>
                    <input type="number" step="0.01" min="0" max="2" class="shimmer-input" @bind="topAPISetting.KoboldConf.dynatemp_exponent" />
                    <label>@Loc["Smoothing Factor"]</label>
                    <input type="number" step="0.01" min="0" max="1" class="shimmer-input" @bind="topAPISetting.KoboldConf.smoothing_factor" />
                </div>

                <div class="shimmer-group">
                    <h5>@Loc["Mirostat"]</h5>
                    <label>@Loc["Mirostat (0=disabled, 1=v1, 2=v2)"]</label>
                    <input type="number" min="0" max="2" class="shimmer-input" @bind="topAPISetting.KoboldConf.mirostat" />
                    <label>@Loc["Mirostat Tau"]</label>
                    <input type="number" class="shimmer-input" @bind="topAPISetting.KoboldConf.mirostat_tau" />
                    <label>@Loc["Mirostat Eta"]</label>
                    <input type="number" step="0.01" min="0" max="1" class="shimmer-input" @bind="topAPISetting.KoboldConf.mirostat_eta" />
                </div>

                <div class="shimmer-group">
                    <h5>@Loc["Advanced"]</h5>
                    <label>@Loc["Stop Sequence (comma separated)"]</label>
                    <input class="shimmer-input" 
                           @bind:get="string.Join(',', topAPISetting.KoboldConf.stop_sequence ?? new string[0])" 
                           @bind:set="value => topAPISetting.KoboldConf.stop_sequence = value.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries).Select(s => s.Trim()).ToArray()" />
                    <label>@Loc["Banned Tokens (comma separated)"]</label>
                    <input class="shimmer-input" 
                           @bind:get="string.Join(',', topAPISetting.KoboldConf.banned_tokens ?? new string[0])" 
                           @bind:set="value => topAPISetting.KoboldConf.banned_tokens = value.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries).Select(s => s.Trim()).ToArray()" />
                    <label>@Loc["Genkey"]</label>
                    <input class="shimmer-input" @bind="topAPISetting.KoboldConf.genkey" />
                    <label>@Loc["Grammar"]</label>
                    <textarea class="shimmer-input" rows="3" @bind="topAPISetting.KoboldConf.grammar"></textarea>
                    <label>@Loc["Trim Stop"]</label>
                    <input type="checkbox" @bind="topAPISetting.KoboldConf.trim_stop" />
                    <label>@Loc["Bypass EOS"]</label>
                    <input type="checkbox" @bind="topAPISetting.KoboldConf.bypass_eos" />
                </div>
                <div class="shimmer-group">
                    <p style="font-style: italic; color: #666;">@Loc["Note: Logit bias settings are available in the API but not configurable through this interface."]</p>
                </div>
            }

            @if (topAPISetting.Type == ApiConfigType.OpenAI)
            {
                <label>@Loc["API URL"]</label>
                <input class="shimmer-input" @bind="topAPISetting.OpenAIUrl" />
                <label>@Loc["API KEY"]</label>
                <input type="password" class="shimmer-input" @bind="topAPISetting.OpenAIApiKey" />
                <label>@Loc["API MODEL"]</label>
                <input class="shimmer-input" @bind="topAPISetting.OpenAIModel" />
                <label>@Loc["API GENERATION LENGTH"]</label>
                <input class="shimmer-input" @bind="topAPISetting.OpenAICtx" />
                <label>@Loc["API ENABLE STREAM"]</label>
                <input type="checkbox" @bind="topAPISetting.OpenAIStream" />
                <label>@Loc["API ASIS"]</label>
                <input type="checkbox" @bind="topAPISetting.OpenAIAsIs" />
            }

            @if (topAPISetting.Type == ApiConfigType.DeepSeek)
            {
                <label>@Loc["API URL"]</label>
                <input class="shimmer-input" @bind="topAPISetting.DeepSeekUrl" />
                <label>@Loc["API KEY"]</label>
                <input type="password" class="shimmer-input" @bind="topAPISetting.DeepSeekApiKey" />
                <label>@Loc["API MODEL"]</label>
                <input class="shimmer-input" @bind="topAPISetting.DeepSeekModel" />
                <label>@Loc["API GENERATION LENGTH"]</label>
                <input class="shimmer-input" @bind="topAPISetting.DeepSeekCtx" />
                <label>@Loc["API ENABLE STREAM"]</label>
                <input type="checkbox" @bind="topAPISetting.DeepSeekStream" />
                <label>@Loc["API ASIS"]</label>
                <input type="checkbox" @bind="topAPISetting.DeepSeekAsIs" />
                <div>
                    <label>@Loc["API REASONING EFFORT"]</label>
                    <select class="shimmer-input" @bind="topAPISetting.DeepSeekReasoningEffort">
                        <option value="">@Loc["API REASONING EFFORT OFF"]</option>
                        <option value="high">High</option>
                        <option value="max">Max</option>
                    </select>
                </div>
            }

            @if (topAPISetting.Type == ApiConfigType.OpenAIText)
            {
                <label>@Loc["API URL"]</label>
                <input class="shimmer-input" @bind="topAPISetting.OpenAITextUrl" />
                <label>@Loc["API KEY"]</label>
                <input type="password" class="shimmer-input" @bind="topAPISetting.OpenAITextApiKey" />
                <label>@Loc["API MODEL"]</label>
                <input class="shimmer-input" @bind="topAPISetting.OpenAITextModel" />
                <label>@Loc["API GENERATION LENGTH"]</label>
                <input class="shimmer-input" @bind="topAPISetting.OpenAITextCtx" />
            }
        </div>
    </div>
}
<br />
<button class="su-btn su-btn-primary" style="margin:5px" @onclick="SaveAll">@Loc["Save"]</button>

@code {
    [Inject]
    public required IKVDataService KVData { get; set; }

    List<ApiConfig> apiSettings { get; set; }

    private int _selectedIndex { get; set; }
    ApiConfig topAPISetting => (_selectedIndex >= 0 && _selectedIndex < apiSettings.Count) ? apiSettings[_selectedIndex] : null;

    private void CreateNewApiConfig()
    {
        apiSettings.Add(new ApiConfig { Name = "New API Setting" });
        _selectedIndex = apiSettings.Count - 1;
    }

    private void CloneCurrentApiConfig()
    {
        if (topAPISetting != null)
        {
            var clonedSetting = topAPISetting.Clone();
            clonedSetting.Name = $"{clonedSetting.Name} - Copy";
            apiSettings.Add(clonedSetting);
            _selectedIndex = apiSettings.Count - 1;
        }
    }

    private void CreateNewTextCompletionSetting()
    {
        if (topAPISetting != null)
        {
            if (topAPISetting.TextCompletionSettings == null)
            {
                topAPISetting.TextCompletionSettings = new List<TextCompletionSetting>();
            }
            topAPISetting.TextCompletionSettings.Add(new TextCompletionSetting { name = "New Text Completion Setting" });
            topAPISetting.SelectedTextCompletionSettingIndex = topAPISetting.TextCompletionSettings.Count - 1;
        }
    }

    private void SaveAll()
    {
        KVData.Write("ApiSettings", "apiSetting", Newtonsoft.Json.JsonConvert.SerializeObject(apiSettings));
        KVData.Write("ApiSettings", "selectedAPIIndex", _selectedIndex.ToString()) ;
        Navigation.NavigateTo(Navigation.Uri, true);
    }

    protected override void OnInitialized()
    {
        var apisettings = KVData.Read("ApiSettings", "apiSetting") ?? "[]";
        apiSettings = Newtonsoft.Json.JsonConvert.DeserializeObject<List<ApiConfig>>(apisettings) ?? [];
        var selectedIndex = KVData.Read("ApiSettings", "selectedAPIIndex") ?? "0";
        _selectedIndex = int.Parse(selectedIndex);
    }

}
