@inject IKVDataService KVData
@attribute [PluginPanel("panel.embedding_api_config", "panel.embedding_api_config.desc")]
<div class="shimmer-group" style="display:flex;flex-direction:column;gap:12px;padding:12px;">
	<div class="su-form-group">
		<label class="su-label">URI</label>
		<input class="su-input" type="text" @bind="Uri" placeholder="localhost" />
	</div>
	<div class="su-form-group">
		<label class="su-label">APIKEY</label>
		<input class="su-input" type="text" @bind="ApiKey" placeholder="your apikey" />
	</div>
	<div class="su-form-group">
		<label class="su-label">MODELNAME</label>
		<input class="su-input" type="text" @bind="ModelName" placeholder="openai/text-embedding-3-small" />
	</div>
</div>


@code {
	string? Uri
	{
		get;
		set
		{
			if (field == value)
				return;
			if (value == null)
				return;
			field = value;
			Save();
		}
	}
	string? ApiKey
	{
		get;
		set
		{
			if (field == value)
				return;
			if (value == null)
				return;
			field = value;
			Save();
		}
	}
	string? ModelName
	{
		get;
		set
		{
			if (field == value)
				return;
			if (value == null)
				return;
			field = value;
			Save();
		}
	}	

	void Save()
	{
		if (!Initialized)
			return;
		KVData.Write("EmbeddingAPI", "uri", Uri);
		KVData.Write("EmbeddingAPI", "apikey", ApiKey);
		KVData.Write("EmbeddingAPI", "modelname", ModelName);
	}

	bool Initialized = false;

	protected override void OnInitialized()
	{
		Uri = KVData.Read("EmbeddingAPI", "uri") ?? string.Empty;
		ApiKey = KVData.Read("EmbeddingAPI", "apikey") ?? string.Empty;
		ModelName = KVData.Read("EmbeddingAPI", "modelname") ?? string.Empty;
		Initialized = true;
	}
}
