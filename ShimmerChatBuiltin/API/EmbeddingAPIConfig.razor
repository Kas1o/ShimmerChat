@inject IKVDataService KVData
@inject ILocService Loc
@attribute [PluginPanel("panel.embedding_api_config", "panel.embedding_api_config.desc")]
<div class="su-group su-flex su-flex-col su-gap-3">
	<div class="su-form-group">
		<label class="su-label">@Loc["api_config.embedding_uri"]</label>
		<input class="su-input" type="text" @bind="Uri" placeholder="@Loc["api_config.embedding_uri_placeholder"]" />
	</div>
	<div class="su-form-group">
		<label class="su-label">@Loc["api_config.embedding_apikey"]</label>
		<input class="su-input" type="text" @bind="ApiKey" placeholder="@Loc["api_config.embedding_apikey_placeholder"]" />
	</div>
	<div class="su-form-group">
		<label class="su-label">@Loc["api_config.embedding_model"]</label>
		<input class="su-input" type="text" @bind="ModelName" placeholder="@Loc["api_config.embedding_model_placeholder"]" />
	</div>
</div>


@code {
	string? Uri
	{
		get;
		set
		{
			if (field == value)
				return;
			if (value == null)
				return;
			field = value;
			Save();
		}
	}
	string? ApiKey
	{
		get;
		set
		{
			if (field == value)
				return;
			if (value == null)
				return;
			field = value;
			Save();
		}
	}
	string? ModelName
	{
		get;
		set
		{
			if (field == value)
				return;
			if (value == null)
				return;
			field = value;
			Save();
		}
	}	

	void Save()
	{
		if (!Initialized)
			return;
		KVData.Write("EmbeddingAPI", "uri", Uri);
		KVData.Write("EmbeddingAPI", "apikey", ApiKey);
		KVData.Write("EmbeddingAPI", "modelname", ModelName);
	}

	bool Initialized = false;

	protected override void OnInitialized()
	{
		Uri = KVData.Read("EmbeddingAPI", "uri") ?? string.Empty;
		ApiKey = KVData.Read("EmbeddingAPI", "apikey") ?? string.Empty;
		ModelName = KVData.Read("EmbeddingAPI", "modelname") ?? string.Empty;
		Initialized = true;
	}
}
