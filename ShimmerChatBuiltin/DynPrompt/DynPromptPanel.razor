@attribute [PluginPanel("panel.dyn_prompt", "panel.dyn_prompt.desc")]

@using ShimmerChatLib.Interface
@using ShimmerChatBuiltin.DynPrompt
@using Newtonsoft.Json
@inject IJSRuntime JS

@inject IKVDataService pluginData
@inject ILocService Loc



<div class="shimmer-content su-p-4">
    <h2 class="su-text-lg su-font-bold">@Loc["panel_dynprompt.title"]</h2>
    
    <!-- 新建 DynPromptSet -->
    <div class="su-group">
        <h3 class="su-text-lg su-font-bold">@Loc["panel_dynprompt.create_new_set"]</h3>
        <div class="su-flex su-gap-3 su-mt-3 su-items-center su-flex-wrap">
            <input type="text" class="shimmer-input su-flex-1 @(validationErrors.ContainsKey("newSetName") ? "su-border-top" : "")" 
                    @bind="newSetName" placeholder="@Loc["panel_dynprompt.set_name_placeholder"]" />
            @if (validationErrors.ContainsKey("newSetName"))
            {
                <div class="su-text-danger su-text-sm">@validationErrors["newSetName"]</div>
            }
            <button class="btn" @onclick="CreateNewSet" disabled="@string.IsNullOrWhiteSpace(newSetName)">
                @Loc["panel_dynprompt.create"]
            </button>
        </div>
    </div>

    <!-- DynPromptSet 列表 -->
    <div class="su-group su-mt-5">
        <h3 class="su-text-lg su-font-bold">@Loc["panel_dynprompt.existing_sets"] (@sets.Count)</h3>
        
        @if (sets.Count == 0)
        {
            <p class="su-text-2 su-mt-3">@Loc["panel_dynprompt.no_sets"]</p>
        }
        else
        {
            <div class="su-row su-gap-3 su-mt-3">
                @foreach (var set in sets)
                {
                    <div class="su-card su-cursor-pointer su-p-3 @(selectedSet?.Name == set.Name ? "su-border-top su-shadow-md" : "")"
                        @onclick="() => EditSet(set)">
                        <div class="set-header su-flex su-justify-between su-w-full">
                            <h4 class="su-mb-0">@set.Name</h4>
                            <div class="set-actions su-flex su-gap-2">
                                <button class="su-btn su-btn-sm" @onclick:stopPropagation @onclick="() => EditSet(set)" title="@Loc["panel_dynprompt.edit"]">✏️</button>
                                <button class="su-btn su-btn-sm" @onclick:stopPropagation @onclick="async () => await DeleteSet(set)" title="@Loc["panel_dynprompt.delete"]">🗑️</button>
                            </div>
                        </div>
                        <div class="set-content su-mt-2">
                            <p class="su-text-sm su-text-2">@Loc.Format("panel_dynprompt.term_count", set.Terms.Count)</p>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- 编辑 DynPromptSet -->
    @if (selectedSet != null)
    {
        <div class="su-group su-mt-5">
            <h3>@Loc.Format("panel_dynprompt.edit_set_title", selectedSet.Name)</h3>
            
            <div class="set-info">
                <div class="su-flex su-gap-3 su-mt-3 su-items-center">
                    <label class="su-mt-1">@Loc["panel_dynprompt.label_set_name"]</label>
                    <input type="text" class="shimmer-input" @bind="editingSetName" />
                    <button class="btn" @onclick="UpdateSetName" disabled="@string.IsNullOrWhiteSpace(editingSetName)">
                        @Loc["panel_dynprompt.update_name"]
                    </button>
                </div>
            </div>

            <!-- DynPromptTerm 列表 -->
            <div class="mt-4">
                <h4>@Loc["panel_dynprompt.term_list"] (@selectedSet.Terms.Count)</h4>
                
                @if (selectedSet.Terms.Count == 0)
                {
                    <p class="su-text-2 su-mt-2">@Loc["panel_dynprompt.no_terms"]</p>
                }
                else
                {
                    <div class="su-flex su-flex-col su-gap-3 su-mt-2">
                        @foreach (var term in selectedSet.Terms)
                        {
                            <div class="su-card su-p-3 @(editingTerm == term ? "su-border-top" : "")">
                                <div class="term-header su-flex su-justify-between">
                                    <h5 class="su-mb-0">@term.Name</h5>
                                    <div class="term-actions su-flex su-gap-2">
                                        <button class="su-btn su-btn-sm" @onclick="() => EditTerm(term)" title="@Loc["panel_dynprompt.edit"]">✏️</button>
                                        <button class="su-btn su-btn-sm" @onclick="async () => await DeleteTerm(term)" title="@Loc["panel_dynprompt.delete"]">🗑️</button>
                                    </div>
                                </div>
                                <div class="term-preview su-mt-2">
                                    <p class="su-text-sm"><strong>@Loc["panel_dynprompt.label_content"]:</strong> @(term.Content.Length > 100 ? term.Content.Substring(0, 100) + "..." : term.Content)</p>
                                    <p class="su-text-sm"><strong>@Loc["panel_dynprompt.label_inject_mode"]:</strong> @term.InjectionMode</p>
                                    <p class="su-text-sm"><strong>@Loc["panel_dynprompt.label_trigger_rule"]:</strong> @(string.IsNullOrEmpty(term.TriggerRule) ? Loc["panel_dynprompt.none"] : term.TriggerRule)</p>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- 添加 DynPromptTerm -->
            <div class="mt-4">
                <h4>@Loc["panel_dynprompt.add_new_term"]</h4>
                <button class="btn mt-2" @onclick="ShowAddTermForm">@Loc["panel_dynprompt.add_term_btn"]</button>
            </div>
        </div>
    }

    <!-- 编辑或添加 DynPromptTerm 的表单 -->
    @if (showTermForm)
    {
        <div class="su-modal-mask">
            <div class="su-modal su-modal-sm su-p-4">
                <h4>@(isEditingTerm ? Loc["panel_dynprompt.edit_term_title"] : Loc["panel_dynprompt.add_term_title"])</h4>
                
                <div class="su-form-group su-mt-3">
                    <label>@Loc["panel_dynprompt.label_term_name"]:</label>
                    <input type="text" class="shimmer-input @(validationErrors.ContainsKey("termName") ? "su-border-top" : "")" 
                            @bind="termForm.Name" placeholder="@Loc["panel_dynprompt.term_name_placeholder"]" />
                    @if (validationErrors.ContainsKey("termName"))
                    {
                        <div class="su-text-danger su-text-sm su-mt-1">@validationErrors["termName"]</div>
                    }
                </div>
                
                <div class="su-form-group su-mt-3">
                    <label>@Loc["panel_dynprompt.label_content"]:</label>
                    <textarea class="shimmer-textarea @(validationErrors.ContainsKey("termContent") ? "su-border-top" : "")" 
                                @bind="termForm.Content" placeholder="@Loc["panel_dynprompt.term_content_placeholder"]" rows="5"></textarea>
                    @if (validationErrors.ContainsKey("termContent"))
                    {
                        <div class="su-text-danger su-text-sm su-mt-1">@validationErrors["termContent"]</div>
                    }
                </div>
                
                <div class="su-form-group su-mt-3">
                    <label>@Loc["panel_dynprompt.label_inject_mode"]:</label>
                    <select class="shimmer-input" @bind="termForm.InjectionMode">
                        @foreach (var mode in Enum.GetValues(typeof(DynPromptTermInjectionMode)))
                        {
                            <option value="@mode">@mode</option>
                        }
                    </select>
                </div>
                
                <div class="su-form-group su-mt-3">
                    <label>@Loc["panel_dynprompt.label_inject_depth"]:</label>
                    <input type="number" class="shimmer-input" @bind="termForm.InjectionDepth" min="1" />
                </div>
                
                <div class="su-form-group su-mt-3">
                    <label>@Loc["panel_dynprompt.label_trigger_rule"]:</label>
                    <textarea class="shimmer-textarea @(validationErrors.ContainsKey("termTriggerRule") ? "su-border-top" : "")" 
                                @bind="termForm.TriggerRule" placeholder="@Loc["panel_dynprompt.trigger_rule_placeholder"]" rows="3"></textarea>
                    @if (validationErrors.ContainsKey("termTriggerRule"))
                    {
                        <div class="su-text-danger su-text-sm su-mt-1">@validationErrors["termTriggerRule"]</div>
                    }
                    <small class="su-text-2 su-mt-1">@Loc["panel_dynprompt.trigger_rule_help"]</small>
                    <a href="https://github.com/Kas1o/ShimmerChat/blob/master/ShimmerChatBuiltin/DynPrompt/TriggerRule.md">@Loc["panel_dynprompt.doc_link"]</a>
                </div>
                
                <div class="su-form-group su-mt-3">
                    <div class="su-flex su-items-center su-gap-2">
                        <input type="checkbox" id="allowRecursive" @bind="termForm.AllowBeTriggeredByRecursive" />
                        <label for="allowRecursive">@Loc["panel_dynprompt.allow_recursive"]</label>
                    </div>
                </div>
                
                <div class="form-actions su-flex su-gap-3 su-justify-end su-mt-4">
                    <button class="su-btn" @onclick="CancelTermForm">@Loc["panel_dynprompt.cancel"]</button>
                    <button class="btn" @onclick="SaveTerm">@Loc["panel_dynprompt.save"]</button>
                </div>
            </div>
        </div>
    }

    <!-- 加载指示器 -->
    @if (isLoading)
    {
        <div class="su-modal-mask">
            <div class="su-modal su-modal-sm su-p-4 su-text-center">
                <div class="su-text-accent su-mb-3">⏳</div>
                <div class="su-text-lg">@Loc["panel_dynprompt.processing"]</div>
            </div>
        </div>
    }

    <!-- 保存和状态消息 -->
    <div class="su-mt-5 su-pt-3 su-border-top">
        <div class="su-flex su-justify-between su-items-center">
            <button class="btn" @onclick="SaveAllChanges" disabled="@isLoading">@Loc["panel_dynprompt.save_all"]</button>
            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="su-px-4 su-py-2 su-rounded su-text-sm 
                            @(statusType == "success" ? "su-badge su-badge-success" : 
                                statusType == "error" ? "su-badge su-badge-danger" : "su-badge")">
                    <span>
                        @(statusType == "success" ? "✓" : statusType == "error" ? "✗" : "i") 
                        @statusMessage
                    </span>
                </div>
            }
        </div>
    </div>
</div>

@code {
    List<DynPromptSet> sets = [];
    DynPromptSet? selectedSet = null;
    string newSetName = "";
    string editingSetName = "";
    DynPromptTerm? editingTerm = null;
    bool showTermForm = false;
    bool isEditingTerm = false;
    string statusMessage = "";
    string statusType = "info"; // info, success, error

    // 表单数据
    DynPromptTerm termForm = new()
    {
        Name = "",
        Content = "",
        InjectionMode = DynPromptTermInjectionMode.BeforeSystem,
        InjectionDepth = 4,
        TriggerRule = "",
        AllowBeTriggeredByRecursive = false
    };

    // 加载状态
    bool isLoading = false;
    // 表单验证错误
    Dictionary<string, string> validationErrors = new();

    protected override void OnInitialized()
    {
        base.OnInitialized();
        LoadDynPromptSets();
    }

    void LoadDynPromptSets()
    {
        try
        {
            isLoading = true;
            var data = pluginData.Read("DynPrompt", "DynPromptSets");
            sets = JsonConvert.DeserializeObject<List<DynPromptSet>>(data ?? "[]") ?? [];
            ShowStatus(Loc["panel_dynprompt.msg_load_success"], "success");
        }
        catch (Exception ex)
        {
            ShowStatus(Loc.Format("panel_dynprompt.msg_load_failed", ex.Message), "error");
            sets = [];
        }
        finally
        {
            isLoading = false;
        }
    }

    // 验证触发规则的正则表达式
    bool ValidateTriggerRule(string rule, out string? message)
    {
        message = null;
        if (string.IsNullOrEmpty(rule))
            return true;
        try
        {
			// 用空字符串测试规则的语法有效性
			_ = DynPromptEvaluator.Evaluate(rule, string.Empty);
			return true;
        }
        catch(Exception ex)
        {
			message = ex.Message;
            return false;
        }
    }

    void CreateNewSet()
    {
        // 清除之前的验证错误
        ClearValidationErrors();
        
        if (string.IsNullOrWhiteSpace(newSetName))
        {
            AddValidationError("newSetName", Loc["panel_dynprompt.msg_invalid_set_name"]);
            ShowStatus(Loc["panel_dynprompt.msg_invalid_set_name"], "error");
            return;
        }

        if (sets.Any(s => s.Name == newSetName))
        {
            AddValidationError("newSetName", Loc["panel_dynprompt.msg_set_name_exists"]);
            ShowStatus(Loc["panel_dynprompt.msg_set_name_exists"], "error");
            return;
        }

        try
        {
            isLoading = true;
            var newSet = new DynPromptSet { Name = newSetName };
            sets.Add(newSet);
            selectedSet = newSet;
            editingSetName = newSetName;
            newSetName = "";
            ShowStatus(Loc["panel_dynprompt.msg_set_created"], "success");
            
            // 自动保存
            SaveAllChanges();
        }
        catch (Exception ex)
        {
            ShowStatus(Loc.Format("panel_dynprompt.msg_set_create_failed", ex.Message), "error");
        }
        finally
        {
            isLoading = false;
        }
    }

    void AddValidationError(string field, string message)
    {
        validationErrors[field] = message;
    }

    void ClearValidationErrors()
    {
        validationErrors.Clear();
    }

    void EditSet(DynPromptSet set)
    {
        selectedSet = set;
        editingSetName = set.Name;
    }

    async Task DeleteSet(DynPromptSet set)
    {
        try
        {
            // 使用JSInterop调用浏览器的confirm函数
            bool confirmed = await JS.InvokeAsync<bool>("confirm", 
                Loc.Format("panel_dynprompt.msg_confirm_delete_set", set.Name));
            
            if (confirmed)
            {
                isLoading = true;
                sets.Remove(set);
                if (selectedSet == set)
                {
                    selectedSet = null;
                    editingSetName = "";
                }
                ShowStatus(Loc["panel_dynprompt.msg_set_deleted"], "success");
                
                 // 自动保存
                SaveAllChanges();
            }
        }
        catch (Exception ex)
        {
            ShowStatus(Loc.Format("panel_dynprompt.msg_set_delete_failed", ex.Message), "error");
        }
        finally
        {
            isLoading = false;
        }
    }

    void UpdateSetName()
    {
        if (selectedSet == null || string.IsNullOrWhiteSpace(editingSetName))
        {
            ShowStatus(Loc["panel_dynprompt.msg_invalid_set_name"], "error");
            return;
        }

        if (sets.Any(s => s.Name == editingSetName && s != selectedSet))
        {
            ShowStatus(Loc["panel_dynprompt.msg_set_name_exists"], "error");
            return;
        }

        selectedSet.Name = editingSetName;
        ShowStatus(Loc["panel_dynprompt.msg_set_name_updated"], "success");
        
        // 自动保存
        SaveAllChanges();
    }

    void ShowAddTermForm()
    {
        if (selectedSet == null)
        {
            ShowStatus(Loc["panel_dynprompt.msg_select_set_first"], "error");
            return;
        }

        isEditingTerm = false;
        termForm = new()
        {
            Name = "",
            Content = "",
            InjectionMode = DynPromptTermInjectionMode.BeforeSystem,
            InjectionDepth = 4,
            TriggerRule = "",
            AllowBeTriggeredByRecursive = false
        };
        showTermForm = true;
    }

    void EditTerm(DynPromptTerm term)
    {
        editingTerm = term;
        isEditingTerm = true;
        termForm = new()
        {
            Name = term.Name,
            Content = term.Content,
            InjectionMode = term.InjectionMode,
            InjectionDepth = term.InjectionDepth,
            TriggerRule = term.TriggerRule,
            AllowBeTriggeredByRecursive = term.AllowBeTriggeredByRecursive
        };
        showTermForm = true;
    }

    async Task DeleteTerm(DynPromptTerm term)
    {
        try
        {
            if (selectedSet != null)
            {
                // 使用JSInterop调用浏览器的confirm函数
                bool confirmed = await JS.InvokeAsync<bool>("confirm", 
                    Loc.Format("panel_dynprompt.msg_confirm_delete_term", term.Name));
                
                if (confirmed)
                {
                    isLoading = true;
                    selectedSet.Terms.Remove(term);
                    if (editingTerm == term)
                    {
                        editingTerm = null;
                    }
                    ShowStatus(Loc["panel_dynprompt.msg_term_deleted"], "success");
                    
                    // 自动保存
                    SaveAllChanges();
                }
            }
        }
        catch (Exception ex)
        {
            ShowStatus(Loc.Format("panel_dynprompt.msg_term_delete_failed", ex.Message), "error");
        }
        finally
        {
            isLoading = false;
        }
    }

    void SaveTerm()
    {
        // 清除之前的验证错误
        ClearValidationErrors();
        
        if (selectedSet == null)
        {
            ShowStatus(Loc["panel_dynprompt.msg_select_set_first"], "error");
            return;
        }

        // 验证必填字段
        if (string.IsNullOrWhiteSpace(termForm.Name))
        {
            AddValidationError("termName", Loc["panel_dynprompt.msg_term_name_required"]);
        }

        if (string.IsNullOrWhiteSpace(termForm.Content))
        {
            AddValidationError("termContent", Loc["panel_dynprompt.msg_term_content_required"]);
        }

        // 验证触发规则
        if (!ValidateTriggerRule(termForm.TriggerRule, out var message))
        {
            AddValidationError("termTriggerRule", Loc.Format("panel_dynprompt.msg_trigger_syntax_error", message ?? ""));
        }

        // 检查名称冲突
        if (!string.IsNullOrWhiteSpace(termForm.Name))
        {
            if (isEditingTerm && editingTerm != null)
            {
                if (selectedSet.Terms.Any(t => t.Name == termForm.Name && t != editingTerm))
                {
                    AddValidationError("termName", Loc["panel_dynprompt.msg_term_name_exists"]);
                }
            }
            else
            {
                if (selectedSet.Terms.Any(t => t.Name == termForm.Name))
                {
                    AddValidationError("termName", Loc["panel_dynprompt.msg_term_name_exists"]);
                }
            }
        }

        // 如果有验证错误，显示错误信息
        if (validationErrors.Count > 0)
        {
            ShowStatus(Loc["panel_dynprompt.msg_fix_form_errors"], "error");
            StateHasChanged();
            return;
        }

        try
        {
            isLoading = true;
            
            if (isEditingTerm && editingTerm != null)
            {
                // 更新现有项
                editingTerm.Name = termForm.Name;
                editingTerm.Content = termForm.Content;
                editingTerm.InjectionMode = termForm.InjectionMode;
                editingTerm.InjectionDepth = termForm.InjectionDepth;
                editingTerm.TriggerRule = termForm.TriggerRule;
                editingTerm.AllowBeTriggeredByRecursive = termForm.AllowBeTriggeredByRecursive;
                ShowStatus(Loc["panel_dynprompt.msg_term_updated"], "success");
            }
            else
            {
                // 添加新项
                var newTerm = new DynPromptTerm
                {
                    Name = termForm.Name,
                    Content = termForm.Content,
                    InjectionMode = termForm.InjectionMode,
                    InjectionDepth = termForm.InjectionDepth,
                    TriggerRule = termForm.TriggerRule,
                    AllowBeTriggeredByRecursive = termForm.AllowBeTriggeredByRecursive
                };
                selectedSet.Terms.Add(newTerm);
                ShowStatus(Loc["panel_dynprompt.msg_term_added"], "success");
            }

            CancelTermForm();
                
                // 自动保存
                SaveAllChanges();
            }
            catch (Exception ex)
            {
                ShowStatus(Loc.Format("panel_dynprompt.msg_term_save_failed", ex.Message), "error");
            }
            finally
            {
                isLoading = false;
            }
    }

    void CancelTermForm()
    {
        showTermForm = false;
        editingTerm = null;
        isEditingTerm = false;
    }

    void SaveAllChanges()
    {
        try
        {
            isLoading = true;
            
            // 验证所有数据
            bool hasErrors = false;
            foreach (var set in sets)
            {
                if (string.IsNullOrWhiteSpace(set.Name))
                {
                    hasErrors = true;
                    ShowStatus(Loc["panel_dynprompt.msg_invalid_set_names"], "error");
                    break;
                }
                
                foreach (var term in set.Terms)
                {
                    if (string.IsNullOrWhiteSpace(term.Name) || string.IsNullOrWhiteSpace(term.Content))
                    {
                        hasErrors = true;
                        ShowStatus(Loc["panel_dynprompt.msg_invalid_terms"], "error");
                        break;
                    }
                    
                    if (!ValidateTriggerRule(term.TriggerRule, out _))
                    {
                        hasErrors = true;
                        ShowStatus(Loc.Format("panel_dynprompt.msg_term_trigger_error", term.Name), "error");
                        break;
                    }
                }
                
                if (hasErrors)
                    break;
            }
            
            if (hasErrors)
                return;
            
            var json = JsonConvert.SerializeObject(sets, Formatting.Indented);
            pluginData.Write("DynPrompt", "DynPromptSets", json);
            ShowStatus(Loc["panel_dynprompt.msg_all_saved"], "success");
        }
        catch (Exception ex)
        {
            ShowStatus(Loc.Format("panel_dynprompt.msg_save_all_failed", ex.Message), "error");
        }
        finally
        {
            isLoading = false;
        }
    }

    void ShowStatus(string message, string type)
    {
        statusMessage = message;
        statusType = type;
        // 3秒后自动清除消息
        InvokeAsync(async () =>
        {
            await Task.Delay(3000);
            statusMessage = "";
            StateHasChanged();
        });
    }

    // 移除模拟的confirm函数，现在使用JSInterop
}