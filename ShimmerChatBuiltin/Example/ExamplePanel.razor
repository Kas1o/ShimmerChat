@using ShimmerChatLib.Panel
@inject ILocService Loc


@attribute [PluginPanelAttribute("panel.example", "panel.example.desc")]

<div class="example-panel su-p-4">
    <h3 class="su-text-lg su-font-bold su-mb-4">@Loc["panel_example.title"]</h3>
    <p class="su-mb-4">@Loc["panel_example.desc"]</p>
    
    <div class="su-surface-3 su-p-4 su-rounded-lg border">
        <h4 class="su-text-lg su-font-bold su-mb-2">@Loc["panel_example.demo_title"]</h4>
        <ul class="su-ps-3 su-flex su-flex-col su-gap-2">
            <li>@Loc["panel_example.feature_dynamic_load"]</li>
            <li>@Loc["panel_example.feature_plugin_attr"]</li>
            <li>@Loc["panel_example.feature_dynamic_render"]</li>
            <li>@Loc["panel_example.feature_custom_icon"]</li>
        </ul>
    </div>
    
    <div class="su-mt-6">
        <button @onclick="OnButtonClick" class="su-btn su-btn-primary">
            @Loc["panel_example.click_me"]
        </button>
    </div>
    
    <div class="su-mt-4 su-text-2 su-text-sm">
        @DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")
    </div>
</div>

@code {
    // 组件代码部分
    protected override void OnInitialized()
    {
        Console.WriteLine("示例面板已初始化");
    }

    private void OnButtonClick()
    {
        Console.WriteLine("按钮被点击了！");
	}
}