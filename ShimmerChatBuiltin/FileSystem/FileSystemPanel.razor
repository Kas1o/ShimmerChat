@attribute [PluginPanelAttribute("panel.file_system", "panel.file_system.desc", PanelDisplayPlace.Settings)]

@using ShimmerChatLib.Interface
@using ShimmerChatBuiltin.FileSystem
@using Newtonsoft.Json
@inject IKVDataService pluginData

<div class="shimmer-content su-p-4">
    <h2 class="su-text-lg su-font-bold su-mb-4">File System Access Control</h2>
    <p class="su-text-2 su-mb-4">Configure regex-based AllowList and BanList patterns to control which paths the File System tools can access.</p>

    <div class="su-row su-gap-4">
        <div class="su-col-6">
            <div class="su-group">
                <h3 class="su-text-lg su-font-bold">AllowList</h3>
                <p class="su-text-sm su-text-2 su-mb-2">Regex patterns for paths that are <strong>explicitly allowed</strong>. One pattern per line. If empty, all non-banned paths are allowed.</p>
                <textarea class="shimmer-textarea su-w-full" rows="8"
                          @bind="allowListText" placeholder="C:\\Users\\.*"></textarea>
            </div>
        </div>
        <div class="su-col-6">
            <div class="su-group">
                <h3 class="su-text-lg su-font-bold">BanList</h3>
                <p class="su-text-sm su-text-2 su-mb-2">Regex patterns for paths that are <strong>always denied</strong>. One pattern per line. BanList takes precedence over AllowList.</p>
                <textarea class="shimmer-textarea su-w-full" rows="8"
                          @bind="banListText" placeholder="C:\\Windows\\.*"></textarea>
            </div>
        </div>
    </div>

    <div class="su-group su-mt-4">
        <h3 class="su-text-lg su-font-bold">Test Path</h3>
        <div class="su-flex su-gap-3 su-mt-2 su-items-center su-flex-wrap">
            <input type="text" class="shimmer-input su-flex-1" @bind="testPath" placeholder="Enter a path to test against the rules..." />
            <button class="btn" @onclick="TestPath">Test</button>
        </div>
        @if (!string.IsNullOrEmpty(testResult))
        {
            <div class="su-mt-2 su-px-3 su-py-2 su-rounded @(testResultClass)">
                @testResult
            </div>
        }
    </div>

    <div class="su-mt-5 su-pt-3 su-border-top su-flex su-justify-between su-items-center">
        <button class="btn" @onclick="SaveConfig" disabled="@isLoading">Save Configuration</button>
        <button class="btn" @onclick="ResetToDefaults">Reset to Defaults</button>
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="su-px-4 su-py-2 su-rounded su-text-sm @(statusType == "success" ? "su-badge su-badge-success" : "su-badge su-badge-danger")">
                @statusMessage
            </div>
        }
    </div>

    @if (isLoading)
    {
        <div class="su-modal-mask">
            <div class="su-modal su-modal-sm su-p-4 su-text-center">
                <div class="su-text-accent su-mb-3">Loading...</div>
            </div>
        </div>
    }
</div>

@code {
    private string allowListText = "";
    private string banListText = "";
    private string testPath = "";
    private string testResult = "";
    private string testResultClass = "";
    private string statusMessage = "";
    private string statusType = "success";
    private bool isLoading;

    protected override void OnInitialized()
    {
        LoadConfig();
    }

    private void LoadConfig()
    {
        try
        {
            isLoading = true;
            var config = FileSystemConfigManager.Load(pluginData);
            allowListText = string.Join(Environment.NewLine, config.AllowList);
            banListText = string.Join(Environment.NewLine, config.BanList);
        }
        catch (Exception ex)
        {
            ShowStatus($"Failed to load config: {ex.Message}", "error");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SaveConfig()
    {
        try
        {
            isLoading = true;

            var config = new FileSystemConfig
            {
                AllowList = allowListText
                    .Split('\n', StringSplitOptions.RemoveEmptyEntries)
                    .Select(s => s.Trim().TrimEnd('\r'))
                    .Where(s => !string.IsNullOrWhiteSpace(s))
                    .ToList(),
                BanList = banListText
                    .Split('\n', StringSplitOptions.RemoveEmptyEntries)
                    .Select(s => s.Trim().TrimEnd('\r'))
                    .Where(s => !string.IsNullOrWhiteSpace(s))
                    .ToList()
            };

            foreach (var pattern in config.AllowList.Concat(config.BanList))
            {
                try
                {
                    _ = System.Text.RegularExpressions.Regex.IsMatch("test", pattern);
                }
                catch (Exception ex)
                {
                    ShowStatus($"Invalid regex pattern: '{pattern}' - {ex.Message}", "error");
                    isLoading = false;
                    return;
                }
            }

            FileSystemConfigManager.Save(pluginData, config);
            ShowStatus("Configuration saved successfully.", "success");
        }
        catch (Exception ex)
        {
            ShowStatus($"Failed to save config: {ex.Message}", "error");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void TestPath()
    {
        if (string.IsNullOrWhiteSpace(testPath))
        {
            testResult = "Please enter a path to test.";
            testResultClass = "bg-info/10 text-info";
            return;
        }

        try
        {
            var fullPath = System.IO.Path.GetFullPath(testPath);
            var normalized = fullPath.Replace('\\', '/');

            var config = new FileSystemConfig
            {
                AllowList = allowListText
                    .Split('\n', StringSplitOptions.RemoveEmptyEntries)
                    .Select(s => s.Trim().TrimEnd('\r'))
                    .Where(s => !string.IsNullOrWhiteSpace(s))
                    .ToList(),
                BanList = banListText
                    .Split('\n', StringSplitOptions.RemoveEmptyEntries)
                    .Select(s => s.Trim().TrimEnd('\r'))
                    .Where(s => !string.IsNullOrWhiteSpace(s))
                    .ToList()
            };

            if (config.BanList.Count > 0)
            {
                foreach (var pattern in config.BanList)
                {
                    if (string.IsNullOrWhiteSpace(pattern)) continue;
                    try
                    {
                        if (System.Text.RegularExpressions.Regex.IsMatch(normalized, pattern, System.Text.RegularExpressions.RegexOptions.IgnoreCase))
                        {
                            testResult = $"BLOCKED - Matched BanList pattern: '{pattern}' (Full path: {normalized})";
                            testResultClass = "bg-danger/10 text-danger";
                            return;
                        }
                    }
                    catch { }
                }
            }

            if (config.AllowList.Count == 0)
            {
                testResult = $"ALLOWED - No AllowList configured. (Full path: {normalized})";
                testResultClass = "bg-success/10 text-success";
                return;
            }

            foreach (var pattern in config.AllowList)
            {
                if (string.IsNullOrWhiteSpace(pattern)) continue;
                try
                {
                    if (System.Text.RegularExpressions.Regex.IsMatch(normalized, pattern, System.Text.RegularExpressions.RegexOptions.IgnoreCase))
                    {
                        testResult = $"ALLOWED - Matched AllowList pattern: '{pattern}' (Full path: {normalized})";
                        testResultClass = "bg-success/10 text-success";
                        return;
                    }
                }
                catch { }
            }

            testResult = $"BLOCKED - Did not match any AllowList pattern. (Full path: {normalized})";
            testResultClass = "bg-danger/10 text-danger";
        }
        catch (Exception ex)
        {
            testResult = $"Error: {ex.Message}";
            testResultClass = "bg-danger/10 text-danger";
        }
    }

    private void ResetToDefaults()
    {
        allowListText = "";
        banListText = "";
        testResult = "";
        ShowStatus("Form reset to defaults. Click Save to persist.", "success");
    }

    private void ShowStatus(string message, string type)
    {
        statusMessage = message;
        statusType = type;
        InvokeAsync(async () =>
        {
            await Task.Delay(3000);
            statusMessage = "";
            StateHasChanged();
        });
    }
}
