@using Newtonsoft.Json
@using ShimmerChatLib
@using ShimmerChatLib.Generation
@inject IKVDataService KVData

<div class="api-select-editor">
    <div class="ge-field">
        <label class="ge-label" title="Select which API configuration to use for this generation">
            API Config
        </label>
        <div class="ge-value">
            <select class="ge-select" @bind="SelectedIndex" @bind:event="onchange"
                    style="width: 100%; max-width: 400px;">
                <option value="-2">Use global default API</option>
                @for (int i = 0; i < _settings.Count; i++)
                {
                    <option value="@i">@_settings[i].Name (@_settings[i].Type)</option>
                }
            </select>
            @if (_settings.Count == 0)
            {
                <div style="font-size: 0.75em; color: #e66; margin-top: 4px;">
                    No API settings configured. Please add one in the API Settings panel.
                </div>
            }
            else
            {
                <div style="font-size: 0.72em; color: #666; margin-top: 4px;">
                    @(SelectedIndex == -2
                        ? "Will use the globally selected API from API Settings."
                        : SelectedIndex >= 0 && SelectedIndex < _settings.Count
                            ? $"Using: {_settings[SelectedIndex].Name} ({_settings[SelectedIndex].Type}) — {(_settings[SelectedIndex].EnableStream ? "streaming" : "non-streaming")}"
                            : "")
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public APISelectNode Node { get; set; } = default!;
    [Parameter] public EventCallback<IGenerationNode> OnChanged { get; set; }

    private List<ApiConfig> _settings = [];

    private int SelectedIndex
    {
        get => field;
        set
        {
            field = value;
            Node.APIIndex = value == -2 ? -1 : value;
            OnChanged.InvokeAsync(Node);
        }
    } = -2;

    protected override void OnInitialized()
    {
        var json = KVData.Read("ApiSettings", "apiSetting") ?? "[]";
        _settings = JsonConvert.DeserializeObject<List<ApiConfig>>(json) ?? [];

        if (Node.APIIndex == -1)
            SelectedIndex = -2;
        else if (Node.APIIndex >= 0 && Node.APIIndex < _settings.Count)
            SelectedIndex = Node.APIIndex;
        else
            SelectedIndex = -2;
    }
}
