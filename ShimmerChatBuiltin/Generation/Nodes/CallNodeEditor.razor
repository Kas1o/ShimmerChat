@using Newtonsoft.Json
@using ShimmerChatLib.Generation
@inject ShimmerChatLib.Interface.IKVDataService KVData
@inject ILocService Loc
@inject IJSRuntime JS

<div class="call-node-editor">
    <div class="ge-field">
        <label class="ge-label">@Loc["editor.call_node.label"]</label>
        <div class="ge-value">

            @if (_showPicker)
            {
                <!-- 搜索 + 列表模式 -->
                <input type="text" class="call-search"
                       placeholder="@Loc["editor.call_node.search_placeholder"]"
                       @bind-value="SearchText" @bind-value:event="oninput" />

                @if (_filteredPresets.Count > 0)
                {
                    <div class="call-list">
                        @foreach (var preset in _filteredPresets)
                        {
                            <div class="call-item @(preset.Id == _selectedPresetId ? "call-item-active" : "")"
                                 @onclick="() => SelectPreset(preset)">
                                <span class="call-item-name">@preset.Name</span>
                                <span class="call-item-id" title="@preset.Id">@preset.Id</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="call-empty">
                        @(_presets.Count == 0
                            ? Loc["editor.call_node.no_presets"]
                            : Loc["editor.call_node.no_match"])
                    </div>
                }
            }
            else
            {
                <!-- 已选择模式 -->
                <div class="call-selected">
                    <span class="call-sel-name">@_selectedPreset?.Name</span>
                    <button class="call-change-btn" @onclick="StartChange"
                            title="@Loc["editor.call_node.change"]">@Loc["editor.call_node.change"]</button>
                </div>
                <div class="call-selected-id">
                    <span class="call-id-label">@Loc["editor.call_node.selected_id"]</span>
                    <code class="call-id-text"
                          @oncontextmenu="CopyId"
                          @oncontextmenu:preventDefault
                          title="Right-click to copy">@_selectedPresetId</code>
                    <button class="call-copy-btn" @onclick="CopyId"
                            title="@Loc["editor.call_node.copy"]">@Loc["editor.call_node.copy"]</button>
                </div>
            }

        </div>
    </div>
</div>

@code {
    [Parameter] public CallNode Node { get; set; } = default!;
    [Parameter] public EventCallback<IGenerationNode> OnChanged { get; set; }

    private List<GenerationPreset> _presets = [];
    private List<GenerationPreset> _filteredPresets = [];
    private GenerationPreset? _selectedPreset;
    private string _selectedPresetId = "";
    private string _searchText = "";
    private bool _showPicker;

    private string SearchText
    {
        get => _searchText;
        set
        {
            _searchText = value;
            ApplyFilter();
        }
    }

    protected override void OnInitialized()
    {
        var json = KVData.Read("GenerationManager", "generation_presets");
        _presets = JsonConvert.DeserializeObject<List<GenerationPreset>>(json ?? "[]") ?? [];
        _selectedPresetId = Node.PresetId ?? "";
        _selectedPreset = _presets.FirstOrDefault(p => p.Id == _selectedPresetId);

        // 有选中预设则显示已选择状态，否则显示选择器
        _showPicker = _selectedPreset == null;
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            _filteredPresets = _presets.ToList();
        }
        else
        {
            var q = _searchText.Trim();
            _filteredPresets = _presets
                .Where(p =>
                    p.Name.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                    p.Id.Contains(q, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    private void SelectPreset(GenerationPreset preset)
    {
        _selectedPreset = preset;
        _selectedPresetId = preset.Id;
        Node.PresetId = preset.Id;
        _showPicker = false;
        _searchText = "";
        OnChanged.InvokeAsync(Node);
    }

    private void StartChange()
    {
        _showPicker = true;
        _searchText = "";
        ApplyFilter();
    }

    private async Task CopyId()
    {
        if (!string.IsNullOrEmpty(_selectedPresetId))
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _selectedPresetId);
        }
    }
}

<style>
.call-node-editor { font-size: 0.82em; }

.call-search {
    width: 100%; max-width: 400px;
    padding: 5px 8px;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 4px;
    background: rgba(255,255,255,0.04);
    color: #ccc;
    font-size: 0.82em;
    margin-bottom: 6px;
}
.call-search:focus { border-color: rgba(100,150,255,0.3); outline: none; }
.call-search::placeholder { color: #666; }

.call-list {
    max-height: 200px; overflow-y: auto;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 4px;
    margin-bottom: 6px;
}
.call-item {
    padding: 5px 8px; cursor: pointer;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    display: flex; gap: 12px; align-items: baseline;
    transition: background 0.1s;
}
.call-item:last-child { border-bottom: none; }
.call-item:hover { background: rgba(100,150,255,0.08); }
.call-item-active { background: rgba(100,150,255,0.14); }
.call-item-name {
    font-weight: 600; color: #ccc;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    max-width: 180px;
}
.call-item-id {
    font-size: 0.72em; color: #555;
    font-family: monospace;
    overflow: hidden; text-overflow: ellipsis;
    flex: 1;
}

.call-empty {
    padding: 10px; color: #555; text-align: center;
    font-style: italic; font-size: 0.78em;
}

.call-selected {
    display: flex; align-items: center; gap: 8px;
    padding: 4px 8px;
    background: rgba(64,192,160,0.06);
    border: 1px solid rgba(64,192,160,0.15);
    border-radius: 4px;
    max-width: 400px;
    margin-bottom: 6px;
}
.call-sel-name { font-weight: 600; color: #40c0a0; flex: 1; }
.call-change-btn {
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.04);
    color: #888;
    cursor: pointer; font-size: 0.72em; padding: 2px 8px;
    border-radius: 3px;
    white-space: nowrap;
}
.call-change-btn:hover { border-color: rgba(100,150,255,0.3); color: #aac; }

.call-selected-id {
    display: flex; align-items: center; gap: 6px;
    max-width: 400px;
}
.call-id-label { font-size: 0.7em; color: #777; white-space: nowrap; }
.call-id-text {
    font-size: 0.72em; color: #999;
    font-family: monospace;
    overflow: hidden; text-overflow: ellipsis;
    flex: 1;
    cursor: pointer;
    user-select: all;
}
.call-copy-btn {
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.04);
    color: #888;
    cursor: pointer; font-size: 0.68em; padding: 2px 6px;
    border-radius: 3px;
    white-space: nowrap;
}
.call-copy-btn:hover { border-color: rgba(64,192,160,0.3); color: #40c0a0; }
</style>
