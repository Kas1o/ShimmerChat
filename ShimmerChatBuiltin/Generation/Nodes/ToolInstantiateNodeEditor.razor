@using ShimmerChatLib.Generation

@inject IToolRegistry ToolRegistry
@inject ILocService Loc

<div class="ti-editor">
    <div class="ti-label">@Loc["editor_tool_instantiate.select_tool"]</div>
    @if (_selectedToolName != null)
    {
        <div class="ti-selected">
            <span class="ti-sel-name">@_selectedToolName</span>
            <button class="ti-sel-clear" @onclick="ClearSelection" title="@Loc["editor_tool_instantiate.clear"]">✕</button>
        </div>
    }

    @if (_showPicker)
    {
        <div class="ti-picker">
            @foreach (var group in _groupedTools)
            {
                <div class="ti-group">
                    <div class="ti-group-header">@string.Join(" / ", group.Key.Split('/').Select(k => Loc[k.Trim()]))</div>
                    @foreach (var tool in group.Value)
                    {
                        <div class="ti-item @(tool.NameKey == _selectedToolName ? "ti-item-active" : "")"
                             @onclick="() => SelectTool(tool)">
                            <span class="ti-item-name">@Loc[tool.NameKey]</span>
                            <span class="ti-item-desc">@Loc[tool.DescriptionKey]</span>
                        </div>
                    }
                </div>
            }
            @if (_groupedTools.Count == 0)
            {
                <div class="ti-empty">@Loc["editor_tool_instantiate.no_tools"]</div>
            }
        </div>
    }
    else
    {
        <button class="ti-btn" @onclick="() => _showPicker = true">
            @(_selectedToolName != null ? Loc["editor_tool_instantiate.change_tool"] : Loc["editor_tool_instantiate.choose_tool"])
        </button>
    }
</div>

@code {
    [Parameter] public IGenerationNode Node { get; set; } = default!;
    [Parameter] public EventCallback<IGenerationNode> OnChanged { get; set; }
    [Parameter] public Action<IGenerationNode>? RemoveMe { get; set; }

    private ToolInstantiateNode? _typedNode;
    private bool _showPicker = true;
    private string? _selectedToolName;
    private Dictionary<string, List<ToolMetadata>> _groupedTools = new();

    protected override void OnInitialized()
    {
        _typedNode = Node as ToolInstantiateNode;
        if (_typedNode == null)
            return;

        _groupedTools = ToolRegistry.AllTools
            .OrderBy(t => string.Join("/", t.CategoryKeys)).ThenBy(t => t.NameKey)
            .GroupBy(t => t.CategoryKeys is { Length: > 0 } ? string.Join("/", t.CategoryKeys) : "category.other")
            .ToDictionary(g => g.Key, g => g.ToList());

        if (!string.IsNullOrEmpty(_typedNode.ToolTypeName))
        {
            var match = _groupedTools.Values
                .SelectMany(g => g)
                .FirstOrDefault(t => t.TypeName == _typedNode.ToolTypeName);
            if (match != null)
            {
                _selectedToolName = match.NameKey;
                _showPicker = false;
            }
        }
    }

    private void SelectTool(ToolMetadata tool)
    {
        if (_typedNode == null) return;
        _typedNode.ToolTypeName = tool.TypeName;
        _selectedToolName = tool.NameKey;
        _showPicker = false;
        OnChanged.InvokeAsync(Node);
    }

    private void ClearSelection()
    {
        if (_typedNode == null) return;
        _typedNode.ToolTypeName = "";
        _selectedToolName = null;
        _showPicker = true;
        OnChanged.InvokeAsync(Node);
    }
}

