@using Newtonsoft.Json
@using ShimmerChatLib
@using ShimmerChatLib.Generation
@inject IKVDataService KVData
@inject ILocService Loc

<div class="api-select-editor">
    <div class="ge-field">
        <label class="ge-label" title="@Loc["node.api_select.tooltip"]">
            @Loc["node.api_select.label"]
        </label>
        <div class="ge-value">
            <select class="ge-select" @bind="SelectedGuid" @bind:event="onchange"
                    style="width: 100%; max-width: 400px;">
                <option value="">@Loc["node.api_select.global_default"]</option>
                @foreach (var s in _settings)
                {
                    <option value="@s.Id.ToString()">@s.Name (@s.Type)</option>
                }
            </select>
            @if (_settings.Count == 0)
            {
                <div style="font-size: 0.75em; color: var(--su-danger); margin-top: 4px;">
                    @Loc["node.api_select.no_settings"]
                </div>
            }
            else
            {
                var selectedSetting = string.IsNullOrEmpty(SelectedGuid)
                    ? null
                    : _settings.FirstOrDefault(s => s.Id.ToString() == SelectedGuid);
                <div style="font-size: 0.72em; color: var(--su-text-1); margin-top: 4px;">
                    @(string.IsNullOrEmpty(SelectedGuid)
                        ? Loc["node.api_select.using_global"]
                        : selectedSetting != null
                            ? string.Format(Loc["node.api_select.using_format"],
                                selectedSetting.Name,
                                selectedSetting.Type,
                                selectedSetting.EnableStream
                                    ? Loc["node.api_select.streaming"]
                                    : Loc["node.api_select.non_streaming"])
                            : "")
                </div>
            }
        </div>
    </div>

    <div style="font-size: 0.72em; color: var(--su-text-1); margin-top: 8px; padding: 6px 8px; background: var(--su-surface-3); border-left: 3px solid var(--su-border-0); border-radius: 2px; line-height: 1.5;">
        @Loc["node.api_select.order_hint"]
    </div>
</div>

@code {
    [Parameter] public APISelectNode Node { get; set; } = default!;
    [Parameter] public int Depth { get; set; }
    [Parameter] public Action<ITreeNode>? CopyMe { get; set; }

    private List<ApiConfig> _settings = [];

    private string SelectedGuid
    {
        get => Node.APIGuid ?? "";
        set => Node.APIGuid = string.IsNullOrEmpty(value) ? null : value;
    }

    protected override void OnInitialized()
    {
        var json = KVData.Read("ApiSettings", "apiSetting") ?? "[]";
        _settings = JsonConvert.DeserializeObject<List<ApiConfig>>(json) ?? [];
    }
}
