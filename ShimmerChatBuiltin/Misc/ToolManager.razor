@page "/toolmanager"
@using ShimmerChatLib.Panel
@using ShimmerChatLib.Generation
@using ShimmerChatBuiltin.Generation.Nodes
@attribute [PluginPanelAttribute("panel.tool_manager", "panel.tool_manager.desc", PanelDisplayPlace.Settings, Order = 2)]

@inject IKVDataService KVData
@inject IStringLocalizer<ToolManager> l
@inject IToolRegistry ToolRegistry
@inject ILocService Loc

<h3>Tool Manager</h3>

@if (_loading)
{
    <p>Loading...</p>
}
else
{
    <div class="shimmer-group" style="margin-top:16px;">
        <h5>Tool Preset</h5>
        <div style="display:flex;gap:8px;align-items:center;margin-bottom:8px;">
            <select class="form-select" style="max-width:300px;" @bind="_selectedPresetName">
                <option value="">-- New preset --</option>
                @foreach (var name in _presetNames)
                {
                    <option value="@name">@name</option>
                }
            </select>
            <button class="btn btn-primary btn-sm" @onclick="CreatePreset">Save As</button>
            <button class="btn btn-outline-danger btn-sm" @onclick="DeletePreset"
                    disabled="@(string.IsNullOrEmpty(_selectedPresetName) || _selectedPresetName == DefaultPresetName)">Delete</button>
        </div>
        @if (!string.IsNullOrEmpty(_status))
        {
            <div class="alert @(_status.Contains("Error") ? "alert-danger" : "alert-success")" style="padding:4px 8px;font-size:0.85em;">@_status</div>
        }
    </div>

    <div class="shimmer-group" style="margin-top:16px;">
        <h5>Available Tools</h5>
        <p class="text-muted" style="font-size:0.85em;">Enable tools here, then use <strong>Tool Preset</strong> node in Generation Manager to load them.</p>

        @foreach (var group in _groupedTools)
        {
            <div class="tm-group">
                <div class="tm-group-header">
                    <span class="tm-group-icon">@(group.Key.Contains('/') ? "▸" : "▾")</span>
                    <span class="tm-group-name">@string.Join(" / ", group.Key.Split('/').Select(k => Loc[k.Trim()]))</span>
                    <span class="tm-group-count">@group.Value.Count</span>
                </div>
                @foreach (var tool in group.Value)
                {
                    <div class="tm-row">
                        <div>
                            <input type="checkbox" checked="@_enabledTools.Contains(tool.NameKey)"
                                   @onchange="e => ToggleTool(tool.NameKey, (bool)(e.Value ?? false))" />
                        </div>
                        <div class="tm-name">@Loc[tool.NameKey]</div>
                        <div class="tm-desc">@Loc[tool.DescriptionKey]</div>
                    </div>
                }
            </div>
        }
        @if (_groupedTools.Count == 0)
        {
            <div class="tm-row"><div colspan="3" style="color:#888;">No tools discovered.</div></div>
        }
    </div>
}

@code {
    private const string DefaultPresetName = "_default_";

    private bool _loading = true;
    private Dictionary<string, List<ToolMetadata>> _groupedTools = new();
    private HashSet<string> _enabledTools = new();
    private List<string> _presetNames = new();
    private string _selectedPresetName = "";
    private string _status = "";

    protected override void OnInitialized()
    {
        _groupedTools = ToolRegistry.AllTools
            .OrderBy(t => string.Join("/", t.CategoryKeys)).ThenBy(t => t.NameKey)
            .GroupBy(t => t.CategoryKeys is { Length: > 0 } ? string.Join("/", t.CategoryKeys) : "category.other")
            .ToDictionary(g => g.Key, g => g.ToList());
        LoadPresets();
        EnsureDefaultPreset();
        _loading = false;
    }

    private void LoadPresets()
    {
        var json = KVData.Read("ToolPresets", "__presets__");
        var persistedNames = string.IsNullOrEmpty(json)
            ? new List<string>()
            : Newtonsoft.Json.JsonConvert.DeserializeObject<List<string>>(json) ?? new();
        // 移除旧版可能持久化的默认预设名，改为每次启动从代码重建
        _presetNames = persistedNames.Where(n => n != DefaultPresetName).ToList();

        if (string.IsNullOrEmpty(_selectedPresetName) && _presetNames.Count > 0)
        {
            _selectedPresetName = _presetNames[0];
            LoadPreset(_selectedPresetName);
        }
    }

    /// <summary>每次启动重建默认预设，包含所有可用工具</summary>
    private void EnsureDefaultPreset()
    {
        var allToolNames = ToolRegistry.AllTools.Select(t => t.NameKey).ToList();
        var defaultPreset = new ToolPreset { Name = DefaultPresetName, EnabledToolTypeNames = allToolNames };
        // 写入 KVData 供 ToolPresetNode 读取
        KVData.Write("ToolPresets", DefaultPresetName,
            Newtonsoft.Json.JsonConvert.SerializeObject(defaultPreset));

        _presetNames.Insert(0, DefaultPresetName);
    }

    private void LoadPreset(string name)
    {
        var json = KVData.Read("ToolPresets", name);
        if (!string.IsNullOrEmpty(json))
        {
            var preset = Newtonsoft.Json.JsonConvert.DeserializeObject<ToolPreset>(json);
            _enabledTools = preset?.EnabledToolTypeNames?.ToHashSet() ?? new();
        }
    }

    private void CreatePreset()
    {
        var name = string.IsNullOrEmpty(_selectedPresetName) ? "Default" : _selectedPresetName;
        var preset = new ToolPreset { Name = name, EnabledToolTypeNames = _enabledTools.ToList() };
        KVData.Write("ToolPresets", name,
            Newtonsoft.Json.JsonConvert.SerializeObject(preset));

        if (!_presetNames.Contains(name))
            _presetNames.Add(name);
        SavePresetNames();

        _selectedPresetName = name;
        _status = $"Saved: {name} ({_enabledTools.Count} tools)";
    }

    private void DeletePreset()
    {
        if (string.IsNullOrEmpty(_selectedPresetName)) return;
        if (_selectedPresetName == DefaultPresetName)
        {
            _status = "Cannot delete the default preset.";
            return;
        }
        _presetNames.Remove(_selectedPresetName);
        SavePresetNames();
        _selectedPresetName = "";
        _enabledTools.Clear();
        _status = "Preset deleted.";
    }

    /// <summary>持久化预设名称列表，排除每次启动重建的默认预设</summary>
    private void SavePresetNames()
    {
        KVData.Write("ToolPresets", "__presets__",
            Newtonsoft.Json.JsonConvert.SerializeObject(
                _presetNames.Where(n => n != DefaultPresetName).ToList()));
    }

    private void ToggleTool(string name, bool enabled)
    {
        if (enabled) _enabledTools.Add(name);
        else _enabledTools.Remove(name);
    }
}

<style>
.tm-group { margin-bottom: 12px; }
.tm-group-header { display: flex; align-items: center; gap: 6px; padding: 5px 8px; background: rgba(255,255,255,0.03); border-radius: 4px 4px 0 0; border-bottom: 1px solid rgba(255,255,255,0.06); }
.tm-group-icon { font-size: 0.75em; color: #666; }
.tm-group-name { font-weight: 600; font-size: 0.82em; color: #bbb; }
.tm-group-count { font-size: 0.7em; color: #555; background: rgba(255,255,255,0.05); padding: 1px 6px; border-radius: 8px; }
.tm-row { display: grid; grid-template-columns: 60px 1fr 2fr; gap: 8px; padding: 6px 8px; align-items: center; border-bottom: 1px solid var(--color-border, rgba(255,255,255,0.05)); }
.tm-name { font-weight: 600; font-size: 0.85em; }
.tm-desc { font-size: 0.78em; color: #888; }
</style>
