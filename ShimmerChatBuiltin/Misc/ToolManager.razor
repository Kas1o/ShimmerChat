@page "/toolmanager"
@using ShimmerChatLib.Panel
@using ShimmerChatLib.Generation
@using ShimmerChatBuiltin.Generation.Nodes
@attribute [PluginPanelAttribute("Tool Manager", "Manage tools and tool presets", PanelDisplayPlace.Settings, Order = 2)]

@inject IKVDataService KVData
@inject IStringLocalizer<ToolManager> l

<h3>Tool Manager</h3>

@if (_loading)
{
    <p>Loading...</p>
}
else
{
    <div class="shimmer-group" style="margin-top:16px;">
        <h5>Tool Preset</h5>
        <div style="display:flex;gap:8px;align-items:center;margin-bottom:8px;">
            <select class="form-select" style="max-width:300px;" @bind="_selectedPresetName">
                <option value="">-- New preset --</option>
                @foreach (var name in _presetNames)
                {
                    <option value="@name">@name</option>
                }
            </select>
            <button class="btn btn-primary btn-sm" @onclick="CreatePreset">Save As</button>
            <button class="btn btn-outline-danger btn-sm" @onclick="DeletePreset"
                    disabled="@(string.IsNullOrEmpty(_selectedPresetName))">Delete</button>
        </div>
        @if (!string.IsNullOrEmpty(_status))
        {
            <div class="alert @(_status.Contains("Error") ? "alert-danger" : "alert-success")" style="padding:4px 8px;font-size:0.85em;">@_status</div>
        }
    </div>

    <div class="shimmer-group" style="margin-top:16px;">
        <h5>Available Tools</h5>
        <p class="text-muted" style="font-size:0.85em;">Enable tools here, then use <strong>Tool Preset</strong> node in Generation Manager to load them.</p>
        <div class="tm-table">
            <div class="tm-header tm-row">
                <div>Enabled</div>
                <div>Name</div>
                <div>Description</div>
            </div>
            @foreach (var toolInfo in _allTools)
            {
                <div class="tm-row">
                    <div>
                        <input type="checkbox" checked="@_enabledTools.Contains(toolInfo.Name)"
                               @onchange="e => ToggleTool(toolInfo.Name, (bool)(e.Value ?? false))" />
                    </div>
                    <div class="tm-name">@toolInfo.Name</div>
                    <div class="tm-desc">@toolInfo.Description</div>
                </div>
            }
            @if (_allTools.Count == 0)
            {
                <div class="tm-row"><div colspan="3" style="color:#888;">No tools discovered.</div></div>
            }
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private List<(string Name, string Description)> _allTools = new();
    private HashSet<string> _enabledTools = new();
    private List<string> _presetNames = new();
    private string _selectedPresetName = "";
    private string _status = "";

    protected override void OnInitialized()
    {
        DiscoverTools();
        LoadPresets();
        _loading = false;
    }

    private void DiscoverTools()
    {
        _allTools.Clear();
        foreach (var asm in AppDomain.CurrentDomain.GetAssemblies())
        {
            if (asm.IsDynamic) continue;
            try
            {
                foreach (var type in asm.GetExportedTypes())
                {
                    if (typeof(IToolV2).IsAssignableFrom(type) && !type.IsAbstract && !type.IsInterface)
                    {
                        try
                        {
                            var instance = (IToolV2)Activator.CreateInstance(type)!;
                            _allTools.Add((instance.Name, instance.Description));
                        }
                        catch { }
                    }
                }
            }
            catch { }
        }
        _allTools = _allTools.OrderBy(t => t.Name).ToList();
    }

    private void LoadPresets()
    {
        var json = KVData.Read("ToolPresets", "__presets__");
        _presetNames = string.IsNullOrEmpty(json)
            ? new()
            : Newtonsoft.Json.JsonConvert.DeserializeObject<List<string>>(json) ?? new();

        if (string.IsNullOrEmpty(_selectedPresetName) && _presetNames.Count > 0)
        {
            _selectedPresetName = _presetNames[0];
            LoadPreset(_selectedPresetName);
        }
    }

    private void LoadPreset(string name)
    {
        var json = KVData.Read("ToolPresets", name);
        if (!string.IsNullOrEmpty(json))
        {
            var preset = Newtonsoft.Json.JsonConvert.DeserializeObject<ToolPreset>(json);
            _enabledTools = preset?.EnabledToolTypeNames?.ToHashSet() ?? new();
        }
    }

    private void CreatePreset()
    {
        var name = string.IsNullOrEmpty(_selectedPresetName) ? "Default" : _selectedPresetName;
        var preset = new ToolPreset { Name = name, EnabledToolTypeNames = _enabledTools.ToList() };
        KVData.Write("ToolPresets", name,
            Newtonsoft.Json.JsonConvert.SerializeObject(preset));

        if (!_presetNames.Contains(name))
            _presetNames.Add(name);
        KVData.Write("ToolPresets", "__presets__",
            Newtonsoft.Json.JsonConvert.SerializeObject(_presetNames));

        _selectedPresetName = name;
        _status = $"Saved: {name} ({_enabledTools.Count} tools)";
    }

    private void DeletePreset()
    {
        if (string.IsNullOrEmpty(_selectedPresetName)) return;
        _presetNames.Remove(_selectedPresetName);
        KVData.Write("ToolPresets", "__presets__",
            Newtonsoft.Json.JsonConvert.SerializeObject(_presetNames));
        _selectedPresetName = "";
        _enabledTools.Clear();
        _status = "Preset deleted.";
    }

    private void ToggleTool(string name, bool enabled)
    {
        if (enabled) _enabledTools.Add(name);
        else _enabledTools.Remove(name);
    }
}

<style>
.tm-table { width: 100%; border-collapse: collapse; }
.tm-row { display: grid; grid-template-columns: 60px 1fr 2fr; gap: 8px; padding: 6px 8px; align-items: center; border-bottom: 1px solid var(--color-border, rgba(255,255,255,0.05)); }
.tm-header { font-weight: 700; font-size: 0.85em; color: #aaa; border-bottom-width: 2px; }
.tm-name { font-weight: 600; font-size: 0.85em; }
.tm-desc { font-size: 0.78em; color: #888; }
</style>
