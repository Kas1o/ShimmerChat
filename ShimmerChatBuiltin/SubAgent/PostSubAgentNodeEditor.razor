@using Newtonsoft.Json
@using ShimmerChatBuiltin.SubAgent
@inject ShimmerChatLib.Interface.IKVDataService KVData
@inject ILocService Loc

@if (Node != null)
{
    <div class="subagent-editor">
        <div class="ge-field">
            <label class="ge-label" title="@Loc["editor_subagent.select_hint"]">
                @Loc["editor_subagent.label"]
            </label>
            <div class="ge-value">
                <select class="ge-select" value="@Node.ConfigGuid" @onchange="OnConfigChanged"
                        style="width: 100%; max-width: 400px;">
                    <option value="">@Loc["editor_subagent.select_option"]</option>
                    @foreach (var cfg in _configs)
                    {
                        <option value="@cfg.Guid.ToString()">@cfg.Name</option>
                    }
                </select>
                @if (_configs.Count == 0)
                {
                    <div style="font-size: 0.75em; color: #e66; margin-top: 4px;">
                        @Loc["editor_subagent.no_configs"]
                    </div>
                }
                else if (!string.IsNullOrEmpty(Node.ConfigGuid))
                {
                    var selected = _configs.FirstOrDefault(c => c.Guid.ToString() == Node.ConfigGuid);
                    if (selected != null)
                    {
                        <div style="font-size: 0.72em; color: #666; margin-top: 4px;">
                            @Loc.Format("editor_subagent.output_label", selected.OutputMode)
                            @if (selected.UseSharedPreset)
                            {
                                <span>@Loc.Format("editor_subagent.preset_label", string.IsNullOrEmpty(selected.ModifierPresetId) ? Loc["editor_subagent.none"] : selected.ModifierPresetId)</span>
                            }
                            else
                            {
                                <span>@Loc["editor_subagent.private_tree_label"]</span>
                            }
                        </div>
                    }
                }
            </div>
        </div>

        <div class="ge-field">
            <label class="ge-label" title="@Loc["prop.post_sub_agent.output_mode.hint"]">
                @Loc["prop.post_sub_agent.output_mode"]
            </label>
            <div class="ge-value">
                <select class="ge-select" @bind="Node.OutputMode" style="width: 100%; max-width: 400px;">
                    <option value="">@Loc["editor_subagent.inherit_option"]</option>
                    <option value="LastMessage">LastMessage</option>
                    <option value="FullJson">FullJson</option>
                    <option value="None">None</option>
                </select>
            </div>
        </div>

        <div class="ge-field">
            <label class="ge-label" title="@Loc["prop.post_sub_agent.max_iterations.hint"]">
                @Loc["prop.post_sub_agent.max_iterations"]
            </label>
            <div class="ge-value">
                <input type="number" class="ge-input ge-input-num"
                       value="@Node.MaxIterations"
                       @onchange="OnMaxIterationsChanged"
                       style="max-width: 120px;" />
            </div>
        </div>

        <div class="ge-field">
            <label class="ge-label" title="@Loc["prop.post_sub_agent.include_full_context.hint"]">
                @Loc["prop.post_sub_agent.include_full_context"]
            </label>
            <div class="ge-value">
                <input type="checkbox" class="ge-check"
                       checked="@Node.IncludeFullContext"
                       @onchange="OnIncludeFullContextChanged" />
            </div>
        </div>

        <div class="ge-field">
            <label class="ge-label" title="@Loc["prop.post_sub_agent.shared_guid.hint"]">
                @Loc["prop.post_sub_agent.shared_guid"]
            </label>
            <div class="ge-value">
                <input type="checkbox" class="ge-check"
                       checked="@Node.SharedGuid"
                       @onchange="OnSharedGuidChanged" />
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public PostSubAgentNode Node { get; set; } = default!;
    [Parameter] public int Depth { get; set; }
    [Parameter] public Action<ITreeNode>? CopyMe { get; set; }

    private List<SubAgentConfig> _configs = [];

    protected override void OnInitialized()
    {
        var json = KVData.Read("SubAgent", "configs");
        _configs = JsonConvert.DeserializeObject<List<SubAgentConfig>>(json ?? "[]") ?? [];
    }

    private void OnConfigChanged(ChangeEventArgs e)
    {
        Node.ConfigGuid = e.Value?.ToString() ?? "";
    }

    private void OnMaxIterationsChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
            Node.MaxIterations = val;
    }

    private void OnIncludeFullContextChanged(ChangeEventArgs e)
    {
        Node.IncludeFullContext = (bool)(e.Value ?? false);
    }

    private void OnSharedGuidChanged(ChangeEventArgs e)
    {
        Node.SharedGuid = (bool)(e.Value ?? false);
    }
}
