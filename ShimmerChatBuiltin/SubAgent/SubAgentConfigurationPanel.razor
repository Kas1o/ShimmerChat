@attribute [PluginPanel("SubAgentConfiguration", "Configure sub-agents for advanced Agentic workflows", PanelDisplayPlace.Settings)]

@using ShimmerChatLib.Generation
@using ShimmerChatLib.Interface
@using ShimmerChatBuiltin.SubAgent
@using ShimmerChatLib
@using Newtonsoft.Json

@inject IKVDataService pluginData



<div class="shimmer-content p-4">
    <h2>SubAgent Configuration</h2>
    <p class="text-muted">Configure sub-agents for use with the SubAgentGeneration context modifier.</p>

    <div class="shimmer-group">
        <div class="d-flex gap-3 mt-3 align-items-center flex-wrap">
            <input type="text" class="shimmer-input" @bind="newConfigName" placeholder="New sub-agent name" />
            <button class="btn btn-primary" @onclick="CreateNewConfig" disabled="@string.IsNullOrWhiteSpace(newConfigName)">
                Create
            </button>
        </div>
    </div>

    <div class="shimmer-group mt-4">
        <h4>Existing Sub-Agents (@configs.Count)</h4>
        @if (configs.Count == 0)
        {
            <p class="text-muted">No sub-agents configured yet.</p>
        }
        else
        {
            <div style="display:flex; flex-wrap:wrap; gap:12px; margin-top:12px;">
                @foreach (var cfg in configs)
                {
                    <div class="card p-3 cursor-pointer @(selectedConfig == cfg ? "border-primary shadow-md" : "")"
                         style="min-width:200px;"
                         @onclick="() => SelectConfig(cfg)">
                        <div class="d-flex justify-content-between w-100">
                            <strong>@cfg.Name</strong>
                            <button class="btn btn-sm bg-danger text-white" @onclick:stopPropagation
                                    @onclick="async () => await DeleteConfig(cfg)" title="Delete">
                                X
                            </button>
                        </div>
                        <div class="text-sm text-muted mt-1">
                            API: @(GetApiName(cfg.SelectedApiIndex))
                        </div>
                        <div class="text-sm text-muted">
                            Tools: @cfg.EnabledToolNames.Count | Preset: @GetPresetName(cfg) | Output: @cfg.OutputMode
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @if (selectedConfig != null)
    {
        <div class="shimmer-group mt-4">
            <h3>Edit: @selectedConfig.Name</h3>

            <div class="mt-3">
                <label><strong>Name</strong></label>
                <input type="text" class="shimmer-input" @bind="selectedConfig.Name" />
            </div>

            <div class="mt-3">
                <label><strong>API Setting</strong></label>
                <select class="form-select" @bind="selectedConfig.SelectedApiIndex">
                    <option value="-1">Inherit Global</option>
                    @for (int i = 0; i < apiSettings.Count; i++)
                    {
                        <option value="@i">@apiSettings[i].Name (@apiSettings[i].Type)</option>
                    }
                </select>
            </div>

            <div class="mt-3">
                <label><strong>Output Mode</strong></label>
                <select class="form-select" @bind="selectedConfig.OutputMode">
                    <option value="LastMessage">Last Message (text only)</option>
                    <option value="FullJson">Full JSON (serialized interaction)</option>
                    <option value="None">None (no output returned)</option>
                </select>
                <p class="text-sm text-muted mt-1">
                    <em>Last Message: returns only the final AI message text. Full JSON: serializes the entire sub-agent interaction (AI + tool calls + results). None: sub-agent executes silently, no output is returned to parent.</em>
                </p>
            </div>

            <div class="mt-4">
                <h5>Tools</h5>
                <p class="text-sm text-muted">Select tools available to this sub-agent.</p>
                <div style="display:flex; flex-wrap:wrap; gap:8px;">
                    @foreach (var toolName in GetAvailableToolNames())
                    {
                        var isChecked = selectedConfig.EnabledToolNames.Contains(toolName);
                        <label class="d-flex align-items-center gap-1" style="cursor:pointer;">
                            <input type="checkbox" checked="@isChecked"
                                   @onchange="e => ToggleTool(toolName, (bool)(e.Value ?? false))" />
                            @toolName
                        </label>
                    }
                </div>
                @if (GetAvailableToolNames().Count == 0)
                {
                    <p class="text-muted">No tools available.</p>
                }
            </div>

            <div class="mt-4">
                <h5>Context Modifiers</h5>

                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" role="switch"
                           id="useSharedPresetSwitch"
                           checked="@selectedConfig.UseSharedPreset"
                           @onchange="e => TogglePresetMode((bool)(e.Value ?? false))" />
                    <label class="form-check-label" for="useSharedPresetSwitch">
                        <strong>Use Shared Preset</strong>
                    </label>
                </div>

                @if (selectedConfig.UseSharedPreset)
                {
                    <p class="text-sm text-muted">Select a shared context modifier preset.</p>
                    <select class="form-select mt-2" @bind="selectedConfig.ModifierPresetId" style="max-width: 400px;">
                        <option value="">— None —</option>
                        @foreach (var preset in GetPresets())
                        {
                            <option value="@preset.Id">@preset.Name</option>
                        }
                    </select>
                }
                else
                {
                    <p class="text-sm text-muted">
                        ShimmerChat 2.0: Independent modifiers are being redesigned.
                        Use the Generation Manager to configure presets.
                    </p>
                }
            </div>

            <div class="mt-4">
                <h5>Plugins</h5>
                <PluginPanelContainer
                    PanelDisplayPlace="PanelDisplayPlace.Agent"
                    Parameters="SubAgentPluginParameters" />
            </div>

            <div class="mt-4">
                <button class="btn btn-primary" @onclick="SaveAll" disabled="@isLoading">
                    @(isLoading ? "Saving..." : "Save All")
                </button>
                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <span class="ms-3 @(statusType == "success" ? "text-success" : "text-danger")">
                        @statusMessage
                    </span>
                }
            </div>
        </div>
    }
</div>

@code {
    List<SubAgentConfig> configs = [];
    SubAgentConfig? selectedConfig;
    string newConfigName = "";
    bool isLoading;
    string statusMessage = "";
    string statusType = "success";

    List<ApiSetting> apiSettings = [];

    protected override void OnInitialized()
    {
        LoadConfigs();
        LoadApiSettings();
    }

    static readonly JsonSerializerSettings _configSerializerSettings = new()
    {
        TypeNameHandling = TypeNameHandling.Auto
    };

    void LoadConfigs()
    {
        var json = pluginData.Read("SubAgent", "configs");
        try
        {
            configs = JsonConvert.DeserializeObject<List<SubAgentConfig>>(json ?? "[]", _configSerializerSettings) ?? [];
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Deserialization with TypeNameHandling failed, trying legacy format: {ex.Message}");
            try
            {
                configs = JsonConvert.DeserializeObject<List<SubAgentConfig>>(json ?? "[]") ?? [];
            }
            catch (Exception ex2)
            {
                Console.WriteLine($"Legacy deserialization also failed: {ex2.Message}");
                configs = [];
            }
        }
    }

    void LoadApiSettings()
    {
        var json = pluginData.Read("ApiSettings", "apiSetting") ?? "[]";
        apiSettings = JsonConvert.DeserializeObject<List<ApiSetting>>(json) ?? [];
    }

    string GetPresetName(SubAgentConfig cfg)
    {
        if (!cfg.UseSharedPreset)
            return $"Independent ({cfg.IndependentModifiers.Count})";
        if (string.IsNullOrEmpty(cfg.ModifierPresetId))
            return "None";
        var preset = GetPresets().FirstOrDefault(p => p.Id == cfg.ModifierPresetId);
        return preset?.Name ?? "—";
    }

    string GetApiName(int index)
    {
        if (index == -1)
            return "Inherit Global";
        if (index >= 0 && index < apiSettings.Count)
            return apiSettings[index].Name;
        return "Default";
    }

    void CreateNewConfig()
    {
        if (string.IsNullOrWhiteSpace(newConfigName))
            return;

        var config = new SubAgentConfig { Name = newConfigName.Trim() };
        configs.Add(config);
        selectedConfig = config;
        newConfigName = "";
    }

    void SelectConfig(SubAgentConfig config)
    {
        selectedConfig = config;
    }

    async Task DeleteConfig(SubAgentConfig config)
    {
        configs.Remove(config);
        if (selectedConfig == config)
            selectedConfig = null;
        await SaveConfigsAsync();
    }

    void ToggleTool(string toolName, bool isChecked)
    {
        if (selectedConfig == null) return;
        if (isChecked && !selectedConfig.EnabledToolNames.Contains(toolName))
            selectedConfig.EnabledToolNames.Add(toolName);
        else if (!isChecked)
            selectedConfig.EnabledToolNames.Remove(toolName);
    }

    async Task SaveConfigsAsync()
    {
        try
        {
            var json = JsonConvert.SerializeObject(configs, Formatting.Indented, _configSerializerSettings);
            pluginData.Write("SubAgent", "configs", json);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Save configs failed: {ex.Message}");
        }
    }

    async void SaveAll()
    {
        try
        {
            isLoading = true;
            await SaveConfigsAsync();
            ShowStatus("Saved successfully", "success");
        }
        catch (Exception ex)
        {
            ShowStatus($"Save failed: {ex.Message}", "error");
        }
        finally
        {
            isLoading = false;
        }
    }

    async void ShowStatus(string message, string type)
    {
        statusMessage = message;
        statusType = type;
        StateHasChanged();
        await Task.Delay(3000);
        statusMessage = "";
        StateHasChanged();
    }

    bool _showIndependentEditor;

    private Dictionary<string, object> SubAgentPluginParameters => new()
    {
        ["AgentGuid"] = selectedConfig?.Guid ?? Guid.Empty,
        ["EventHandlerReg"] = (Action<IChatPanelEventHandler>)(handler => { })
    };

    void TogglePresetMode(bool useShared)
    {
        if (selectedConfig == null) return;
        selectedConfig.UseSharedPreset = useShared;
    }

    void OnIndependentPresetChanged(GenerationPreset changed)
    {
        if (selectedConfig == null) return;
        // ShimmerChat 2.0: independent modifiers are stored as a list of modifier names
        selectedConfig.IndependentModifiers = new();
    }

    // ShimmerChat 2.0: direct scan for IToolV2 implementations
    private static List<string> GetAvailableToolNames()
    {
        var names = new List<string>();
        foreach (var asm in AppDomain.CurrentDomain.GetAssemblies())
        {
            if (asm.IsDynamic) continue;
            try
            {
                foreach (var type in asm.GetExportedTypes())
                {
                    if (typeof(IAutoCreateToolV2).IsAssignableFrom(type) && !type.IsAbstract && !type.IsInterface)
                    {
                        try
                        {
                            var nameProp = type.GetProperty("Name",
                                System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.Static);
                            if (nameProp != null)
                                names.Add((string)nameProp.GetValue(null)!);
                        }
                        catch { }
                    }
                }
            }
            catch { }
        }
        return names.OrderBy(n => n).ToList();
    }

    private List<GenerationPreset> GetPresets()
    {
        var json = pluginData.Read("GenerationManager", "generation_presets");
        return string.IsNullOrEmpty(json)
            ? new()
            : Newtonsoft.Json.JsonConvert.DeserializeObject<List<GenerationPreset>>(json) ?? new();
    }
}
