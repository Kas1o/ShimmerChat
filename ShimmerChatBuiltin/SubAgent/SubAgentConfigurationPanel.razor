@attribute [PluginPanel("panel.sub_agent_config", "panel.sub_agent_config.desc", PanelDisplayPlace.Settings)]

@using ShimmerChatLib.Components
@using ShimmerChatLib.Generation
@using ShimmerChatLib.Interface
@using ShimmerChatBuiltin.SubAgent
@using ShimmerChatBuiltin.Generation.Nodes
@using Newtonsoft.Json

@inject IKVDataService pluginData
@inject IPreGenerationNodeSerializer Serializer
@inject IPostGenerationNodeSerializer PostSerializer
@inject ILocService Loc



<div class="shimmer-content su-p-4">
    <h2>@Loc["panel_subagent.title"]</h2>
    <p class="su-text-2">@Loc["panel_subagent.desc"]</p>

    <div class="su-group">
        <div class="su-flex su-gap-3 su-mt-3 su-items-center su-flex-wrap">
            <input type="text" class="shimmer-input" @bind="newConfigName" placeholder="@Loc["panel_subagent.name_placeholder"]" />
            <button class="su-btn su-btn-primary" @onclick="CreateNewConfig" disabled="@string.IsNullOrWhiteSpace(newConfigName)">
                @Loc["panel_subagent.create"]
            </button>
        </div>
    </div>

    <div class="su-group su-mt-4">
        <h4>@Loc["panel_subagent.existing"] (@configs.Count)</h4>
        @if (configs.Count == 0)
        {
            <p class="su-text-2">@Loc["panel_subagent.no_subagents"]</p>
        }
        else
        {
            <div style="display:flex; flex-wrap:wrap; gap:12px; margin-top:12px;">
                @foreach (var cfg in configs)
                {
                    <div class="su-card su-p-3 su-cursor-pointer @(selectedConfig == cfg ? "su-border-top su-shadow-md" : "")"
                         style="min-width:200px;"
                         @onclick="() => SelectConfig(cfg)">
                        <div class="su-flex su-justify-between su-w-full">
                            <strong>@cfg.Name</strong>
                            <button class="su-btn su-btn-sm" @onclick:stopPropagation
                                    @onclick="async () => await DeleteConfig(cfg)" title="@Loc["panel_subagent.delete"]">
                                X
                            </button>
                        </div>
                        <div class="su-text-sm su-text-2 su-mt-1">
                            @Loc.Format("panel_subagent.preset_summary", GetPresetName(cfg), cfg.OutputMode)
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @if (selectedConfig != null)
    {
        <div class="su-group mt-4">
            <h3>@Loc.Format("panel_subagent.edit_title", selectedConfig.Name)</h3>

            <div class="mt-3">
                <label><strong>@Loc["panel_subagent.label_name"]</strong></label>
                <input type="text" class="shimmer-input" @bind="selectedConfig.Name" />
            </div>

            <div class="mt-3">
                <label><strong>@Loc["panel_subagent.label_output_mode"]</strong></label>
                <select class="su-select" @bind="selectedConfig.OutputMode">
                    <option value="LastMessage">@Loc["panel_subagent.output_last_msg"]</option>
                    <option value="FullJson">@Loc["panel_subagent.output_full_json"]</option>
                    <option value="None">@Loc["panel_subagent.output_none"]</option>
                </select>
                <p class="su-text-sm su-text-2 su-mt-1">
                    <em>@Loc["panel_subagent.output_help"]</em>
                </p>
            </div>

            <div class="mt-4">
                <h5>@Loc["panel_subagent.modifier_tree"]</h5>

                @if (selectedConfig.UseSharedPreset)
                {
                    <div class="gen-config-status mb-2">
                        <span class="gen-config-badge preset">@Loc["panel_subagent.using_preset"]</span>
                        <span class="gen-config-hint">@Loc["panel_subagent.select_preset_hint"]</span>
                    </div>
                    <div style="display:flex; gap:8px; align-items:center;">
                        <select class="su-select" style="max-width:300px;" @bind="selectedConfig.ModifierPresetId">
                            <option value="">@Loc["panel_subagent.none_option"]</option>
                            @foreach (var preset in GetPresets())
                            {
                                <option value="@preset.Id">@preset.Name</option>
                            }
                        </select>
                        <button class="su-btn su-btn-outline-primary su-btn-sm" @onclick="CreatePrivateTree">
                            <i class="bi bi-pencil"></i> @Loc["panel_subagent.create_private_tree"]
                        </button>
                    </div>
                }
                else
                {
                    @if (!string.IsNullOrEmpty(selectedConfig.ModifierTreeJson))
                    {
                        <div class="gen-config-status mb-2">
                            <span class="gen-config-badge private">@Loc["panel_subagent.private_tree"]</span>
                            <span class="gen-config-hint">@Loc["panel_subagent.private_tree_hint"]</span>
                        </div>
                        <div style="display:flex; gap:8px; margin-bottom: 12px;">
                            <button class="su-btn su-btn-outline su-btn-sm" @onclick="RevertToPreset">
                                <i class="bi bi-arrow-counterclockwise"></i> @Loc["panel_subagent.revert_to_preset"]
                            </button>
                            <button class="su-btn su-btn-outline-danger su-btn-sm" @onclick="ClearPrivateTree">
                                @Loc["panel_subagent.clear_private_tree"]
                            </button>
                        </div>
                        @if (_editingTree != null)
                        {
                            <div class="tree-editor-container">
                                <CascadingValue Value="_dragContext">
                                    <TreeEditor Node="@_editingTree" />
                                </CascadingValue>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="gen-config-status mb-2">
                            <span class="gen-config-badge private">@Loc["panel_subagent.minimal"]</span>
                            <span class="gen-config-hint">@Loc["panel_subagent.minimal_hint"]</span>
                        </div>
                        <button class="su-btn su-btn-outline-primary su-btn-sm" @onclick="CreatePrivateTree">
                            <i class="bi bi-pencil"></i> @Loc["panel_subagent.create_private_tree"]
                        </button>
                    }
                }
            </div>

            <div class="su-mt-4">
                <h5>@Loc["panel_subagent.post_tree"]</h5>
                <p class="su-text-sm su-text-2 su-mt-1">
                    <em>@Loc["panel_subagent.post_tree_hint"]</em>
                </p>

                @if (_editingPostTree != null)
                {
                    <div class="gen-config-status mb-2">
                        <span class="gen-config-badge private">@Loc["panel_subagent.private_tree"]</span>
                        <span class="gen-config-hint">@Loc["panel_subagent.post_tree_private_hint"]</span>
                    </div>
                    <div style="display:flex; gap:8px; margin-bottom: 12px;">
                        <button class="su-btn su-btn-outline-danger su-btn-sm" @onclick="ClearPrivatePostTree">
                            @Loc["panel_subagent.clear_private_tree"]
                        </button>
                    </div>
                    <div class="tree-editor-container">
                        <CascadingValue Value="_postDragContext">
                            <TreeEditor Node="@_editingPostTree" />
                        </CascadingValue>
                    </div>
                }
                else
                {
                    <div class="gen-config-status mb-2">
                        <span class="gen-config-badge private">@Loc["panel_subagent.minimal"]</span>
                        <span class="gen-config-hint">@Loc["panel_subagent.post_tree_minimal_hint"]</span>
                    </div>
                    <button class="su-btn su-btn-outline-primary su-btn-sm" @onclick="CreatePrivatePostTree">
                        <i class="bi bi-pencil"></i> @Loc["panel_subagent.create_private_post_tree"]
                    </button>
                }
            </div>

            <div class="su-mt-4">
                <h5>@Loc["panel_subagent.plugins"]</h5>
                <PluginPanelContainer
                    PanelDisplayPlace="PanelDisplayPlace.Agent"
                    Parameters="SubAgentPluginParameters" />
            </div>

            <div class="su-mt-4">
                <button class="su-btn su-btn-primary" @onclick="SaveAll" disabled="@isLoading">
                    @(isLoading ? Loc["panel_subagent.saving"] : Loc["panel_subagent.save_all"])
                </button>
                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <span class="su-ms-3 @(statusType == "success" ? "su-text-success" : "su-text-danger")">
                        @statusMessage
                    </span>
                }
            </div>
        </div>
    }
</div>


@code {
    List<SubAgentConfig> configs = [];
    SubAgentConfig? selectedConfig;
    string newConfigName = "";
    bool isLoading;
    string statusMessage = "";
    string statusType = "success";
    IPreGenerationNode? _editingTree;
    IPostGenerationNode? _editingPostTree;
    TreeDragContext _dragContext = new();
    TreeDragContext _postDragContext = new();

    protected override void OnInitialized()
    {
        LoadConfigs();
    }

    static readonly JsonSerializerSettings _configSerializerSettings = new()
    {
        TypeNameHandling = TypeNameHandling.Auto
    };

    void LoadConfigs()
    {
        var json = pluginData.Read("SubAgent", "configs");
        try
        {
            configs = JsonConvert.DeserializeObject<List<SubAgentConfig>>(json ?? "[]", _configSerializerSettings) ?? [];
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Deserialization with TypeNameHandling failed, trying legacy format: {ex.Message}");
            try
            {
                configs = JsonConvert.DeserializeObject<List<SubAgentConfig>>(json ?? "[]") ?? [];
            }
            catch (Exception ex2)
            {
                Console.WriteLine($"Legacy deserialization also failed: {ex2.Message}");
                configs = [];
            }
        }
    }

    string GetPresetName(SubAgentConfig cfg)
    {
        if (!cfg.UseSharedPreset)
            return !string.IsNullOrEmpty(cfg.ModifierTreeJson) ? Loc["panel_subagent.private_tree"] : Loc["panel_subagent.minimal"];
        if (string.IsNullOrEmpty(cfg.ModifierPresetId))
            return Loc["panel_subagent.none_option_fallback"];
        var preset = GetPresets().FirstOrDefault(p => p.Id == cfg.ModifierPresetId);
        return preset?.Name ?? Loc["panel_subagent.none_option_fallback"];
    }

    void CreateNewConfig()
    {
        if (string.IsNullOrWhiteSpace(newConfigName))
            return;

        var config = new SubAgentConfig { Name = newConfigName.Trim() };
        configs.Add(config);
        selectedConfig = config;
        newConfigName = "";
    }

    void SelectConfig(SubAgentConfig config)
    {
        selectedConfig = config;
        LoadEditingTree();
    }

    void LoadEditingTree()
    {
        if (selectedConfig != null && !selectedConfig.UseSharedPreset
            && !string.IsNullOrEmpty(selectedConfig.ModifierTreeJson))
        {
            _editingTree = Serializer.Deserialize(selectedConfig.ModifierTreeJson)
                ?? new SequenceNode { Name = selectedConfig.Name };
        }
        else
        {
            _editingTree = null;
        }

        if (selectedConfig != null && !string.IsNullOrEmpty(selectedConfig.PostGenerationTreeJson))
        {
            _editingPostTree = PostSerializer.Deserialize(selectedConfig.PostGenerationTreeJson)
                as IPostGenerationNode;
        }
        else
        {
            _editingPostTree = null;
        }
    }

    async Task DeleteConfig(SubAgentConfig config)
    {
        configs.Remove(config);
        if (selectedConfig == config)
            selectedConfig = null;
        await SaveConfigsAsync();
    }

    async Task SaveConfigsAsync()
    {
        try
        {
            var json = JsonConvert.SerializeObject(configs, Formatting.Indented, _configSerializerSettings);
            pluginData.Write("SubAgent", "configs", json);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Save configs failed: {ex.Message}");
        }
    }

    async void SaveAll()
    {
        try
        {
            isLoading = true;
            if (_editingTree != null && selectedConfig != null)
            {
                selectedConfig.ModifierTreeJson = Serializer.Serialize(_editingTree);
            }
            if (_editingPostTree != null && selectedConfig != null)
            {
                selectedConfig.PostGenerationTreeJson = PostSerializer.Serialize(_editingPostTree);
            }
            await SaveConfigsAsync();
            ShowStatus(Loc["panel_subagent.msg_saved"], "success");
        }
        catch (Exception ex)
        {
            ShowStatus(Loc.Format("panel_subagent.msg_save_failed", ex.Message), "error");
        }
        finally
        {
            isLoading = false;
        }
    }

    async void ShowStatus(string message, string type)
    {
        statusMessage = message;
        statusType = type;
        StateHasChanged();
        await Task.Delay(3000);
        statusMessage = "";
        StateHasChanged();
    }

    private Dictionary<string, object> SubAgentPluginParameters => new()
    {
        ["AgentGuid"] = selectedConfig?.Guid ?? Guid.Empty,
        ["EventHandlerReg"] = (Action<IChatPanelEventHandler>)(handler => { })
    };

    void CreatePrivateTree()
    {
        if (selectedConfig == null) return;
        var root = new SequenceNode
        {
            Name = $"{selectedConfig.Name} Private Tree",
            Nodes = new List<IPreGenerationNode>()
        };

        if (!string.IsNullOrEmpty(selectedConfig.ModifierPresetId))
        {
            var presets = GetPresets();
            var preset = presets.FirstOrDefault(p => p.Id == selectedConfig.ModifierPresetId);
            root.Nodes.Add(new CallNode
            {
                Name = preset?.Name ?? "Preset",
                PresetId = selectedConfig.ModifierPresetId
            });
        }

        selectedConfig.ModifierTreeJson = Serializer.Serialize(root);
        selectedConfig.UseSharedPreset = false;
        _editingTree = root;
    }

    void RevertToPreset()
    {
        if (selectedConfig == null) return;
        selectedConfig.UseSharedPreset = true;
        selectedConfig.ModifierTreeJson = null;
        _editingTree = null;
    }

    void ClearPrivateTree()
    {
        if (selectedConfig == null) return;
        selectedConfig.ModifierTreeJson = null;
        _editingTree = null;
    }

    private List<PreGenerationPreset> GetPresets()
    {
        var json = pluginData.Read("GenerationManager", "generation_presets");
        return string.IsNullOrEmpty(json)
            ? new()
            : Newtonsoft.Json.JsonConvert.DeserializeObject<List<PreGenerationPreset>>(json) ?? new();
    }

    void CreatePrivatePostTree()
    {
        if (selectedConfig == null) return;
        var root = new PostSequenceNode
        {
            Name = $"{selectedConfig.Name} Post Tree",
            Children = new List<IPostGenerationNode>()
        };
        selectedConfig.PostGenerationTreeJson = PostSerializer.Serialize(root);
        _editingPostTree = root;
    }

    void ClearPrivatePostTree()
    {
        if (selectedConfig == null) return;
        selectedConfig.PostGenerationTreeJson = null;
        _editingPostTree = null;
    }

    private List<PostGenerationPreset> GetPostPresets()
    {
        var json = pluginData.Read("PostGenerationManager", "post_generation_presets");
        return string.IsNullOrEmpty(json)
            ? new()
            : Newtonsoft.Json.JsonConvert.DeserializeObject<List<PostGenerationPreset>>(json) ?? new();
    }
}
