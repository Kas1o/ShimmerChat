@using ShimmerChatBuiltin.Variable
@using ShimmerChatLib.Panel
@using ShimmerChatLib
@using ShimmerChatLib.Interface
@inject IKVDataService KVData
@inject ILocService Loc

@attribute [PluginPanelAttribute("panel.agent_variable", "panel.agent_variable.desc", PanelDisplayPlace.Agent)]
@implements IChatPanelEventHandler

<div class="variable-panel">
    <div class="variable-actions su-mb-3">
        <div class="su-input-group">
            <span class="su-input-group-addon bi bi-plus-circle"></span>
            <input type="text" class="su-input" placeholder="@Loc["panel_agent_variable.name_placeholder"]" @bind="_newVariableName">
            <select class="su-select" style="max-width: 100px;" @bind="_newVariableType">
                <option value="String">@Loc["panel_agent_variable.type_string"]</option>
                <option value="Int">@Loc["panel_agent_variable.type_int"]</option>
                <option value="Float">@Loc["panel_agent_variable.type_float"]</option>
            </select>
            <input type="text" class="su-input" placeholder="@Loc["panel_agent_variable.value_placeholder"]" @bind="_newVariableValue">
            <button class="su-btn su-btn-primary" @onclick="AddVariable">
                <span class="bi bi-plus"></span> @Loc["panel_agent_variable.add"]
            </button>
        </div>
    </div>

    @if (_variables.Variables.Count == 0)
    {
        <div class="su-alert su-alert-info">
            <span class="bi bi-info-circle"></span> @Loc["panel_agent_variable.no_variables"]
        </div>
    }
    else
    {
        <div class="variable-list">
            @foreach (var variable in _variables.Variables)
            {
                <div class="variable-item">
                    <div class="variable-info" @onclick="() => ToggleVariableEdit(variable)">
                        <div class="variable-name">
                            <span class="bi bi-tag"></span> @variable.Name
                            <span class="su-badge">@variable.Type</span>
                        </div>
                        <div class="variable-value">
                            @if (variable.Type == VariableType.String)
                            {
                                <span class="su-text-2">"</span>@variable.StringValue<span class="su-text-2">"</span>
                            }
                            else
                            {
                                @variable.GetValueAsString()
                            }
                        </div>
                        <div class="variable-meta">
                            <small class="su-text-2">@variable.UpdatedAt</small>
                        </div>
                    </div>
                    <div class="variable-actions-item">
                        <button class="su-btn su-btn-sm su-btn-outline-danger" @onclick="() => DeleteVariable(variable)">
                            <span class="bi bi-trash"></span>
                        </button>
                    </div>
                </div>
                @if (_editingVariable?.Name == variable.Name)
                {
                    <div class="variable-edit">
                        <div class="su-input-group su-input-group-sm">
                            <span class="su-input-group-addon">@Loc["panel_agent_variable.label_value"]</span>
                            @if (variable.Type == VariableType.String)
                            {
                                <input type="text" class="su-input" @bind="_editValue">
                            }
                            else if (variable.Type == VariableType.Int)
                            {
                                <input type="number" class="su-input" @bind="_editValue">
                            }
                            else
                            {
                                <input type="number" class="su-input" step="0.1" @bind="_editValue">
                            }
                            <button class="su-btn su-btn-outline-success" @onclick="() => SaveVariable(variable)">
                                <span class="bi bi-check"></span>
                            </button>
                            <button class="su-btn su-btn-outline" @onclick="CancelEdit">
                                <span class="bi bi-x"></span>
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    }

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="su-alert su-alert-info su-mt-3">
            @_message
        </div>
    }
</div>


@code {
    [Parameter]
    public Guid AgentGuid { get; set; }

    [Parameter]
    public Action<IChatPanelEventHandler> EventHandlerReg { get; set; }

    private VariableSet _variables = new();
    private string _newVariableName = string.Empty;
    private string _newVariableType = "String";
    private string _newVariableValue = string.Empty;
    private Variable? _editingVariable;
    private string _editValue = string.Empty;
    private string _message = string.Empty;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        LoadVariables();
        EventHandlerReg?.Invoke(this);
    }

    private void LoadVariables()
    {
        _variables = VariableManager.GetAgentVariables(KVData, AgentGuid);
    }

    private void ToggleVariableEdit(Variable variable)
    {
        if (_editingVariable?.Name == variable.Name)
        {
            _editingVariable = null;
        }
        else
        {
            _editingVariable = variable;
            _editValue = variable.GetValueAsString();
        }
    }

    private void AddVariable()
    {
        if (string.IsNullOrWhiteSpace(_newVariableName))
        {
            _message = Loc["panel_agent_variable.msg_name_required"];
            return;
        }

        var type = _newVariableType switch
        {
            "Int" => VariableType.Int,
            "Float" => VariableType.Float,
            _ => VariableType.String
        };

        var value = ParseValue(_newVariableValue, type);
        if (value == null && type != VariableType.String)
        {
            _message = Loc.Format("panel_agent_variable.msg_invalid_format", type);
            return;
        }

        var variable = new Variable
        {
            Name = _newVariableName,
            Type = type,
            Scope = VariableScope.Agent
        };
        variable.SetValue(value ?? _newVariableValue);

        VariableManager.SetAgentVariable(KVData, AgentGuid, variable);

        _message = Loc.Format("panel_agent_variable.msg_var_added", _newVariableName);
        _newVariableName = string.Empty;
        _newVariableValue = string.Empty;
        LoadVariables();
    }

    private void SaveVariable(Variable variable)
    {
        if (_editingVariable == null) return;

        var value = ParseValue(_editValue, variable.Type);
        if (value == null && variable.Type != VariableType.String)
        {
            _message = Loc["panel_agent_variable.msg_invalid_value"];
            return;
        }

        variable.SetValue(value ?? _editValue);
        variable.Scope = VariableScope.Agent;
        VariableManager.SetAgentVariable(KVData, AgentGuid, variable);

        _editingVariable = null;
        _editValue = string.Empty;
        _message = Loc.Format("panel_agent_variable.msg_var_updated", variable.Name);
        LoadVariables();
    }

    private void CancelEdit()
    {
        _editingVariable = null;
        _editValue = string.Empty;
    }

    private void DeleteVariable(Variable variable)
    {
        VariableManager.RemoveAgentVariable(KVData, AgentGuid, variable.Name);
        _message = Loc.Format("panel_agent_variable.msg_var_deleted", variable.Name);
        LoadVariables();
    }

    public void OnToolCallResult(Message message)
    {
        if (message.message.Content.Contains("Variable"))
        {
            LoadVariables();
            InvokeAsync(StateHasChanged);
        }
    }

    public void OnUserMessage(Message message) { }

    public void OnAgentMessage(Message message) { }

    private object? ParseValue(string value, VariableType type)
    {
        return type switch
        {
            VariableType.Float => float.TryParse(value, out var f) ? f : null,
            VariableType.Int => int.TryParse(value, out var i) ? i : null,
            VariableType.String => value,
            _ => value
        };
    }
}
