@inject IContextModifierService ContextModifierService

<div class="shimmer-group">
    <button class="btn btn-primary" style="margin:5px" @onclick="ShowAddPopup">Add Modifier</button>

    @if (Preset.Modifiers.Any())
    {
        <h5>Active Modifiers:</h5>
        <div class="list-group" ondragover="event.preventDefault();" @ondrop="() => HandleDrop()">
            @for (int i = 0; i < Preset.Modifiers.Count; i++)
            {
                var modifier = Preset.Modifiers[i];
                var index = i;
                <div class="list-group-item d-flex justify-content-between align-items-center"
                     draggable="true"
                     @ondragstart="() => HandleDragStart(index)"
                     @ondragover="() => HandleDragOver(index)"
                     data-index="@index">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-grip-vertical" style="margin-right: 10px; cursor: move; color: #6c757d;"></i>
                        <div class="me-2">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" role="switch"
                                       id="enableSwitch_@index"
                                       checked="@modifier.IsEnabled"
                                       @onchange="(e) => ToggleModifierEnabled(index, (bool)(e.Value ?? false))" />
                                <label class="form-check-label" for="enableSwitch_@index">
                                    <strong>@modifier.Name</strong>
                                </label>
                            </div>
                            @{
                                var preview = modifier.Config?.ToString() ?? "";
                            }
                            @if (!string.IsNullOrEmpty(preview))
                            {
                                <small class="d-block text-muted">@preview</small>
                            }
                        </div>
                    </div>
                    <div>
                        <button class="btn btn-outline-primary btn-sm me-2" @onclick="() => ShowEditPopup(index)">Edit</button>
                        <button class="btn btn-danger btn-sm" @onclick="() => RemoveModifier(index)">Remove</button>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">No active modifiers</p>
    }
</div>

@if (_showAddPopup)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Context Modifier</h5>
                    <button type="button" class="btn-close" @onclick="HideAddPopup"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Select Modifier</label>
                        <select @bind="_addSelectedName" @bind:after="UpdateAddSelectedModifier" class="form-select">
                            <option value="">-- Select --</option>
                            @foreach (var mod in ContextModifierService.LoadedModifiers)
                            {
                                <option value="@mod.info.Name">@mod.info.Name - @mod.info.Description</option>
                            }
                        </select>
                    </div>

                    @if (_addSelectedModifier != null)
                    {
                        <div class="mb-3">
                            <label class="form-label">Configuration</label>
                            <ConfigEditor Config="_addCurrentConfig"
                                          Modifier="_addSelectedModifier"
                                          OnConfigChanged="OnAddConfigChanged"
                                          OnErrorsChanged="OnAddErrorsChanged" />
                        </div>

                        @if (!_addIsValid)
                        {
                            <small class="text-danger">@_addErrorMessage</small>
                        }
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="HideAddPopup">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="ConfirmAdd"
                            disabled="@(string.IsNullOrEmpty(_addSelectedName) || !_addIsValid)">
                        Add
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showEditPopup)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Context Modifier</h5>
                    <button type="button" class="btn-close" @onclick="HideEditPopup"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <strong>@_editModifierName</strong>
                        @if (_editModifier != null)
                        {
                            <small class="d-block text-muted">@_editModifier.info.Description</small>
                        }
                    </div>

                    @if (_editModifier != null)
                    {
                        <div class="mb-3">
                            <label class="form-label">Configuration</label>
                            <ConfigEditor Config="_editCurrentConfig"
                                          Modifier="_editModifier"
                                          OnConfigChanged="OnEditConfigChanged"
                                          OnErrorsChanged="OnEditErrorsChanged" />
                        </div>

                        @if (!_editIsValid)
                        {
                            <small class="text-danger">@_editErrorMessage</small>
                        }
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="HideEditPopup">Cancel</button>
                    <button type="button" class="btn btn-success" @onclick="ConfirmEdit"
                            disabled="@(!_editIsValid)">
                        Update
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public required ContextModifierPreset Preset { get; set; }

    [Parameter]
    public EventCallback<ContextModifierPreset> Changed { get; set; }

    private int _dragIndex = -1;
    private int _dropTargetIndex = -1;

    private bool _showAddPopup;
    private string? _addSelectedName;
    private IContextModifier? _addSelectedModifier;
    private ModifierConfig _addCurrentConfig = new LegacyModifierConfig { Value = "" };
    private bool _addIsValid = true;
    private string _addErrorMessage = "";

    private bool _showEditPopup;
    private int _editModifierIndex = -1;
    private string? _editModifierName;
    private IContextModifier? _editModifier;
    private ModifierConfig _editCurrentConfig = new LegacyModifierConfig { Value = "" };
    private bool _editIsValid = true;
    private string _editErrorMessage = "";

    private async Task NotifyChanged()
    {
        await Changed.InvokeAsync(Preset);
    }

    private void HandleDragStart(int index)
    {
        _dragIndex = index;
    }

    private void HandleDragOver(int index)
    {
        _dropTargetIndex = index;
    }

    private async Task HandleDrop()
    {
        if (_dragIndex == -1 || _dropTargetIndex == -1 || _dragIndex == _dropTargetIndex)
            return;

        var modifiers = Preset.Modifiers;
        var item = modifiers[_dragIndex];
        modifiers.RemoveAt(_dragIndex);
        modifiers.Insert(_dropTargetIndex, item);
        _dragIndex = -1;
        _dropTargetIndex = -1;
        await NotifyChanged();
    }

    private async Task ToggleModifierEnabled(int index, bool isEnabled)
    {
        if (index >= 0 && index < Preset.Modifiers.Count)
        {
            Preset.Modifiers[index].IsEnabled = isEnabled;
            await NotifyChanged();
        }
    }

    private async Task RemoveModifier(int index)
    {
        if (index >= 0 && index < Preset.Modifiers.Count)
        {
            Preset.Modifiers.RemoveAt(index);
            await NotifyChanged();
        }
    }

    private void UpdateAddSelectedModifier()
    {
        _addSelectedModifier = ContextModifierService.LoadedModifiers
            .FirstOrDefault(m => m.info.Name == _addSelectedName);

        if (_addSelectedModifier != null)
        {
            _addCurrentConfig = (ModifierConfig)Activator.CreateInstance(_addSelectedModifier.ConfigType)!;
        }
        else
        {
            _addCurrentConfig = new LegacyModifierConfig { Value = "" };
        }
        _addIsValid = true;
        _addErrorMessage = "";
    }

    private void ShowAddPopup()
    {
        _addSelectedName = null;
        _addSelectedModifier = null;
        _addCurrentConfig = new LegacyModifierConfig { Value = "" };
        _addIsValid = true;
        _addErrorMessage = "";
        _showAddPopup = true;
    }

    private void HideAddPopup()
    {
        _showAddPopup = false;
    }

    private async Task OnAddConfigChanged(ModifierConfig config)
    {
        _addCurrentConfig = config;
        await Task.CompletedTask;
    }

    private void OnAddErrorsChanged(Dictionary<string, string> errors)
    {
        _addIsValid = errors.Count == 0;
        _addErrorMessage = string.Join("; ", errors.Values);
    }

    private async Task ConfirmAdd()
    {
        if (!string.IsNullOrEmpty(_addSelectedName) && _addSelectedModifier != null)
        {
            Preset.Modifiers.Add(new ActivatedModifier
            {
                Name = _addSelectedName,
                Config = _addCurrentConfig,
                IsEnabled = true
            });
            await NotifyChanged();
        }
        HideAddPopup();
    }

    private void ShowEditPopup(int index)
    {
        if (index >= 0 && index < Preset.Modifiers.Count)
        {
            _editModifierIndex = index;
            var modifier = Preset.Modifiers[index];
            _editModifierName = modifier.Name;
            _editModifier = ContextModifierService.LoadedModifiers
                .FirstOrDefault(m => m.info.Name == modifier.Name);
            _editCurrentConfig = modifier.Config ?? new LegacyModifierConfig { Value = "" };

            if (_editModifier != null
                && _editModifier.ConfigType != typeof(LegacyModifierConfig)
                && _editCurrentConfig.GetType() != _editModifier.ConfigType)
            {
                _editCurrentConfig = (ModifierConfig)Activator.CreateInstance(_editModifier.ConfigType)!;
            }

            _editIsValid = true;
            _editErrorMessage = "";
            _showEditPopup = true;
        }
    }

    private void HideEditPopup()
    {
        _showEditPopup = false;
        _editModifierIndex = -1;
    }

    private async Task OnEditConfigChanged(ModifierConfig config)
    {
        _editCurrentConfig = config;
        await Task.CompletedTask;
    }

    private void OnEditErrorsChanged(Dictionary<string, string> errors)
    {
        _editIsValid = errors.Count == 0;
        _editErrorMessage = string.Join("; ", errors.Values);
    }

    private async Task ConfirmEdit()
    {
        if (_editModifierIndex >= 0 && _editModifierIndex < Preset.Modifiers.Count)
        {
            Preset.Modifiers[_editModifierIndex].Config = _editCurrentConfig;
            await NotifyChanged();
        }
        HideEditPopup();
    }
}
