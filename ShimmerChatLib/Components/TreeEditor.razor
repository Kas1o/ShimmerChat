@using System.Reflection
@using ShimmerChatLib.Generation
@inject ILocService Loc

@if (_info == null)
{
    <div class="tree-node-card" style="border-left-color: var(--node-debug);">
        <div class="tn-header @(_isDraggingSelf ? "tn-dragging" : "")"
             draggable="@(_isDraggable ? "true" : null)"
             @ondragstart="OnDragStart" @ondragend="OnDragEnd">
            <span class="tn-icon">●</span>
            <span class="tn-label">@Node.GetType().Name</span>
            <span class="tn-name">@Node.Name</span>
            <div class="tn-actions">
                @if (CopyMe != null)
                {
                    <button class="tn-btn tn-btn-copy" @onclick="() => CopyMe?.Invoke(Node)"
                            @onclick:stopPropagation="true" title="@Loc["tree_editor.copy"]">📋</button>
                }
                @if (RemoveMe != null && Depth > 0)
                {
                    <button class="tn-btn tn-btn-del" @onclick="() => RemoveMe?.Invoke(Node)"
                            @onclick:stopPropagation="true" title="@Loc["tree_editor.remove"]">✕</button>
                }
            </div>
        </div>
    </div>
}
else
{
    var isContainer = typeof(IList<IGenerationNode>).IsAssignableFrom(
        Node.GetType().GetProperties().FirstOrDefault(p =>
            p.PropertyType.IsGenericType &&
            p.PropertyType.GetGenericTypeDefinition() == typeof(List<>) &&
            typeof(IGenerationNode).IsAssignableFrom(p.PropertyType.GenericTypeArguments[0])
        )?.PropertyType ?? typeof(object));

    <div class="tree-node-card" style="border-left-color: @_info.Color;">
        <div class="tn-header @(_isDraggingSelf ? "tn-dragging" : "")"
             @onclick="ToggleExpand"
             draggable="@(_isDraggable ? "true" : null)"
             @ondragstart="OnDragStart" @ondragend="OnDragEnd">
            <span class="tn-icon">@_info.Icon</span>
            <span class="tn-label">@Loc[_info.LabelKey]</span>
            <input class="tn-name-input" @bind="Node.Name" @bind:event="oninput"
                   @onkeydown="OnNameKeyDown" @onclick:stopPropagation="true" placeholder="@Loc["tree_editor.name_placeholder"]" />
            <div class="tn-actions">
                @if (CopyMe != null)
                {
                    <button class="tn-btn tn-btn-copy" @onclick="() => CopyMe?.Invoke(Node)"
                            @onclick:stopPropagation="true" title="@Loc["tree_editor.copy"]">📋</button>
                }
                @if (RemoveMe != null && Depth > 0)
                {
                    <button class="tn-btn tn-btn-del" @onclick="() => RemoveMe?.Invoke(Node)"
                            @onclick:stopPropagation="true" title="@Loc["tree_editor.remove"]">✕</button>
                }
                @if (isContainer)
                {
                    <button class="tn-btn tn-btn-exp" @onclick="ToggleExpand" title="@(_expanded ? Loc["tree_editor.collapse"] : Loc["tree_editor.expand"])">
                        @(_expanded ? "▾" : "▸")
                    </button>
                }
            </div>
        </div>

        @if (_expanded)
        {
            <div class="tn-body">
                @* Custom editor via [NodeEditor] *@
                @if (_customEditorType != null)
                {
                    <ErrorBoundary @key="@Node.Id">
                        <ChildContent>
                            <DynamicComponent Type="_customEditorType" Parameters="@_editorParams" @key="@Node.Id" />
                        </ChildContent>
                        <ErrorContent Context="ex">
                            <div class="tn-custom-editor-error" title="@ex?.ToString()">
                                <span class="tn-error-icon">⚠</span>
                                <span class="tn-error-msg">Editor error: @_customEditorType.Name — @ex?.Message</span>
                            </div>
                        </ErrorContent>
                    </ErrorBoundary>
                }
                else
                {
                    @* Auto-generated editor *@
                    <NodeBodyRenderer Node="@Node" Depth="@Depth"
                                      OnTreeChanged="OnTreeChanged"
                                      RemoveMe="RemoveMe"
                                      CopyMe="CopyMe" />
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public IGenerationNode Node { get; set; } = default!;
    [Parameter] public int Depth { get; set; }
    [Parameter] public EventCallback OnTreeChanged { get; set; }
    [Parameter] public Action<IGenerationNode>? RemoveMe { get; set; }
    [Parameter] public Action<IGenerationNode>? CopyMe { get; set; }

    /// <summary>
    /// The parent list this node belongs to. When set, the node becomes draggable.
    /// </summary>
    [Parameter] public IList<IGenerationNode>? ParentList { get; set; }

    /// <summary>
    /// For single-node slots: called when this node is dragged away.
    /// </summary>
    [Parameter] public Func<Task>? OnDragRemove { get; set; }

    [CascadingParameter] public TreeDragContext? DragContext { get; set; }

    private NodeInfoAttribute? _info;
    private Type? _customEditorType;
    private Dictionary<string, object> _editorParams = new();
    private bool _expanded = true;
    private bool _isDraggingSelf => DragContext?.DraggedNode == Node;
    private bool _isDraggable => (ParentList != null && Depth > 0) || OnDragRemove != null;

    protected override void OnParametersSet()
    {
        var type = Node.GetType();
        _info = type.GetCustomAttribute<NodeInfoAttribute>();
        _customEditorType = type.GetCustomAttribute<NodeEditorAttribute>()?.EditorType;
        // Must create a NEW dictionary instance so that Blazor detects the parameter change
        // and propagates the updated Node to the DynamicComponent / custom editor.
        _editorParams = new Dictionary<string, object>
        {
            ["Node"] = Node,
            ["OnChanged"] = EventCallback.Factory.Create<IGenerationNode>(this, _ => OnTreeChanged.InvokeAsync()),
            ["OnTreeChanged"] = OnTreeChanged,
            ["Depth"] = Depth,
            ["CopyMe"] = CopyMe
        };
    }

    private void ToggleExpand() => _expanded = !_expanded;

    private async Task OnNameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await OnTreeChanged.InvokeAsync();
    }

    // ─── Drag Source ───────────────────────────────────

    private async Task OnDragStart(DragEventArgs e)
    {
        if (DragContext == null || !_isDraggable) return;

        // setData + effectAllowed handled synchronously by JS listener in util.js
        e.DataTransfer.EffectAllowed = "move";

        if (ParentList != null)
        {
            DragContext.BeginDrag(Node, ParentList, () => OnTreeChanged.InvokeAsync());
        }
        else if (OnDragRemove != null)
        {
            DragContext.BeginDrag(Node, OnDragRemove, () => OnTreeChanged.InvokeAsync());
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnDragEnd(DragEventArgs e)
    {
        DragContext?.EndDrag();
        await InvokeAsync(StateHasChanged);
    }
}
