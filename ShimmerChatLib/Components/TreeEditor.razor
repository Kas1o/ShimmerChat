@using System.Reflection
@using ShimmerChatLib.Generation
@inject ILocService Loc

@if (_info == null)
{
    <div class="tree-node-card" style="border-left-color: #888;">
        <div class="tn-header">
            <span class="tn-icon">●</span>
            <span class="tn-label">@Node.GetType().Name</span>
            <span class="tn-name">@Node.Name</span>
            <div class="tn-actions">
                @if (CopyMe != null)
                {
                    <button class="tn-btn tn-btn-copy" @onclick="() => CopyMe?.Invoke(Node)"
                            @onclick:stopPropagation="true" title="Copy">📋</button>
                }
                @if (RemoveMe != null && Depth > 0)
                {
                    <button class="tn-btn tn-btn-del" @onclick="() => RemoveMe?.Invoke(Node)"
                            @onclick:stopPropagation="true" title="Remove">✕</button>
                }
            </div>
        </div>
    </div>
}
else
{
    var isContainer = typeof(IList<IGenerationNode>).IsAssignableFrom(
        Node.GetType().GetProperties().FirstOrDefault(p =>
            p.PropertyType.IsGenericType &&
            p.PropertyType.GetGenericTypeDefinition() == typeof(List<>) &&
            typeof(IGenerationNode).IsAssignableFrom(p.PropertyType.GenericTypeArguments[0])
        )?.PropertyType ?? typeof(object));

    <div class="tree-node-card" style="border-left-color: @_info.Color;">
        <div class="tn-header" @onclick="ToggleExpand">
            <span class="tn-icon">@_info.Icon</span>
            <span class="tn-label">@Loc[_info.LabelKey]</span>
            <input class="tn-name-input" @bind="Node.Name" @bind:event="oninput"
                   @onkeydown="OnNameKeyDown" @onclick:stopPropagation="true" placeholder="Name" />
            <div class="tn-actions">
                @if (CopyMe != null)
                {
                    <button class="tn-btn tn-btn-copy" @onclick="() => CopyMe?.Invoke(Node)"
                            @onclick:stopPropagation="true" title="Copy">📋</button>
                }
                @if (RemoveMe != null && Depth > 0)
                {
                    <button class="tn-btn tn-btn-del" @onclick="() => RemoveMe?.Invoke(Node)"
                            @onclick:stopPropagation="true" title="Remove">✕</button>
                }
                @if (isContainer)
                {
                    <button class="tn-btn tn-btn-exp" @onclick="ToggleExpand" title="@(_expanded ? "Collapse" : "Expand")">
                        @(_expanded ? "▾" : "▸")
                    </button>
                }
            </div>
        </div>

        @if (_expanded)
        {
            <div class="tn-body">
                @* Custom editor via [NodeEditor] *@
                @if (_customEditorType != null)
                {
                    <DynamicComponent Type="_customEditorType" Parameters="@_editorParams" />
                }
                else
                {
                    @* Auto-generated editor *@
                    <NodeBodyRenderer Node="@Node" Depth="@Depth"
                                      OnTreeChanged="OnTreeChanged"
                                      RemoveMe="RemoveMe"
                                      CopyMe="CopyMe" />
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public IGenerationNode Node { get; set; } = default!;
    [Parameter] public int Depth { get; set; }
    [Parameter] public EventCallback OnTreeChanged { get; set; }
    [Parameter] public Action<IGenerationNode>? RemoveMe { get; set; }
    [Parameter] public Action<IGenerationNode>? CopyMe { get; set; }

    private NodeInfoAttribute? _info;
    private Type? _customEditorType;
    private Dictionary<string, object> _editorParams = new();
    private bool _expanded = true;

    protected override void OnInitialized()
    {
        var type = Node.GetType();
        _info = type.GetCustomAttribute<NodeInfoAttribute>();

        _customEditorType = type.GetCustomAttribute<NodeEditorAttribute>()?.EditorType;

        _editorParams = new Dictionary<string, object>
        {
            ["Node"] = Node,
            ["OnChanged"] = EventCallback.Factory.Create<IGenerationNode>(this, _ => OnTreeChanged.InvokeAsync())
        };
    }

    private void ToggleExpand() => _expanded = !_expanded;

    private async Task OnNameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await OnTreeChanged.InvokeAsync();
    }
}

