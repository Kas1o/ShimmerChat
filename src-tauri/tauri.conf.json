{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "ShimmerChat",
  "version": "0.0.0-placeholder",
  "identifier": "com.shimmerchat.desktop",
  "build": {
    "frontendDist": "./frontend",
    "devUrl": "http://127.0.0.1:5000",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "ShimmerChat",
        "width": 1280,
        "height": 840,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "binaries/shimmer-server/": "./shimmer-server/"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
